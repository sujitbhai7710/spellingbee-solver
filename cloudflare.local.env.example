# Copy this file to `cloudflare.local.env`, fill in the values, then run:
#   powershell -ExecutionPolicy Bypass -File .\scripts\sync-worker-secrets.ps1
#   powershell -ExecutionPolicy Bypass -File .\scripts\purge-analysis-cache.ps1
#
# GitHub token recommendation:
# - Prefer a fine-grained personal access token over a classic token.
# - Give it access only to https://github.com/gogibeta/spellingbee-solver
# - Repository permission needed here: Contents = Read and write
# - Classic PAT fallback only if needed: `repo` scope

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_WORKER_NAME=spelling-bee-api
CLOUDFLARE_KV_NAMESPACE_ID=
APIKEY=
GITHUB_TOKEN=
GITHUB_REPO_URL=https://github.com/gogibeta/spellingbee-solver
NVIDIA_NIM_API_KEY=
