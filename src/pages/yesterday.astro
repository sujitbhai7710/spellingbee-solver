---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Redirecting to Puzzle Archive" description="The Yesterday's Answers page has been moved to the Puzzle Archive.">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-20 text-center">
    <div class="card-elevated p-8 sm:p-12">
      <div class="mx-auto w-16 h-16 bg-amber-50 rounded-2xl flex items-center justify-center mb-6">
        <svg class="w-8 h-8 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
          <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
        </svg>
      </div>
      <h1 class="text-2xl font-bold text-gray-900 mb-3">This Page Has Moved</h1>
      <p class="text-gray-500 mb-6 leading-relaxed">
        Yesterday's answers can now be found in our puzzle archive. You'll be redirected automatically.
      </p>
      <a href="/archive" class="btn-primary inline-flex">
        Go to Puzzle Archive
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M6.5 3.5L11 8l-4.5 4.5L5.5 11 8.5 8 5.5 5z"/></svg>
      </a>
      <p class="text-xs text-gray-400 mt-4">Redirecting in a moment...</p>
    </div>
  </div>
</BaseLayout>

<script>
  // Client-side redirect after a short delay
  setTimeout(function() {
    window.location.href = '/archive';
  }, 2000);
</script>
