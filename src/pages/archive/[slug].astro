---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { readPublicJson, readPublicText } from '../../lib/site-data';
import { buildArchivePath } from '../../lib/utils';

export function getStaticPaths() {
  const summaries = readPublicJson('site-data/archive-summaries.json', []) || [];
  return summaries
    .filter((summary) => summary?.slug)
    .map((summary) => ({
      params: { slug: summary.slug },
      props: { summary },
    }));
}

const summary = Astro.props.summary || {};
const slug = Astro.params.slug || summary.slug || '';
const bundle = readPublicJson(`site-data/archive/${slug}.json`, null);
const detailHtml = readPublicText(`site-data/archive-html/${slug}.html`, '');
const puzzle = bundle?.puzzle || summary || {};
const titleDate = puzzle.date || summary.date || 'Spelling Bee Archive';
const wordCount = Number(puzzle.word_count || summary.word_count || 0);
const pangramCount = Number(puzzle.pangrams_count || summary.pangrams_count || 0);
const totalPoints = Number(bundle?.totalPoints || 0);

const archivePageSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: `Spelling Bee Answer today with Clue and Meaning (${titleDate})`,
  url: `https://spellingbeesolver.dev${buildArchivePath(titleDate)}`,
  description: `Spelling Bee answers, clues, meanings, charts, and analysis for ${titleDate}.`,
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://spellingbeesolver.dev/' },
      { '@type': 'ListItem', position: 2, name: 'Archive', item: 'https://spellingbeesolver.dev/archive' },
      { '@type': 'ListItem', position: 3, name: titleDate, item: `https://spellingbeesolver.dev${buildArchivePath(titleDate)}` },
    ],
  },
});
---

<BaseLayout title={`Spelling Bee Answer today with Clue and Meaning (${titleDate})`} description={`See the Spelling Bee answers with clue and meaning for ${titleDate}. Full archive analysis with ${wordCount} answers, ${pangramCount} pangrams, and ${totalPoints} total points.`} schema={archivePageSchema}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
    <div class="mb-6">
      <a href="/archive" class="text-sm font-semibold text-amber-600 hover:text-amber-700 inline-flex items-center gap-1">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M9.5 12.5L5 8l4.5-4.5L10.5 5 7.5 8l3 3z"/></svg>
        Back to Archive
      </a>
    </div>

    {detailHtml ? (
      <Fragment set:html={detailHtml} />
    ) : (
      <div class="card-elevated p-8 text-center">
        <h1 class="text-2xl font-bold text-gray-900 mb-3">{titleDate}</h1>
        <p class="text-gray-500">The prebuilt archive detail for this puzzle is missing from the current snapshot.</p>
      </div>
    )}
  </div>
</BaseLayout>
