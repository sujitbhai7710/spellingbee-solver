---
import BaseLayout from '../layouts/BaseLayout.astro';

export function getStaticPaths() {
  const paths = [];
  const months = ['january','february','march','april','may','june','july','august','september','october','november','december'];
  const today = new Date();
  for (let i = 0; i < 100; i++) {
    const d = new Date(today);
    d.setDate(today.getDate() - i);
    const month = months[d.getMonth()];
    const day = d.getDate();
    const year = d.getFullYear();
    paths.push({
      params: { slug: `answer-for-${month}-${day}-${year}` },
    });
  }
  return paths;
}
---

<BaseLayout title="Spelling Bee Answers" description="Find answers for any NYT Spelling Bee puzzle by date.">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8 sm:py-10">
    <div class="mb-6">
      <a href="/archive" class="text-sm font-semibold text-amber-600 hover:text-amber-700 mb-3 inline-flex items-center gap-1">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M9.5 12.5L5 8l4.5-4.5L10.5 5 7.5 8l3 3z"/></svg>
        Back to Archive
      </a>
      <h1 id="page-h1" class="text-2xl sm:text-3xl font-black text-gray-900">Spelling Bee Answers</h1>
    </div>

    <div id="answer-content">
      <div class="text-center py-12">
        <div class="inline-block w-10 h-10 border-[3px] border-amber-400 border-t-transparent rounded-full animate-spin"></div>
        <p class="text-gray-500 mt-3 font-medium">Loading puzzle...</p>
      </div>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ API_BASE: 'https://spelling-bee-api.sbsolver.workers.dev' }}>
  function parseSlug() {
    var path = window.location.pathname;
    var slug = path.replace(/^\//, '').replace(/\/$/, '');
    var parts = slug.replace(/^answer-for-/, '').split('-');
    var months = ['january','february','march','april','may','june','july','august','september','october','november','december'];
    if (parts.length >= 3) {
      var monthName = parts[0].charAt(0).toUpperCase() + parts[0].slice(1);
      var day = parseInt(parts[1]);
      var year = parts[2];
      if (months.includes(parts[0].toLowerCase()) && day > 0 && year.length === 4) {
        return monthName + ' ' + day + ', ' + year;
      }
    }
    return null;
  }

  function slugFromDate(date) {
    return 'answer-for-' + date.toLowerCase().replace(/,\s*/g, '-').replace(/\s+/g, '-');
  }

  async function loadPuzzle() {
    var dateStr = parseSlug();
    if (!dateStr) {
      window.location.href = '/archive';
      return;
    }
    try {
      // SINGLE enriched API call — gets ALL data including nytbee features
      var res = await fetch(API_BASE + '/api/puzzle/enriched/' + encodeURIComponent(dateStr));
      var data = await res.json();

      if (!data.success || !data.puzzle) {
        document.getElementById('answer-content').innerHTML = '<div class="text-center py-12"><p class="text-gray-500 text-lg font-medium">No puzzle found for ' + dateStr + '</p><a href="/archive" class="btn-primary mt-4 inline-flex">Browse Archive</a></div>';
        return;
      }

      var puzzle = data.puzzle;
      var words = data.words || [];
      var totalPoints = data.totalPoints || 0;
      var geniusThreshold = data.geniusThreshold || Math.ceil(totalPoints * 0.70);
      var hasPerfectPangram = data.hasPerfectPangram || false;
      var perfectPangrams = data.perfectPangrams || [];
      var geniusAnalysis = data.geniusAnalysis || {};
      var pangramHistory = data.pangramHistory || {};
      var wordFrequency = data.wordFrequency || {};
      var letterHistory = data.letterHistory || {};
      var percentiles = data.percentiles || {};
      var excludedWords = data.excludedWords || [];
      var excludedCount = data.excludedCount || 0;
      var comparisonData = data.comparisonData || {};
      var mostCommonWords = data.mostCommonWords || [];
      var globalWordLengthDistribution = data.globalWordLengthDistribution || {};
      var totalAnswersEver = data.totalAnswersEver || 0;
      var uniqueWordsEver = data.uniqueWordsEver || 0;

      var center = puzzle.center || puzzle.letters || '';
      var allLetters = puzzle.all_letters || '';
      var outerLetters = Array.isArray(puzzle.outer_letters) ? puzzle.outer_letters : allLetters.split('').filter(function(l) { return l !== center; });
      var pangrams = words.filter(function(w) { return w.is_pangram === 1; });
      var regularWords = words.filter(function(w) { return w.is_pangram !== 1; });

      // Update page title and H1 dynamically
      document.title = 'Spelling Bee Answers for ' + puzzle.date + ' | SbSolver';
      var h1El = document.getElementById('page-h1');
      if (h1El) h1El.textContent = 'Spelling Bee Answers for ' + puzzle.date;

      // Build honeycomb HTML
      var honeycombHtml = '<div class="flex justify-center mb-6"><div class="p-4 bg-gradient-to-br from-amber-50 to-yellow-50 rounded-2xl border border-amber-100 inline-block">';
      honeycombHtml += '<div class="honeycomb honeycomb-md mx-auto" style="margin-bottom:0;">';
      outerLetters.forEach(function(letter, i) {
        honeycombHtml += '<div class="hex-cell hex-outer hex-pos-' + i + '">';
        honeycombHtml += '<svg viewBox="0 -17 256 256" fill="none" class="hex-svg">';
        honeycombHtml += '<path d="M0 111L64 0.148707L192 0.148707L256 111L192 221.851L64 221.851L0 111Z" fill="currentColor" />';
        honeycombHtml += '</svg><span class="hex-letter">' + letter + '</span></div>';
      });
      honeycombHtml += '<div class="hex-cell hex-center hex-pos-center">';
      honeycombHtml += '<svg viewBox="0 -17 256 256" fill="none" class="hex-svg">';
      honeycombHtml += '<path d="M0 111L64 0.148707L192 0.148707L256 111L192 221.851L64 221.851L0 111Z" fill="currentColor" />';
      honeycombHtml += '</svg><span class="hex-letter hex-letter-center">' + center + '</span></div>';
      honeycombHtml += '</div></div></div>';

      // Stats
      var statsHtml = '<div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">' +
        '<div class="stat-card"><p class="stat-value">' + puzzle.word_count + '</p><p class="stat-label">Words</p></div>' +
        '<div class="stat-card"><p class="stat-value">' + puzzle.pangrams_count + '</p><p class="stat-label">Pangrams</p></div>' +
        '<div class="stat-card"><p class="stat-value">' + totalPoints + '</p><p class="stat-label">Max Points</p></div>' +
        '<div class="stat-card"><p class="stat-value">' + geniusThreshold + '</p><p class="stat-label">Points for Genius</p></div></div>';

      // Letters info
      var lettersInfo = '<div class="text-sm text-gray-500 mb-3"><span class="font-semibold text-gray-700">Center:</span> <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-amber-100 text-amber-700 text-xs font-bold">' + center + '</span><span class="mx-2 text-gray-300">|</span><span class="font-semibold text-gray-700">Letters:</span> ';
      allLetters.split('').forEach(function(l) {
        lettersInfo += '<span class="inline-flex items-center justify-center w-6 h-6 rounded text-xs font-bold mx-0.5 ' + (l === center ? 'bg-amber-100 text-amber-700' : 'bg-gray-100 text-gray-600') + '">' + l + '</span>';
      });
      lettersInfo += '</div>';

      if (hasPerfectPangram) {
        lettersInfo += '<div class="text-sm text-emerald-700 font-semibold flex items-center gap-1.5"><svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="#10B981" stroke-width="2"><circle cx="10" cy="10" r="9"/><path d="M6 10l3 3 5-5" stroke-linecap="round" stroke-linejoin="round"/></svg> Has Perfect Pangram!</div>';
      }

      // Genius analysis
      var geniusHtml = '<div class="card-elevated p-5 mb-6">' +
        '<h2 class="text-sm font-bold text-gray-800 mb-3 flex items-center gap-2">' +
        '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2" stroke-linecap="round"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>' +
        'Genius Requirement Analysis</h2>' +
        '<p class="text-sm text-gray-600 leading-relaxed">' +
        'Genius requires between <strong>' + (geniusAnalysis.minWordsForGenius || '?') + '</strong> and <strong>' + (geniusAnalysis.maxWordsForGenius || '?') + '</strong> words. ' +
        (pangrams.length > 0 ?
          'If you don\'t get the pangrams, you need <strong>' + (geniusAnalysis.pctWithoutPangrams || 70) + '%</strong> of the total points. ' +
          (geniusAnalysis.pctWithPangrams >= 100 ? 
            '<span class="text-amber-600 font-semibold">Getting the pangrams alone already earns enough points to reach Genius!</span>' :
            'If you get the pangrams, you only need <strong>' + (geniusAnalysis.pctWithPangrams || 0) + '%</strong> of the remaining points.') :
          'You need <strong>' + (geniusAnalysis.pctWithoutPangrams || 70) + '%</strong> of the total points to reach genius.'
        ) + '</p></div>';

      // Spoiler reveal button
      var revealBtn = '<div class="mb-6"><button id="reveal-answers-btn-dynamic" class="btn-secondary text-sm !py-2.5 w-full sm:w-auto" type="button"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg> Show All Answers</button><p class="text-xs text-gray-400 mt-1.5">Spoilers ahead! Click to reveal the complete word list.</p></div>';

      // Perfect Pangrams
      var perfectPangramsHtml = '';
      if (hasPerfectPangram && perfectPangrams.length > 0) {
        perfectPangramsHtml = '<div class="mb-6 p-5 bg-emerald-50 border border-emerald-200 rounded-xl"><h2 class="text-sm font-bold text-emerald-800 mb-2 flex items-center gap-2"><svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="#10B981" stroke-width="2"><circle cx="10" cy="10" r="9"/><path d="M6 10l3 3 5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>Perfect Pangram' + (perfectPangrams.length > 1 ? 's' : '') + '!</h2><p class="text-xs text-emerald-600 mb-3">A perfect pangram uses all 7 letters exactly once (7 letters total).</p><div class="flex flex-wrap gap-2">' + perfectPangrams.map(function(w) { return '<span class="perfect-pangram-chip">' + w + '</span>'; }).join('') + '</div></div>';
      }

      // Pangrams
      var pangramsHtml = pangrams.length > 0 ? '<div class="mb-8"><h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2"><svg width="16" height="16" viewBox="0 0 20 20" fill="#F59E0B"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.33L10 13.27l-4.77 2.51.91-5.33L2.27 6.62l5.34-.78z"/></svg> Pangrams (' + pangrams.length + ')</h2><div class="flex flex-wrap gap-2">' + pangrams.map(function(w) { return '<span class="pangram-chip"><span class="star">&#9733;</span>' + w.word + ' <span class="text-xs text-amber-500 opacity-70">' + w.length + '</span></span>'; }).join('') + '</div></div>' : '';

      // Words by length
      var byLen = {};
      for (var w of regularWords) { var l = w.length; if (!byLen[l]) byLen[l] = []; byLen[l].push(w); }
      var wordsHtml = '<div><h2 class="text-lg font-bold text-gray-800 mb-4">All Words (' + words.length + ')</h2><div class="card-elevated divide-y divide-gray-50 max-h-[600px] overflow-y-auto custom-scroll">' + Object.keys(byLen).sort(function(a,b) { return +b - +a; }).map(function(len) {
        return '<div class="px-5 py-4"><p class="text-xs font-bold text-gray-400 mb-3 uppercase tracking-wider">' + len + '-Letter Words (' + byLen[len].length + ')</p><div class="flex flex-wrap gap-2">' + byLen[len].map(function(w) { return '<span class="word-chip">' + w.word + '</span>'; }).join('') + '</div></div>';
      }).join('') + '</div></div>';

      // Word length distribution chart
      var wordsByLenAll = {};
      for (var w of words) { var l = w.length; if (!wordsByLenAll[l]) wordsByLenAll[l] = []; wordsByLenAll[l].push(w); }
      var sortedLenAll = Object.keys(wordsByLenAll).sort(function(a,b) { return +a - +b; });
      var maxLenCount = Math.max.apply(null, Object.values(wordsByLenAll).map(function(v) { return v.length; }).concat([1]));

      var lenChartHtml = '<div class="mt-8 card-elevated p-6"><h2 class="text-lg font-bold text-gray-800 mb-2">Length of Words in This Puzzle</h2><p class="text-xs text-gray-400 mb-4">Hover over bars to see which words belong to each length.</p><div class="space-y-2.5">';
      for (var i = 0; i < sortedLenAll.length; i++) {
        var len = sortedLenAll[i]; var count = wordsByLenAll[len].length; var pct = Math.round((count / words.length) * 100);
        var barWidth = Math.max((count / maxLenCount) * 100, 3); var isPangramLen = wordsByLenAll[len].some(function(w) { return w.is_pangram; });
        var wordList = wordsByLenAll[len].map(function(w) { return w.word; }).join(', ');
        lenChartHtml += '<div class="flex items-center gap-3 cursor-default" title="' + wordList + '"><span class="w-8 text-sm font-bold text-gray-600 text-right">' + len + '</span><div class="flex-1"><div class="w-full bg-gray-100 rounded-full h-8 overflow-hidden"><div class="h-8 rounded-full flex items-center pl-3 text-xs font-bold ' + (isPangramLen ? 'bg-gradient-to-r from-amber-300 to-amber-500 text-white' : 'bg-gray-300 text-gray-700') + '" style="width:' + barWidth + '%">' + count + (isPangramLen ? ' <span class="ml-1 text-amber-100">&#9733;</span>' : '') + '</div></div></div><span class="text-xs text-gray-400 font-medium w-10 text-right">' + pct + '%</span></div>';
      }
      lenChartHtml += '</div></div>';

      // Points by Length chart
      var pointsByLength = {};
      for (var w of words) { var l = w.length; var pts = l === 4 ? 1 : l + (w.is_pangram ? 7 : 0); if (!pointsByLength[l]) pointsByLength[l] = 0; pointsByLength[l] += pts; }
      var maxPointsByLen = Math.max.apply(null, Object.values(pointsByLength).concat([1]));
      var pointsByLenHtml = '<div class="mt-6 card-elevated p-6"><h2 class="text-lg font-bold text-gray-800 mb-2">Points Available by Length</h2><p class="text-xs text-gray-400 mb-4">How the total score breaks down by word length.</p><div class="space-y-2.5">';
      for (var i = 0; i < sortedLenAll.length; i++) {
        var len = sortedLenAll[i]; var pts = pointsByLength[len] || 0; var pct = totalPoints > 0 ? Math.round((pts / totalPoints) * 100) : 0;
        var barWidth = Math.max((pts / maxPointsByLen) * 100, 3);
        pointsByLenHtml += '<div class="flex items-center gap-3"><span class="w-8 text-sm font-bold text-gray-600 text-right">' + len + '</span><div class="flex-1"><div class="w-full bg-gray-100 rounded-full h-8 overflow-hidden"><div class="h-8 rounded-full flex items-center pl-3 text-xs font-bold bg-gradient-to-r from-purple-300 to-purple-500 text-white" style="width:' + barWidth + '%">' + pts + ' pts</div></div></div><span class="text-xs text-gray-400 font-medium w-10 text-right">' + pct + '%</span></div>';
      }
      pointsByLenHtml += '</div></div>';

      // How Long Are Words in the Bee? - Global section
      var globalLenHtml = '';
      if (Object.keys(globalWordLengthDistribution).length > 0) {
        var globalLenEntries = Object.entries(globalWordLengthDistribution).sort(function(a,b) { return +a[0] - +b[0]; });
        var globalMaxLen = Math.max.apply(null, globalLenEntries.map(function(e) { return e[1]; }).concat([1]));

        globalLenHtml = '<div class="mt-8 card-elevated p-6"><h2 class="text-lg font-bold text-gray-800 mb-2">How Long Are Words in the Bee?</h2>';
        globalLenHtml += '<p class="text-xs text-gray-400 mb-4">There have been ' + totalAnswersEver.toLocaleString() + ' answers ever accepted in the Bee - with ' + uniqueWordsEver.toLocaleString() + ' unique words. Below are the distributions of the lengths of these words.</p>';
        globalLenHtml += '<div class="grid grid-cols-1 md:grid-cols-2 gap-6">';

        // This Puzzle
        globalLenHtml += '<div><h4 class="text-xs font-bold text-gray-500 mb-2 uppercase">This Puzzle</h4><div class="space-y-1.5">';
        for (var i = 0; i < sortedLenAll.length; i++) {
          var len = sortedLenAll[i]; var count = wordsByLenAll[len].length; var thisMax = Math.max.apply(null, Object.values(wordsByLenAll).map(function(v) { return v.length; }).concat([1]));
          var barWidth = Math.max((count / thisMax) * 100, 3); var isPangramLen = wordsByLenAll[len].some(function(w) { return w.is_pangram; });
          globalLenHtml += '<div class="flex items-center gap-2"><span class="w-6 text-xs font-bold text-gray-500 text-right">' + len + '</span><div class="flex-1"><div class="w-full bg-gray-100 rounded-full h-5 overflow-hidden"><div class="h-5 rounded-full flex items-center pl-2 text-xs font-bold ' + (isPangramLen ? 'bg-gradient-to-r from-amber-400 to-amber-500 text-white' : 'bg-gradient-to-r from-blue-400 to-blue-500 text-white') + '" style="width:' + barWidth + '%">' + count + '</div></div></div></div>';
        }
        globalLenHtml += '</div></div>';

        // All Puzzles
        globalLenHtml += '<div><h4 class="text-xs font-bold text-gray-500 mb-2 uppercase">All Puzzles</h4><div class="space-y-1.5">';
        for (var i = 0; i < globalLenEntries.length; i++) {
          var len = globalLenEntries[i][0]; var count = globalLenEntries[i][1];
          var barWidth = Math.max((count / globalMaxLen) * 100, 3);
          globalLenHtml += '<div class="flex items-center gap-2"><span class="w-6 text-xs font-bold text-gray-500 text-right">' + len + '</span><div class="flex-1"><div class="w-full bg-gray-100 rounded-full h-5 overflow-hidden"><div class="h-5 rounded-full flex items-center pl-2 text-xs font-bold bg-gradient-to-r from-purple-400 to-purple-500 text-white" style="width:' + barWidth + '%">' + count.toLocaleString() + '</div></div></div></div>';
        }
        globalLenHtml += '</div></div>';

        globalLenHtml += '</div></div>';
      }

      // First letter counts
      var wordsByFirstLetter = {};
      for (var w of words) { var first = w.word[0] ? w.word[0].toUpperCase() : ''; if (!first) continue; if (!wordsByFirstLetter[first]) wordsByFirstLetter[first] = { count: 0, isPangram: false, words: [] }; wordsByFirstLetter[first].count++; wordsByFirstLetter[first].words.push(w.word); if (w.is_pangram) wordsByFirstLetter[first].isPangram = true; }
      var sortedFirstLetters = Object.keys(wordsByFirstLetter).sort();
      var maxFirstLetterCount = Math.max.apply(null, Object.values(wordsByFirstLetter).map(function(v) { return v.count; }).concat([1]));

      var firstLetterBtnHtml = '<div class="mt-6"><button id="show-first-letter-btn-dynamic" class="btn-secondary text-sm !py-2.5 w-full sm:w-auto" type="button"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 20V10M12 20V4M6 20v-6"/></svg> Show Counts by First Letter</button><p class="text-xs text-gray-400 mt-1.5">Red bars indicate pangram(s) starting with that letter.</p></div>';

      var firstLetterChartHtml = '<div id="first-letter-chart-dynamic" class="hidden mt-4 card-elevated p-6"><div class="space-y-2.5">';
      for (var i = 0; i < sortedFirstLetters.length; i++) {
        var letter = sortedFirstLetters[i]; var info = wordsByFirstLetter[letter]; var barWidth = Math.max((info.count / maxFirstLetterCount) * 100, 8);
        firstLetterChartHtml += '<div class="flex items-center gap-3" title="' + info.words.join(', ') + '"><span class="w-8 text-sm font-black text-right ' + (info.isPangram ? 'text-red-500' : 'text-gray-600') + '">' + letter + '</span><div class="flex-1"><div class="w-full bg-gray-100 rounded-full h-7 overflow-hidden"><div class="h-7 rounded-full flex items-center pl-3 text-xs font-bold ' + (info.isPangram ? 'bg-red-400 text-white' : 'bg-gray-300 text-gray-700') + '" style="width:' + barWidth + '%">' + info.count + '</div></div></div>' + (info.isPangram ? '<span class="text-xs text-red-500 font-bold">PANGRAM</span>' : '') + '</div>';
      }
      firstLetterChartHtml += '</div></div>';

      // ========== NYTBEE NEW FEATURES ==========

      // Other Days With This Pangram
      var pangramHistoryHtml = '';
      if (Object.keys(pangramHistory).length > 0) {
        pangramHistoryHtml = '<div class="mt-6 card-elevated p-6"><h2 class="text-lg font-bold text-gray-800 mb-2 flex items-center gap-2"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> Other Days With This Pangram</h2><p class="text-xs text-gray-400 mb-4">See which other puzzles featured the same pangram word.</p>';
        Object.keys(pangramHistory).forEach(function(word) {
          var dates = pangramHistory[word];
          pangramHistoryHtml += '<div class="mb-3"><p class="text-sm font-bold text-amber-700 mb-1.5">' + word.toUpperCase() + '</p>';
          if (dates.length > 0) {
            pangramHistoryHtml += '<div class="flex flex-wrap gap-2">';
            dates.forEach(function(d) {
              pangramHistoryHtml += '<a href="/' + slugFromDate(d.date) + '" class="text-xs bg-purple-50 text-purple-700 px-2.5 py-1 rounded-full hover:bg-purple-100 transition-colors">' + d.date + ' (Center: ' + d.center + ')</a>';
            });
            pangramHistoryHtml += '</div>';
          } else {
            pangramHistoryHtml += '<p class="text-xs text-gray-400">No other puzzles with this pangram.</p>';
          }
          pangramHistoryHtml += '</div>';
        });
        pangramHistoryHtml += '</div>';
      }

      // How Does This Puzzle Compare? - 4 chart cards
      var percentilesHtml = '<div class="mt-6 card-elevated p-6"><h2 class="text-lg font-bold text-gray-800 mb-2 flex items-center gap-2"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2" stroke-linecap="round"><path d="M18 20V10M12 20V4M6 20v-6"/></svg> How Does This Puzzle Compare To Other Puzzles?</h2><p class="text-xs text-gray-400 mb-4">This puzzle\'s stats compared to all other puzzles.</p>';
      percentilesHtml += '<div class="grid grid-cols-1 md:grid-cols-2 gap-4">';

      // Card 1: Total Points
      var ptsPercentile = percentiles.total_points ? percentiles.total_points.percentile : 0;
      percentilesHtml += '<div class="p-4 bg-gray-50 rounded-xl"><h3 class="text-sm font-bold text-gray-800 mb-2">Total Points</h3><p class="text-xs text-gray-600 mb-3 leading-relaxed">';
      percentilesHtml += 'This puzzle\'s score of <strong>' + totalPoints + '</strong> was in the <strong>' + ptsPercentile + 'th</strong> percentile of all puzzles.';
      if (comparisonData.lastTimeScoreThisHigh) percentilesHtml += ' The last time there was a score this high was on ' + comparisonData.lastTimeScoreThisHigh + '.';
      if (comparisonData.highestScoreEver) percentilesHtml += ' The highest score ever was <strong>' + comparisonData.highestScoreEver.value + '</strong> on ' + comparisonData.highestScoreEver.date + '.';
      if (comparisonData.lowestScoreEver) percentilesHtml += ' The lowest score ever was <strong>' + comparisonData.lowestScoreEver.value + '</strong> on ' + comparisonData.lowestScoreEver.date + '.';
      percentilesHtml += '</p>';
      percentilesHtml += '<div class="relative"><div class="w-full bg-gray-200 rounded-full h-4 overflow-hidden"><div class="h-4 rounded-full bg-gradient-to-r from-blue-400 to-blue-600" style="width:' + ptsPercentile + '%"></div></div>';
      percentilesHtml += '<div class="absolute top-0 h-4 flex items-center" style="left:calc(' + ptsPercentile + '% - 8px)"><div class="w-4 h-4 bg-amber-500 rounded-full border-2 border-white shadow-md"></div></div></div>';
      percentilesHtml += '<div class="flex justify-between text-xs text-gray-400 mt-1"><span>' + (comparisonData.lowestScoreEver ? comparisonData.lowestScoreEver.value : '?') + ' pts</span><span>' + (comparisonData.highestScoreEver ? comparisonData.highestScoreEver.value : '?') + ' pts</span></div></div>';

      // Card 2: Word Count
      var wcPercentile = percentiles.word_count ? percentiles.word_count.percentile : 0;
      percentilesHtml += '<div class="p-4 bg-gray-50 rounded-xl"><h3 class="text-sm font-bold text-gray-800 mb-2">Number of Answers</h3><p class="text-xs text-gray-600 mb-3 leading-relaxed">';
      percentilesHtml += 'This puzzle\'s <strong>' + puzzle.word_count + '</strong> possible answers rank it in the <strong>' + wcPercentile + 'th</strong> percentile of all puzzles.';
      if (comparisonData.lastTimeWordCountThisHigh) percentilesHtml += ' The last time there were more answers was on ' + comparisonData.lastTimeWordCountThisHigh + '.';
      if (comparisonData.highestWordCountEver) percentilesHtml += ' The highest number of answers was <strong>' + comparisonData.highestWordCountEver.value + '</strong> on ' + comparisonData.highestWordCountEver.date + '.';
      if (comparisonData.lowestWordCountEver) percentilesHtml += ' The lowest number of answers was <strong>' + comparisonData.lowestWordCountEver.value + '</strong> on ' + comparisonData.lowestWordCountEver.date + '.';
      percentilesHtml += '</p>';
      percentilesHtml += '<div class="relative"><div class="w-full bg-gray-200 rounded-full h-4 overflow-hidden"><div class="h-4 rounded-full bg-gradient-to-r from-purple-400 to-purple-600" style="width:' + wcPercentile + '%"></div></div>';
      percentilesHtml += '<div class="absolute top-0 h-4 flex items-center" style="left:calc(' + wcPercentile + '% - 8px)"><div class="w-4 h-4 bg-amber-500 rounded-full border-2 border-white shadow-md"></div></div></div>';
      percentilesHtml += '<div class="flex justify-between text-xs text-gray-400 mt-1"><span>' + (comparisonData.lowestWordCountEver ? comparisonData.lowestWordCountEver.value : '?') + ' words</span><span>' + (comparisonData.highestWordCountEver ? comparisonData.highestWordCountEver.value : '?') + ' words</span></div></div>';

      // Card 3: Min Word Length for Genius
      percentilesHtml += '<div class="p-4 bg-gray-50 rounded-xl"><h3 class="text-sm font-bold text-gray-800 mb-2">Min Word Length for Genius</h3>';
      percentilesHtml += '<div class="text-4xl font-black text-purple-600 mb-2">' + (comparisonData.minWordLengthForGenius || '?') + '</div>';
      percentilesHtml += '<p class="text-xs text-gray-600 leading-relaxed">It takes a <strong>' + (comparisonData.minWordLengthForGenius || '?') + '</strong>-letter word for genius.';
      if (comparisonData.lastTimeWordCountThisHigh) percentilesHtml += ' The last time this happened was on ' + comparisonData.lastTimeWordCountThisHigh + '.';
      percentilesHtml += '</p></div>';

      // Card 4: Average Word Length
      percentilesHtml += '<div class="p-4 bg-gray-50 rounded-xl"><h3 class="text-sm font-bold text-gray-800 mb-2">Average Word Length</h3>';
      percentilesHtml += '<div class="flex items-end gap-3 mb-2"><div class="text-4xl font-black text-blue-600">' + (comparisonData.avgWordLengthThis || '?') + '</div><div class="text-sm text-gray-400 pb-1">this puzzle</div></div>';
      percentilesHtml += '<div class="flex items-end gap-3"><div class="text-2xl font-bold text-gray-400">' + (comparisonData.avgWordLengthAll || '?') + '</div><div class="text-xs text-gray-400 pb-0.5">all puzzles average</div></div>';
      percentilesHtml += '</div>';

      percentilesHtml += '</div></div>';

      // Haven't I Seen These Letters Before?
      var letterHistoryHtml = '';
      if (Object.keys(letterHistory).length > 0) {
        letterHistoryHtml = '<div class="mt-6 card-elevated p-6"><h2 class="text-lg font-bold text-gray-800 mb-2 flex items-center gap-2"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2" stroke-linecap="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg> Haven\'t I Seen These Letters Before?</h2><p class="text-xs text-gray-400 mb-4">Hover over any letter to see its history across all puzzles.</p><div class="flex flex-wrap gap-3 justify-center">';
        allLetters.split('').forEach(function(letter) {
          var info = letterHistory[letter] || {};
          var isCenter = letter === center;
          letterHistoryHtml += '<div class="group relative"><div class="w-14 h-14 rounded-xl flex items-center justify-center text-xl font-black cursor-default transition-all hover:scale-110 ' + (isCenter ? 'bg-amber-400 text-white shadow-md' : 'bg-gray-100 text-gray-700 hover:bg-gray-200') + '">' + letter + '</div>';
          letterHistoryHtml += '<div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-56 p-3 bg-gray-900 text-white rounded-xl text-xs opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-50 shadow-xl"><p class="font-bold text-base mb-1.5">' + letter + '</p><div class="space-y-1"><p>Center letter: <strong>' + (info.centerCount || 0) + '</strong> times</p><p>Appeared in: <strong>' + (info.totalCount || 0) + '</strong> puzzles</p>' + (info.firstCenterDate ? '<p>First as center: ' + info.firstCenterDate + '</p>' : '') + (info.lastCenterDate ? '<p>Last as center: ' + info.lastCenterDate + '</p>' : '') + (info.firstAppearanceDate ? '<p>First appeared: ' + info.firstAppearanceDate + '</p>' : '') + (info.lastAppearanceDate ? '<p>Last appeared: ' + info.lastAppearanceDate + '</p>' : '') + '</div></div></div>';
        });
        letterHistoryHtml += '</div>';

        // Bar charts for letter history
        letterHistoryHtml += '<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-4">';

        // Center Letter Frequency chart
        var maxCenterCount = 0;
        allLetters.split('').forEach(function(l) { var c = (letterHistory[l] || {}).centerCount || 0; if (c > maxCenterCount) maxCenterCount = c; });
        letterHistoryHtml += '<div><h4 class="text-xs font-bold text-gray-500 mb-2 uppercase">Times as Center Letter</h4><div class="space-y-1.5">';
        allLetters.split('').forEach(function(letter) {
          var info = letterHistory[letter] || {};
          var barWidth = maxCenterCount > 0 ? Math.max(((info.centerCount || 0) / maxCenterCount) * 100, 3) : 3;
          var isCenter = letter === center;
          letterHistoryHtml += '<div class="flex items-center gap-2"><span class="w-6 text-xs font-black text-right ' + (isCenter ? 'text-amber-600' : 'text-gray-500') + '">' + letter + '</span><div class="flex-1"><div class="w-full bg-gray-100 rounded-full h-5 overflow-hidden"><div class="h-5 rounded-full flex items-center pl-2 text-xs font-bold ' + (isCenter ? 'bg-gradient-to-r from-amber-400 to-amber-500 text-white' : 'bg-gradient-to-r from-gray-300 to-gray-400 text-white') + '" style="width:' + barWidth + '%">' + (info.centerCount || 0) + '</div></div></div></div>';
        });
        letterHistoryHtml += '</div></div>';

        // Total Appearances chart
        var maxTotalCount = 0;
        allLetters.split('').forEach(function(l) { var c = (letterHistory[l] || {}).totalCount || 0; if (c > maxTotalCount) maxTotalCount = c; });
        letterHistoryHtml += '<div><h4 class="text-xs font-bold text-gray-500 mb-2 uppercase">Total Appearances</h4><div class="space-y-1.5">';
        allLetters.split('').forEach(function(letter) {
          var info = letterHistory[letter] || {};
          var barWidth = maxTotalCount > 0 ? Math.max(((info.totalCount || 0) / maxTotalCount) * 100, 3) : 3;
          var isCenter = letter === center;
          letterHistoryHtml += '<div class="flex items-center gap-2"><span class="w-6 text-xs font-black text-right ' + (isCenter ? 'text-amber-600' : 'text-gray-500') + '">' + letter + '</span><div class="flex-1"><div class="w-full bg-gray-100 rounded-full h-5 overflow-hidden"><div class="h-5 rounded-full flex items-center pl-2 text-xs font-bold ' + (isCenter ? 'bg-gradient-to-r from-amber-400 to-amber-500 text-white' : 'bg-gradient-to-r from-blue-400 to-blue-500 text-white') + '" style="width:' + barWidth + '%">' + (info.totalCount || 0) + '</div></div></div></div>';
        });
        letterHistoryHtml += '</div></div>';

        letterHistoryHtml += '</div></div>';
      }

      // Haven't I Seen These Words Before?
      var wordFreqHtml = '';
      var freqWords = words.filter(function(w) { return wordFrequency[w.word] && wordFrequency[w.word].other_puzzles > 0; }).sort(function(a, b) { return (wordFrequency[b.word]?.other_puzzles || 0) - (wordFrequency[a.word]?.other_puzzles || 0); }).slice(0, 20);
      if (freqWords.length > 0) {
        wordFreqHtml = '<div class="mt-6 card-elevated p-6"><h2 class="text-lg font-bold text-gray-800 mb-2 flex items-center gap-2"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2" stroke-linecap="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg> Haven\'t I Seen These Words Before?</h2><p class="text-xs text-gray-400 mb-4">Words from this puzzle that appear frequently across other puzzles.</p><div class="flex flex-wrap gap-2">';
        freqWords.forEach(function(w) {
          var freq = wordFrequency[w.word];
          var cls = freq.other_puzzles > 20 ? 'bg-red-50 text-red-700' : freq.other_puzzles > 10 ? 'bg-orange-50 text-orange-700' : 'bg-blue-50 text-blue-700';
          wordFreqHtml += '<span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium ' + cls + '" title="Appears in ' + freq.other_puzzles + ' other puzzle' + (freq.other_puzzles !== 1 ? 's' : '') + '">' + w.word + ' <span class="opacity-60">(' + freq.other_puzzles + ')</span></span>';
        });
        wordFreqHtml += '</div>';

        // Add most common words globally
        wordFreqHtml += '<div class="mt-4 pt-4 border-t border-gray-100"><h3 class="text-sm font-bold text-gray-700 mb-3">The most common words in the Bee are:</h3><div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-x-4 gap-y-0.5 max-h-80 overflow-y-auto custom-scroll">';
        mostCommonWords.forEach(function(w) {
          wordFreqHtml += '<div class="flex justify-between text-xs py-0.5 border-b border-gray-50"><span class="text-gray-700">' + w.word + '</span><span class="text-gray-400 font-medium">' + w.count + '</span></div>';
        });
        wordFreqHtml += '</div></div></div>';
      }

      // Excluded Valid Words
      var excludedHtml = '';
      if (excludedCount > 0) {
        excludedHtml = '<div class="mt-6 card-elevated p-6"><h2 class="text-lg font-bold text-gray-800 mb-2 flex items-center gap-2"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2" stroke-linecap="round"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="2"/><line x1="9" y1="12" x2="15" y2="12"/><line x1="9" y1="16" x2="13" y2="16"/></svg> Valid Dictionary Words Not in Today\'s Official Answers</h2><p class="text-xs text-gray-400 mb-3">These ' + excludedCount + ' words follow the Spelling Bee rules but aren\'t in the NYT\'s official answer list. The NYT uses a curated dictionary that excludes obscure, offensive, or less common words.</p><button id="show-excluded-btn-dynamic" class="btn-secondary text-xs !py-2 mb-3" type="button">Show Excluded Words (' + excludedCount + ')</button><div id="excluded-words-container-dynamic" class="hidden"><div class="flex flex-wrap gap-1.5">';
        excludedWords.slice(0, 50).forEach(function(w) {
          excludedHtml += '<span class="text-xs bg-gray-50 text-gray-500 px-2 py-1 rounded border border-gray-200">' + w.word + '</span>';
        });
        excludedHtml += '</div>' + (excludedCount > 50 ? '<p class="text-xs text-gray-400 mt-2">Showing 50 of ' + excludedCount + ' excluded words.</p>' : '') + '</div></div>';
      }

      // Assemble all content
      document.getElementById('answer-content').innerHTML =
        '<p class="text-gray-500 font-medium mb-6">' + puzzle.date + '</p>' +
        honeycombHtml +
        statsHtml +
        lettersInfo +
        geniusHtml +
        revealBtn +
        '<div id="answers-container-dynamic" class="hidden">' +
        perfectPangramsHtml +
        pangramsHtml +
        wordsHtml +
        lenChartHtml +
        pointsByLenHtml +
        globalLenHtml +
        firstLetterBtnHtml +
        firstLetterChartHtml +
        pangramHistoryHtml +
        percentilesHtml +
        letterHistoryHtml +
        wordFreqHtml +
        excludedHtml +
        '</div>';

      // Event handlers
      document.getElementById('reveal-answers-btn-dynamic')?.addEventListener('click', function() {
        var container = document.getElementById('answers-container-dynamic');
        if (container) { container.classList.remove('hidden'); this.style.display = 'none'; }
      });

      document.getElementById('show-first-letter-btn-dynamic')?.addEventListener('click', function() {
        var chart = document.getElementById('first-letter-chart-dynamic');
        if (chart) { var isHidden = chart.classList.contains('hidden'); chart.classList.toggle('hidden'); this.innerHTML = (isHidden ? 'Hide' : 'Show') + ' Counts by First Letter'; }
      });

      document.getElementById('show-excluded-btn-dynamic')?.addEventListener('click', function() {
        var container = document.getElementById('excluded-words-container-dynamic');
        if (container) { container.classList.remove('hidden'); this.style.display = 'none'; }
      });

    } catch (error) {
      console.error('Error loading puzzle:', error);
      document.getElementById('answer-content').innerHTML = '<div class="text-center py-12"><p class="text-red-500 font-medium">Failed to load puzzle data</p><a href="/archive" class="btn-primary mt-4 inline-flex">Browse Archive</a></div>';
    }
  }
  loadPuzzle();
</script>
