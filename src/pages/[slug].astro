---
import BaseLayout from '../layouts/BaseLayout.astro';

export function getStaticPaths() {
  const paths = [];
  const months = ['january','february','march','april','may','june','july','august','september','october','november','december'];
  const today = new Date();
  for (let i = 0; i < 100; i++) {
    const d = new Date(today);
    d.setDate(today.getDate() - i);
    const month = months[d.getMonth()];
    const day = d.getDate();
    const year = d.getFullYear();
    paths.push({
      params: { slug: `answer-for-${month}-${day}-${year}` },
    });
  }
  return paths;
}
---

<BaseLayout title="Spelling Bee Answers" description="Find answers for any NYT Spelling Bee puzzle by date.">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8 sm:py-10">
    <div class="mb-6">
      <a href="/archive" class="text-sm font-semibold text-amber-600 hover:text-amber-700 mb-3 inline-flex items-center gap-1">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M9.5 12.5L5 8l4.5-4.5L10.5 5 7.5 8l3 3z"/></svg>
        Back to Archive
      </a>
      <h1 id="page-h1" class="text-2xl sm:text-3xl font-black text-gray-900">Spelling Bee Answers</h1>
    </div>

    <div id="answer-content">
      <div class="text-center py-12">
        <div class="inline-block w-10 h-10 border-[3px] border-amber-400 border-t-transparent rounded-full animate-spin"></div>
        <p class="text-gray-500 mt-3 font-medium">Loading puzzle...</p>
      </div>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ API_BASE: 'https://spelling-bee-api.sbsolver.workers.dev' }}>
  function parseSlug() {
    var path = window.location.pathname;
    var slug = path.replace(/^\//, '').replace(/\/$/, '');
    var parts = slug.replace(/^answer-for-/, '').split('-');
    var months = ['january','february','march','april','may','june','july','august','september','october','november','december'];
    if (parts.length >= 3) {
      var monthName = parts[0].charAt(0).toUpperCase() + parts[0].slice(1);
      var day = parseInt(parts[1]);
      var year = parts[2];
      if (months.includes(parts[0].toLowerCase()) && day > 0 && year.length === 4) {
        return monthName + ' ' + day + ', ' + year;
      }
    }
    return null;
  }

  function buildHoneycombHTML(center, outer) {
    var html = '<div class="honeycomb honeycomb-md mx-auto" style="margin-bottom:1.5rem;">';
    outer.forEach(function(letter, i) {
      html += '<div class="hex-cell hex-outer hex-pos-' + i + '">';
      html += '<svg viewBox="0 -17 256 256" fill="none" class="hex-svg">';
      html += '<path d="M0 111L64 0.148707L192 0.148707L256 111L192 221.851L64 221.851L0 111Z" fill="currentColor" />';
      html += '</svg>';
      html += '<span class="hex-letter">' + letter + '</span>';
      html += '</div>';
    });
    html += '<div class="hex-cell hex-center hex-pos-center">';
    html += '<svg viewBox="0 -17 256 256" fill="none" class="hex-svg">';
    html += '<path d="M0 111L64 0.148707L192 0.148707L256 111L192 221.851L64 221.851L0 111Z" fill="currentColor" />';
    html += '</svg>';
    html += '<span class="hex-letter hex-letter-center">' + center + '</span>';
    html += '</div>';
    html += '</div>';
    return html;
  }

  function calculateWordPoints(word, isPangram) {
    var pts = word.length === 4 ? 1 : word.length;
    if (isPangram) pts += 7;
    return pts;
  }

  async function loadPuzzle() {
    var dateStr = parseSlug();
    if (!dateStr) {
      window.location.href = '/archive';
      return;
    }
    try {
      var res = await fetch(API_BASE + '/api/search/date/' + encodeURIComponent(dateStr));
      var data = await res.json();
      var results = data.results || [];

      if (results.length === 0) {
        res = await fetch(API_BASE + '/api/puzzles/list?limit=1&search=' + encodeURIComponent(dateStr));
        data = await res.json();
        results = data.puzzles || [];
      }

      if (results.length === 0) {
        document.getElementById('answer-content').innerHTML = '<div class="text-center py-12"><p class="text-gray-500 text-lg font-medium">No puzzle found for ' + dateStr + '</p><a href="/archive" class="btn-primary mt-4 inline-flex">Browse Archive</a></div>';
        return;
      }

      var p = results[0];
      var puzzleRes = await fetch(API_BASE + '/api/puzzle/' + p.puzzle_id);
      var puzzleData = await puzzleRes.json();
      var puzzle = puzzleData.puzzle || p;
      var words = puzzleData.words || [];
      var totalPoints = puzzleData.totalPoints || 0;
      var hasPerfectPangram = puzzleData.hasPerfectPangram || false;
      var perfectPangrams = puzzleData.perfectPangrams || [];
      var center = puzzle.letters || '';
      var allLetters = puzzle.all_letters || '';
      var outerLetters = allLetters.split('').filter(function(l) { return l !== center; });
      var pangrams = words.filter(function(w) { return w.is_pangram === 1; });
      var regularWords = words.filter(function(w) { return w.is_pangram !== 1; });
      var geniusThreshold = Math.ceil(totalPoints * 0.70);

      // Genius analysis
      var pangramPoints = pangrams.reduce(function(sum, w) {
        var pts = w.length === 4 ? 1 : w.length;
        return sum + pts + 7;
      }, 0);
      var nonPangramPoints = totalPoints - pangramPoints;
      var pointsNeededWithoutPangrams = Math.max(0, geniusThreshold);
      var pctWithoutPangrams = totalPoints > 0 ? Math.round((pointsNeededWithoutPangrams / totalPoints) * 100) : 0;
      var remainingAfterPangrams = totalPoints - pangramPoints;
      var pointsStillNeededWithPangrams = Math.max(0, geniusThreshold - pangramPoints);
      var pctWithPangrams = remainingAfterPangrams > 0 ? Math.round((pointsStillNeededWithPangrams / remainingAfterPangrams) * 100) : 0;

      // Min words for genius
      var minWordsForGenius = Math.ceil(geniusThreshold / 1);
      var avgWordPoints = words.length > 0 ? totalPoints / words.length : 1;
      var maxWordsForGenius = Math.ceil(geniusThreshold / Math.max(avgWordPoints, 1));

      // Min word length for genius
      var minLenForGenius = 4;
      if (words.length > 0) {
        var sortedByPoints = words.slice().sort(function(a, b) {
          var ptsA = a.length === 4 ? 1 : a.length;
          var ptsB = b.length === 4 ? 1 : b.length;
          return ptsA - ptsB;
        });
        var cumulativePts = 0;
        for (var i = 0; i < sortedByPoints.length; i++) {
          var w = sortedByPoints[i];
          var pts = w.length === 4 ? 1 : w.length + (w.is_pangram ? 7 : 0);
          cumulativePts += pts;
          if (cumulativePts >= geniusThreshold) {
            minLenForGenius = w.length;
            break;
          }
        }
      }

      // Update page title and H1 dynamically
      document.title = 'Spelling Bee Answers for ' + puzzle.date + ' | SbSolver';
      var h1El = document.getElementById('page-h1');
      if (h1El) {
        h1El.textContent = 'Spelling Bee Answers for ' + puzzle.date;
      }

      var honeycombHtml = '<div class="flex justify-center mb-6">' + buildHoneycombHTML(center, outerLetters) + '</div>';

      var statsHtml = '<div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">' +
        '<div class="stat-card"><p class="stat-value">' + puzzle.word_count + '</p><p class="stat-label">Words</p></div>' +
        '<div class="stat-card"><p class="stat-value">' + puzzle.pangrams_count + '</p><p class="stat-label">Pangrams</p></div>' +
        '<div class="stat-card"><p class="stat-value">' + totalPoints + '</p><p class="stat-label">Max Points</p></div>' +
        '<div class="stat-card"><p class="stat-value">' + geniusThreshold + '</p><p class="stat-label">Points for Genius</p></div>' +
        '</div>';

      // Genius analysis section
      var geniusHtml = '<div class="card-elevated p-5 mb-6">' +
        '<h2 class="text-sm font-bold text-gray-800 mb-3 flex items-center gap-2">' +
        '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2" stroke-linecap="round"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>' +
        'Genius Requirement Analysis</h2>' +
        '<p class="text-sm text-gray-600 leading-relaxed">' +
        'Genius requires between <strong>' + minWordsForGenius + '</strong> and <strong>' + maxWordsForGenius + '</strong> words. ' +
        'You need at least a <strong>' + minLenForGenius + '-letter word</strong> to reach genius. ' +
        (pangrams.length > 0 ?
          'If you don\'t get the pangrams, you need <strong>' + pctWithoutPangrams + '%</strong> of the total points to reach genius. ' +
          'If you get the pangrams, you only need <strong>' + pctWithPangrams + '%</strong> of the remaining points to reach genius.' :
          'You need <strong>' + pctWithoutPangrams + '%</strong> of the total points to reach genius.'
        ) + '</p></div>';

      // Perfect Pangrams section
      var perfectPangramsHtml = '';
      if (hasPerfectPangram && perfectPangrams.length > 0) {
        perfectPangramsHtml = '<div class="mb-6 p-5 bg-emerald-50 border border-emerald-200 rounded-xl">' +
          '<h2 class="text-sm font-bold text-emerald-800 mb-2 flex items-center gap-2">' +
          '<svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="#10B981" stroke-width="2"><circle cx="10" cy="10" r="9"/><path d="M6 10l3 3 5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>' +
          'Perfect Pangram' + (perfectPangrams.length > 1 ? 's' : '') + '!</h2>' +
          '<p class="text-xs text-emerald-600 mb-3">A perfect pangram uses all 7 letters exactly once (7 letters total).</p>' +
          '<div class="flex flex-wrap gap-2">' +
          perfectPangrams.map(function(w) { return '<span class="perfect-pangram-chip">' + w + '</span>'; }).join('') +
          '</div></div>';
      }

      var pangramsHtml = pangrams.length > 0 ? '<div class="mb-8"><h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2"><svg width="16" height="16" viewBox="0 0 20 20" fill="#F59E0B"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.33L10 13.27l-4.77 2.51.91-5.33L2.27 6.62l5.34-.78z"/></svg> Pangrams (' + pangrams.length + ')</h2><div class="flex flex-wrap gap-2">' + pangrams.map(function(w) { return '<span class="pangram-chip"><span class="star">&#9733;</span>' + w.word + ' <span class="text-xs text-amber-500 opacity-70">' + w.length + '</span></span>'; }).join('') + '</div></div>' : '';

      var byLen = {};
      for (var w of regularWords) {
        var l = w.length;
        if (!byLen[l]) byLen[l] = [];
        byLen[l].push(w);
      }
      var wordsHtml = Object.keys(byLen).sort(function(a,b) { return +b - +a; }).map(function(len) {
        return '<div class="px-5 py-4"><p class="text-xs font-bold text-gray-400 mb-3 uppercase tracking-wider">' + len + '-Letter Words (' + byLen[len].length + ')</p><div class="flex flex-wrap gap-2">' + byLen[len].map(function(w) { return '<span class="word-chip">' + w.word + '</span>'; }).join('') + '</div></div>';
      }).join('');

      // Word length distribution chart
      var wordsByLenAll = {};
      for (var w of words) {
        var l = w.length;
        if (!wordsByLenAll[l]) wordsByLenAll[l] = [];
        wordsByLenAll[l].push(w);
      }
      var sortedLenAll = Object.keys(wordsByLenAll).sort(function(a,b) { return +a - +b; });
      var maxLenCount = Math.max.apply(null, Object.values(wordsByLenAll).map(function(v) { return v.length; }).concat([1]));

      var lenChartHtml = '<div class="mt-8 card-elevated p-6">' +
        '<h2 class="text-lg font-bold text-gray-800 mb-2">Length of Words in This Puzzle</h2>' +
        '<p class="text-xs text-gray-400 mb-4">Hover over bars to see which words belong to each length.</p>' +
        '<div class="space-y-2.5">';

      for (var i = 0; i < sortedLenAll.length; i++) {
        var len = sortedLenAll[i];
        var count = wordsByLenAll[len].length;
        var pct = Math.round((count / words.length) * 100);
        var barWidth = Math.max((count / maxLenCount) * 100, 3);
        var isPangramLen = wordsByLenAll[len].some(function(w) { return w.is_pangram; });
        var wordList = wordsByLenAll[len].map(function(w) { return w.word; }).join(', ');

        lenChartHtml += '<div class="flex items-center gap-3 cursor-default" title="' + wordList + '">' +
          '<span class="w-8 text-sm font-bold text-gray-600 text-right">' + len + '</span>' +
          '<div class="flex-1"><div class="w-full bg-gray-100 rounded-full h-8 overflow-hidden">' +
          '<div class="h-8 rounded-full flex items-center pl-3 text-xs font-bold ' +
          (isPangramLen ? 'bg-gradient-to-r from-amber-300 to-amber-500 text-white' : 'bg-gray-300 text-gray-700') +
          '" style="width: ' + barWidth + '%">' + count + (isPangramLen ? ' <span class="ml-1 text-amber-100">&#9733;</span>' : '') +
          '</div></div></div>' +
          '<span class="text-xs text-gray-400 font-medium w-10 text-right">' + pct + '%</span></div>';
      }
      lenChartHtml += '</div></div>';

      // First letter counts chart
      var wordsByFirstLetter = {};
      for (var w of words) {
        var first = w.word[0] ? w.word[0].toUpperCase() : '';
        if (!first) continue;
        if (!wordsByFirstLetter[first]) wordsByFirstLetter[first] = { count: 0, isPangram: false, words: [] };
        wordsByFirstLetter[first].count++;
        wordsByFirstLetter[first].words.push(w.word);
        if (w.is_pangram) wordsByFirstLetter[first].isPangram = true;
      }
      var sortedFirstLetters = Object.keys(wordsByFirstLetter).sort();
      var maxFirstLetterCount = Math.max.apply(null, Object.values(wordsByFirstLetter).map(function(v) { return v.count; }).concat([1]));

      var firstLetterBtnHtml = '<div class="mt-6"><button id="show-first-letter-btn-dynamic" class="btn-secondary text-sm !py-2.5 w-full sm:w-auto" type="button">' +
        '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 20V10M12 20V4M6 20v-6"/></svg> ' +
        'Show Counts by First Letter</button>' +
        '<p class="text-xs text-gray-400 mt-1.5">Red bars indicate that there is a pangram(s) starting with that letter.</p></div>';

      var firstLetterChartHtml = '<div id="first-letter-chart-dynamic" class="hidden mt-4 card-elevated p-6"><div class="space-y-2.5">';
      for (var i = 0; i < sortedFirstLetters.length; i++) {
        var letter = sortedFirstLetters[i];
        var info = wordsByFirstLetter[letter];
        var barWidth = Math.max((info.count / maxFirstLetterCount) * 100, 8);
        firstLetterChartHtml += '<div class="flex items-center gap-3" title="' + info.words.join(', ') + '">' +
          '<span class="w-8 text-sm font-black text-right ' + (info.isPangram ? 'text-red-500' : 'text-gray-600') + '">' + letter + '</span>' +
          '<div class="flex-1"><div class="w-full bg-gray-100 rounded-full h-7 overflow-hidden">' +
          '<div class="h-7 rounded-full flex items-center pl-3 text-xs font-bold ' +
          (info.isPangram ? 'bg-red-400 text-white' : 'bg-gray-300 text-gray-700') +
          '" style="width: ' + barWidth + '%">' + info.count + '</div></div></div>' +
          (info.isPangram ? '<span class="text-xs text-red-500 font-bold">PANGRAM</span>' : '') +
          '</div>';
      }
      firstLetterChartHtml += '</div></div>';

      document.getElementById('answer-content').innerHTML =
        '<p class="text-gray-500 font-medium mb-6">' + puzzle.date + '</p>' +
        honeycombHtml +
        statsHtml +
        geniusHtml +
        perfectPangramsHtml +
        pangramsHtml +
        '<div><h2 class="text-lg font-bold text-gray-800 mb-4">All Words (' + words.length + ')</h2><div class="card-elevated max-h-[600px] overflow-y-auto custom-scroll divide-y divide-gray-50">' + wordsHtml + '</div></div>' +
        lenChartHtml +
        firstLetterBtnHtml +
        firstLetterChartHtml +
        '<div class="mt-10 p-6 bg-gray-50 rounded-2xl"><h2 class="text-lg font-bold text-gray-800 mb-3">About This Puzzle</h2><p class="text-gray-600 leading-relaxed text-sm">The NYT Spelling Bee for <strong>' + puzzle.date + '</strong> features center letter <strong>' + center + '</strong> with outer letters <strong>' + outerLetters.join(', ') + '</strong>. Players can find <strong>' + puzzle.word_count + ' words</strong> including <strong>' + puzzle.pangrams_count + ' pangram' + (puzzle.pangrams_count !== 1 ? 's' : '') + '</strong>, earning up to <strong>' + totalPoints + ' points</strong>. To reach Genius, you need <strong>' + geniusThreshold + ' points</strong> (70% of the total).' + (hasPerfectPangram ? ' This puzzle features a <strong>perfect pangram</strong> — a 7-letter word using all letters exactly once.' : '') + '</p></div>';

      // Add click handler for first letter chart toggle
      document.getElementById('show-first-letter-btn-dynamic')?.addEventListener('click', function() {
        var chart = document.getElementById('first-letter-chart-dynamic');
        if (chart) {
          var isHidden = chart.classList.contains('hidden');
          chart.classList.toggle('hidden');
          this.textContent = isHidden ? 'Hide Counts by First Letter' : 'Show Counts by First Letter';
        }
      });

    } catch (error) {
      document.getElementById('answer-content').innerHTML = '<div class="text-center py-12"><p class="text-red-500 font-medium">Failed to load puzzle data</p><a href="/archive" class="btn-primary mt-4 inline-flex">Browse Archive</a></div>';
    }
  }
  loadPuzzle();
</script>
