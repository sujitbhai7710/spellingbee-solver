---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildArchivePath, dateTextToIso } from '../lib/utils';
import { readPublicJson } from '../lib/site-data';

const summaries = readPublicJson('site-data/archive-summaries.json', []) || [];
const totalPuzzles = summaries.length;
const newestPuzzle = summaries[0] || null;
const oldestPuzzle = summaries[totalPuzzles - 1] || null;
const maxArchiveDate = newestPuzzle?.date_iso || dateTextToIso(newestPuzzle?.date) || new Date().toISOString().slice(0, 10);

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'How far back does the Spelling Bee archive go?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: totalPuzzles > 0
          ? `Our archive contains ${totalPuzzles.toLocaleString()} puzzles, from ${oldestPuzzle?.date || 'the earliest available date'} through ${newestPuzzle?.date || 'today'}. Each puzzle has a permanent detail page with answers and analysis.`
          : 'Our archive is generated from the daily Spelling Bee database and includes every puzzle available in the snapshot build.',
      },
    },
    {
      '@type': 'Question',
      name: 'Can I open a specific date directly?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Every puzzle now has its own permanent archive URL, and the date picker jumps straight to that page.',
      },
    },
  ],
});
---

<BaseLayout title="Spelling Bee Puzzle Archive" description={`Browse ${totalPuzzles.toLocaleString()} NYT Spelling Bee puzzles with permanent archive pages, complete answers, and detailed analysis.`} schema={faqSchema}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">Puzzle Archive</h1>
      <p class="text-gray-500">
        {totalPuzzles.toLocaleString()} puzzles
        {newestPuzzle && oldestPuzzle ? ` · ${newestPuzzle.date} back to ${oldestPuzzle.date}` : ''}
      </p>
    </div>

    <div class="card-elevated p-5 mb-6">
      <h2 class="font-bold text-gray-800 mb-3 text-sm">Jump to a Date</h2>
      <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-3">
        <input type="date" id="date-picker" class="solver-input !py-2.5 !px-4 !text-base !letter-normal !normal-case flex-1" min="2018-01-01" max={maxArchiveDate} />
        <button id="go-date-btn" class="btn-primary !py-2.5 !px-5 text-sm" type="button">Open Archive Page</button>
      </div>
      <p class="text-xs text-gray-400 mt-3">Each date opens its own permanent page like <span class="font-mono">/archive/may-22-2026/</span>.</p>
    </div>

    <div class="card-elevated p-5 mb-8">
      <h2 class="text-lg font-bold text-gray-800 mb-3">How the Archive Works</h2>
      <p class="text-sm text-gray-600 leading-relaxed mb-2">The archive index is static, fast, and search-engine friendly. Click any puzzle below to open its own fully rendered page with answers, meanings, charts, and historical comparison data.</p>
      <p class="text-sm text-gray-600 leading-relaxed">Older `?date=` archive URLs are redirected to the new permanent paths automatically, so the site keeps one clean canonical URL per puzzle.</p>
    </div>

    <div class="card-elevated divide-y divide-gray-50">
      {summaries.map((puzzle) => (
        <a
          href={buildArchivePath(puzzle.date)}
          class="flex items-center justify-between gap-4 p-5 hover:bg-amber-50/50 transition-colors group"
          data-date={puzzle.date}
          data-date-iso={puzzle.date_iso || dateTextToIso(puzzle.date)}
          data-slug={String(puzzle.slug || '')}
        >
          <div class="flex items-center gap-4 min-w-0">
            <span class="letter-circle letter-circle-center flex-shrink-0">{puzzle.letters}</span>
            <div class="min-w-0">
              <p class="font-semibold text-gray-800 group-hover:text-amber-700 transition-colors truncate">{puzzle.date}</p>
              <p class="text-xs text-gray-400 font-mono mt-0.5 truncate">{puzzle.all_letters}</p>
            </div>
          </div>
          <div class="text-right flex-shrink-0">
            <p class="text-sm font-semibold text-gray-600">{puzzle.word_count} words</p>
            <p class="text-xs text-amber-500">{puzzle.pangrams_count} pangram{puzzle.pangrams_count !== 1 ? 's' : ''}</p>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-10 p-6 bg-gray-50 rounded-2xl">
      <h2 class="text-lg font-bold text-gray-800 mb-3">Browse the Complete Spelling Bee Archive</h2>
      <p class="text-gray-600 leading-relaxed text-sm mb-3">This archive page lists every puzzle from the current site snapshot. Each detail page is generated ahead of time, so the answers, meanings, charts, and statistics are already in the HTML when the page loads.</p>
      <p class="text-gray-600 leading-relaxed text-sm mb-3">That means the archive is faster, lighter on the worker, and much easier for Google to index than the old query-string detail view. It also gives every puzzle a stable URL you can bookmark or share.</p>
      <p class="text-gray-600 leading-relaxed text-sm">If you know the date you want, use the date picker above. If not, scroll through the list and open any puzzle to see the full analysis page for that day.</p>
    </div>
  </div>

  <script>
    const datePicker = document.getElementById('date-picker');
    const goDateBtn = document.getElementById('go-date-btn');
    const archiveLinks = Array.from(document.querySelectorAll('[data-date-iso][data-slug]'));

    function slugForIso(isoDate) {
      const match = archiveLinks.find((link) => link.getAttribute('data-date-iso') === isoDate);
      return match ? match.getAttribute('data-slug') : '';
    }

    function goToArchiveSlug(slug) {
      if (!slug) return;
      window.location.assign(`/archive/${slug}/`);
    }

    function normalizeLegacyArchiveRedirect() {
      const params = new URLSearchParams(window.location.search);
      const legacyDate = params.get('date') || sessionStorage.getItem('sb_archive_date');
      if (!legacyDate) return;
      sessionStorage.removeItem('sb_archive_date');
      const cleanSlug = String(legacyDate).replace(/^\/+|\/+$/g, '');
      if (cleanSlug) {
        window.location.replace(`/archive/${cleanSlug}/`);
      }
    }

    normalizeLegacyArchiveRedirect();

    if (goDateBtn && datePicker) {
      goDateBtn.addEventListener('click', () => {
        const isoDate = datePicker.value;
        if (!isoDate) return;
        const slug = slugForIso(isoDate);
        if (slug) {
          goToArchiveSlug(slug);
        }
      });

      datePicker.addEventListener('keydown', (event) => {
        if (event.key === 'Enter') {
          event.preventDefault();
          goDateBtn.click();
        }
      });
    }
  </script>
</BaseLayout>
