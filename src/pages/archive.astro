          '<hr class="border-gray-100 my-6" />' +
          '<div><h3 class="text-sm font-bold text-gray-700 mb-3">Average Word Length</h3>' +
          '<p class="text-sm text-gray-600 leading-relaxed mb-2">This puzzle has an average word length of <strong>' + roundTo(safeNum(analysis.averageWordLength && analysis.averageWordLength.value, 0), 1).toFixed(1) + '</strong>.</p>' +
          '<p class="text-sm text-gray-600 leading-relaxed mb-4">For all Bees up to that date, the average word length had been <strong>' + roundTo(safeNum(analysis.averageWordLength && analysis.averageWordLength.globalAverage, 0), 1).toFixed(1) + '</strong>.</p>' +
          '<div class="space-y-1.5">' + renderHistogramRows(analysis.averageWordLength && analysis.averageWordLength.histogram || [], averageLengthHistogramPeak, { rowBg: 'bg-emerald-50 -mx-2 px-2 rounded-lg py-0.5', labelColor: 'text-emerald-700', barClass: 'bg-gradient-to-r from-emerald-400 to-emerald-500 text-white' }, 1) + '</div>' +
          '<p class="text-xs text-gray-400 mt-2">Average word length in all puzzles</p></div></div>';

        var aboutHtml = '<div class="mt-10 p-6 bg-gray-50 rounded-2xl"><h2 class="text-lg font-bold text-gray-800 mb-3">About This Puzzle</h2>' +
          '<p class="text-gray-600 leading-relaxed text-sm mb-3">The NYT Spelling Bee for <strong>' + escapeHtml(puzzle.date) + '</strong> uses <strong>' + escapeHtml(center) + '</strong> as the mandatory center letter with outer letters <strong>' + escapeHtml(outerLetters.join(', ')) + '</strong>. This puzzle contains <strong>' + safeNum(puzzle.word_count, 0) + ' answers</strong>, <strong>' + safeNum(puzzle.pangrams_count, 0) + ' pangram' + (safeNum(puzzle.pangrams_count, 0) !== 1 ? 's' : '') + '</strong>, and a maximum score of <strong>' + totalPoints + '</strong>.</p>' +
          '<p class="text-gray-600 leading-relaxed text-sm">Historically, it ranks in the <strong>' + wordCountPercentileText + '</strong> percentile for answer count and the <strong>' + scorePercentileText + '</strong> percentile for score. The archive detail view now uses the same analysis source as the today page, so these charts and history sections stay aligned.</p>' +
          '</div>';

        puzzleDetailContent.innerHTML =
          '<p class="text-gray-500 font-medium mb-6">' + puzzle.date + '</p>' +
          honeycombHtml +
          statsHtml +
          perfectPangramsHtml +
          pangramsHtml +
          wordLengthHtml +
          pointsByLengthHtml +
          firstLetterHtml +
          pangramHistoryHtml +
          compareHtml +
          lettersHistoryHtml +
          commonWordsHtml +
          historicalLengthHtml +
          nonOfficialWordsHtml +
          '<div><h2 class="text-lg font-bold text-gray-800 mb-4">All Words (' + words.length + ')</h2><div class="card-elevated max-h-[600px] overflow-y-auto custom-scroll divide-y divide-gray-50">' + wordsHtml + '</div></div>' +
          definitionsHtml +
          aboutHtml;

      } catch (error) {
        puzzleDetailContent.innerHTML = '<div class="text-center py-12"><p class="text-red-500 font-medium">Failed to load puzzle data</p><button onclick="showListView()" class="btn-primary mt-4 inline-flex">Back to Archive</button></div>';
      }
    }

    function showNotFound(dateStr) {
      showDetailView();
      puzzleDetailContent.innerHTML =
        '<div class="text-center py-16">' +
        '<svg viewBox="0 -17 256 256" fill="none" width="64" height="64" class="mx-auto opacity-30 mb-4"><path d="M0 111L64 0.148707L192 0.148707L256 111L192 221.851L64 221.851L0 111Z" fill="#FEF3C7" stroke="#F7C948" stroke-width="3"/><text x="128" y="125" font-family="system-ui,sans-serif" font-size="80" font-weight="900" fill="#D97706" text-anchor="middle">?</text></svg>' +
        '<h2 class="text-xl font-bold text-gray-800 mb-2">Puzzle Not Found</h2>' +
        '<p class="text-gray-500 mb-6">No Spelling Bee puzzle exists for <strong>' + (dateStr || 'this date') + '</strong>. The puzzle may not have been published on that date, or it may be outside our archive range.</p>' +
        '<button onclick="document.getElementById(\'back-to-list-btn\').click()" class="btn-primary">Back to Archive</button>' +
        '</div>';
    }

    // Back button
    backBtn.addEventListener('click', showListView);

    // Date picker go button
    document.getElementById('go-date-btn').addEventListener('click', function() {
      var datePicker = document.getElementById('date-picker');
      if (!datePicker || !datePicker.value) return;
      var dateObj = new Date(datePicker.value + 'T00:00:00Z');
      if (isNaN(dateObj.getTime())) return;
      var month = months[dateObj.getMonth()];
      var day = dateObj.getDate();
      var year = dateObj.getFullYear();
      var slug = month + '-' + day + '-' + year;
      loadPuzzleBySlug(slug);
    });

    // Allow Enter key on date picker
    document.getElementById('date-picker').addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        document.getElementById('go-date-btn').click();
      }
    });

    // Click on puzzle rows in the list
    document.querySelectorAll('.archive-puzzle-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var slug = this.getAttribute('data-slug');
        if (slug) loadPuzzleBySlug(slug);
      });
    });

    // Check sessionStorage for redirect from /answer-for-* URLs
    // This is set by the 404 page when it detects an old permalink pattern
    (function() {
      var redirectSlug = sessionStorage.getItem('sb_archive_date');
      if (redirectSlug) {
        sessionStorage.removeItem('sb_archive_date');
        loadPuzzleBySlug(redirectSlug);
        return;
      }

      var params = new URLSearchParams(window.location.search);
      var selectedDate = params.get('date');
      if (selectedDate) {
        loadPuzzleBySlug(selectedDate);
      }
    })();
  </script>
</BaseLayout>
