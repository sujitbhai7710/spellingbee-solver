---
import BaseLayout from '../layouts/BaseLayout.astro';
import Honeycomb from '../components/Honeycomb.astro';
import { API_BASE } from '../lib/utils';

const page = parseInt(Astro.url.searchParams.get('page') || '1');
const res = await fetch(`${API_BASE}/api/puzzles/list?limit=20&page=${page}`);
const data = await res.json();
const puzzles = data.puzzles || [];
const pagination = data.pagination || {};

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How far back does the Spelling Bee archive go?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Our archive contains ${pagination.total_items || 'over 2,900'} puzzles dating back to 2018, covering every daily Spelling Bee puzzle from the NYT.`
      }
    },
    {
      "@type": "Question",
      "name": "Can I search for a specific date's puzzle?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Use the date picker above the puzzle list to jump directly to a specific date. The puzzle details will be shown right here on the archive page."
      }
    }
  ]
});
---

<BaseLayout title="Spelling Bee Puzzle Archive" description={`Browse ${pagination.total_items || '2,900+'} NYT Spelling Bee puzzles with complete answers. Search by date, letter, or puzzle ID.`} schema={faqSchema}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">Puzzle Archive</h1>
      <p class="text-gray-500">{pagination.total_items?.toLocaleString() || 0} puzzles &middot; Page {pagination.page} of {pagination.total_pages}</p>
    </div>

    <!-- Date Picker -->
    <div class="card-elevated p-5 mb-6">
      <h3 class="font-bold text-gray-800 mb-3 text-sm">Jump to a Date</h3>
      <div class="flex items-center gap-3">
        <input type="date" id="date-picker" class="solver-input !py-2.5 !px-4 !text-base !letter-normal !normal-case flex-1" min="2018-01-01" max={new Date().toISOString().split('T')[0]} />
        <button id="go-date-btn" class="btn-primary !py-2.5 !px-5 text-sm" type="button">Go!</button>
      </div>
    </div>

    <!-- Puzzle Detail View (hidden by default, shown when date is selected) -->
    <div id="puzzle-detail" class="hidden">
      <div class="mb-6">
        <button id="back-to-list-btn" class="text-sm font-semibold text-amber-600 hover:text-amber-700 mb-3 inline-flex items-center gap-1">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M9.5 12.5L5 8l4.5-4.5L10.5 5 7.5 8l3 3z"/></svg>
          Back to Archive List
        </button>
      </div>
      <div id="puzzle-detail-content">
        <div class="text-center py-12">
          <div class="inline-block w-10 h-10 border-[3px] border-amber-400 border-t-transparent rounded-full animate-spin"></div>
          <p class="text-gray-500 mt-3 font-medium">Loading puzzle...</p>
        </div>
      </div>
    </div>

    <!-- Puzzle List View (default) -->
    <div id="puzzle-list-view">
      <div class="card-elevated divide-y divide-gray-50">
        {puzzles.map(p => {
          const slug = p.date.toLowerCase().replace(/,\s*/g, '-').replace(/\s+/g, '-');
          return (
            <button data-slug={slug} data-date={p.date} class="archive-puzzle-btn flex items-center justify-between p-5 hover:bg-amber-50/50 transition-colors group w-full text-left">
              <div class="flex items-center gap-4">
                <span class="letter-circle letter-circle-center">{p.letters}</span>
                <div>
                  <p class="font-semibold text-gray-800 group-hover:text-amber-700 transition-colors">{p.date}</p>
                  <p class="text-xs text-gray-400 font-mono mt-0.5">{p.all_letters}</p>
                </div>
              </div>
              <div class="text-right">
                <p class="text-sm font-semibold text-gray-600">{p.word_count} words</p>
                <p class="text-xs text-amber-500">{p.pangrams_count} pangram{p.pangrams_count !== 1 ? 's' : ''}</p>
              </div>
            </button>
          );
        })}
      </div>

      <!-- Pagination -->
      {pagination.total_pages > 1 && (
        <div class="flex items-center justify-center gap-3 mt-8">
          {pagination.page > 1 && (
            <a href={`/archive?page=${pagination.page - 1}`} class="btn-secondary !py-2.5 !px-5 text-sm">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M9.5 12.5L5 8l4.5-4.5L10.5 5 7.5 8l3 3z"/></svg>
              Previous
            </a>
          )}
          <span class="text-sm text-gray-500 font-medium">Page {pagination.page} of {pagination.total_pages}</span>
          {pagination.has_next && (
            <a href={`/archive?page=${pagination.page + 1}`} class="btn-primary !py-2.5 !px-5 text-sm">
              Next
              <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M6.5 3.5L11 8l-4.5 4.5L5.5 11 8.5 8 5.5 5z"/></svg>
            </a>
          )}
        </div>
      )}
    </div>

    <!-- SEO Content -->
    <div class="mt-10 p-6 bg-gray-50 rounded-2xl">
      <h2 class="text-lg font-bold text-gray-800 mb-3">Browse the Complete Spelling Bee Archive</h2>
      <p class="text-gray-600 leading-relaxed text-sm mb-3">Our puzzle archive covers every daily NYT Spelling Bee puzzle, providing complete answer lists, pangram details, and scoring breakdowns for each date. Whether you're catching up on puzzles you missed or analyzing patterns across thousands of past games, the archive gives you instant access to the full historical record.</p>
      <p class="text-gray-600 leading-relaxed text-sm mb-3">Each entry shows the center letter, all available letters, word count, and pangram count at a glance. Click any date to see the complete word list organized by length, with pangrams highlighted and perfect pangrams called out separately. The scoring breakdown includes total points and Genius threshold for every puzzle.</p>
      <p class="text-gray-600 leading-relaxed text-sm mb-3">Use the date picker to jump directly to a specific puzzle, or browse page by page with the pagination controls. Puzzles are listed in reverse chronological order, starting with the most recent. The archive contains {pagination.total_items?.toLocaleString() || 'over 2,900'} puzzles spanning from 2018 to the present day.</p>
      <p class="text-gray-600 leading-relaxed text-sm">Reviewing past puzzles is one of the most effective ways to improve your Spelling Bee performance. Pay attention to which letter combinations appear frequently, how pangram patterns work, and which word structures tend to show up repeatedly. Players who study the archive consistently score higher than those who only play today's puzzle.</p>
    </div>

    <!-- FAQ Section -->
    <div class="mt-8">
      <h2 class="text-lg font-bold text-gray-800 mb-4">Frequently Asked Questions</h2>
      <div class="space-y-3">
        <details class="card-elevated p-5 group" open>
          <summary class="font-semibold text-gray-800 cursor-pointer flex items-center justify-between">How far back does the archive go?
            <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="text-sm text-gray-600 mt-3 leading-relaxed">The archive contains {pagination.total_items?.toLocaleString() || 'over 2,900'} puzzles starting from 2018. Every daily NYT Spelling Bee puzzle since the game launched in the NYT app is included with complete answer data.</p>
        </details>
        <details class="card-elevated p-5 group">
          <summary class="font-semibold text-gray-800 cursor-pointer flex items-center justify-between">Can I search for a specific date?
            <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="text-sm text-gray-600 mt-3 leading-relaxed">Yes. Use the date picker at the top of the archive page to jump directly to any date. The puzzle details will be shown right on this page. You can also browse page by page using the Previous and Next buttons. Each page shows 20 puzzles in reverse chronological order.</p>
        </details>
      </div>
    </div>
  </div>

  <script define:vars={{ API_BASE }}>
    const months = ['january','february','march','april','may','june','july','august','september','october','november','december'];
    const puzzleDetail = document.getElementById('puzzle-detail');
    const puzzleDetailContent = document.getElementById('puzzle-detail-content');
    const puzzleListView = document.getElementById('puzzle-list-view');
    const backBtn = document.getElementById('back-to-list-btn');
    const allLettersAZ = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
    var allLettersFrequencyCachePromise = null;
    var dictionaryWordsCachePromise = null;

    function parseSlugToDate(slug) {
      var parts = slug.split('-');
      if (parts.length >= 3) {
        var monthName = parts[0].charAt(0).toUpperCase() + parts[0].slice(1);
        var day = parseInt(parts[1]);
        var year = parts[2];
        if (months.includes(parts[0].toLowerCase()) && day > 0 && year.length === 4) {
          return monthName + ' ' + day + ', ' + year;
        }
      }
      return null;
    }

    function buildHoneycombHTML(center, outer) {
      var html = '<div class="honeycomb honeycomb-md mx-auto" style="margin-bottom:1.5rem;">';
      outer.forEach(function(letter, i) {
        html += '<div class="hex-cell hex-outer hex-pos-' + i + '">';
        html += '<svg viewBox="0 -17 256 256" fill="none" class="hex-svg">';
        html += '<path d="M0 111L64 0.148707L192 0.148707L256 111L192 221.851L64 221.851L0 111Z" fill="currentColor" />';
        html += '</svg>';
        html += '<span class="hex-letter">' + letter + '</span>';
        html += '</div>';
      });
      html += '<div class="hex-cell hex-center hex-pos-center">';
      html += '<svg viewBox="0 -17 256 256" fill="none" class="hex-svg">';
      html += '<path d="M0 111L64 0.148707L192 0.148707L256 111L192 221.851L64 221.851L0 111Z" fill="currentColor" />';
      html += '</svg>';
      html += '<span class="hex-letter hex-letter-center">' + center + '</span>';
      html += '</div>';
      html += '</div>';
      return html;
    }

    function safeNum(value, fallback) {
      var parsed = Number(value);
      return Number.isFinite(parsed) ? parsed : (fallback || 0);
    }

    function roundTo(value, decimals) {
      var factor = Math.pow(10, decimals || 1);
      return Math.round(Number(value || 0) * factor) / factor;
    }

    function safeLocale(value) {
      return typeof value === 'number' ? value.toLocaleString() : (value ?? '--');
    }

    function formatOrdinal(value) {
      var number = safeNum(value, 0);
      var mod100 = number % 100;
      if (mod100 >= 11 && mod100 <= 13) return number + 'th';
      switch (number % 10) {
        case 1: return number + 'st';
        case 2: return number + 'nd';
        case 3: return number + 'rd';
        default: return number + 'th';
      }
    }

    function histogramPeak(bins) {
      return Math.max.apply(null, (bins || []).map(function(bin) { return safeNum(bin.percentage, 0); }).concat([1]));
    }

    function formatHistogramRange(bin, decimals) {
      if (!bin) return '--';
      if ((decimals || 0) > 0) {
        var startDec = roundTo(bin.start, decimals).toFixed(decimals);
        var endDec = roundTo(bin.end, decimals).toFixed(decimals);
        return startDec === endDec ? startDec : startDec + '-' + endDec;
      }
      var start = Math.round(bin.start);
      var end = Math.round(bin.end);
      return start === end ? String(start) : start + '-' + end;
    }

    function archiveHref(date) {
      return '/archive?date=' + String(date || '').toLowerCase().replace(/,\s*/g, '-').replace(/\s+/g, '-');
    }

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function renderHistogramRows(bins, peak, currentTheme, decimals) {
      return (bins || []).map(function(bin) {
        var barWidth = Math.max((safeNum(bin.percentage, 0) / peak) * 100, bin.isCurrent ? 3 : 1);
        var rowBg = bin.isCurrent ? currentTheme.rowBg : '';
        var labelColor = bin.isCurrent ? currentTheme.labelColor : 'text-gray-400';
        var barClass = bin.isCurrent ? currentTheme.barClass : 'bg-gray-300 text-gray-600';
        return '<div class="flex items-center gap-3 ' + rowBg + '">' +
          '<span class="w-20 text-xs font-bold text-right flex-shrink-0 ' + labelColor + '">' + formatHistogramRange(bin, decimals || 0) + '</span>' +
          '<div class="flex-1"><div class="w-full bg-gray-100 rounded-full h-5 overflow-hidden">' +
          '<div class="h-5 rounded-full flex items-center pl-2 text-[10px] font-bold ' + barClass + '" style="width:' + barWidth + '%;">' +
          (bin.isCurrent ? 'Current' : roundTo(safeNum(bin.percentage, 0), 1) + '%') +
          '</div></div></div></div>';
      }).join('');
    }

    function renderDiscreteHistogramRows(items, peak, currentTheme, labelSuffix) {
      return (items || []).map(function(item) {
        var barWidth = Math.max((safeNum(item.percentage, 0) / peak) * 100, item.isCurrent ? 3 : 1);
        var rowBg = item.isCurrent ? currentTheme.rowBg : '';
        var labelColor = item.isCurrent ? currentTheme.labelColor : 'text-gray-400';
        var barClass = item.isCurrent ? currentTheme.barClass : 'bg-gray-300 text-gray-600';
        return '<div class="flex items-center gap-3 ' + rowBg + '">' +
          '<span class="w-20 text-xs font-bold text-right flex-shrink-0 ' + labelColor + '">' + item.value + labelSuffix + '</span>' +
          '<div class="flex-1"><div class="w-full bg-gray-100 rounded-full h-5 overflow-hidden">' +
          '<div class="h-5 rounded-full flex items-center pl-2 text-[10px] font-bold ' + barClass + '" style="width:' + barWidth + '%;">' +
          (item.isCurrent ? 'Current' : roundTo(safeNum(item.percentage, 0), 1) + '%') +
          '</div></div></div></div>';
      }).join('');
    }

    function getWordPoints(word) {
      var length = safeNum(word && word.length, String(word && word.word || '').length);
      if (length <= 0) return 0;
      return length === 4 ? 1 : length + (word && word.is_pangram === 1 ? 7 : 0);
    }

    async function loadAllLettersFrequency() {
      if (!allLettersFrequencyCachePromise) {
        allLettersFrequencyCachePromise = fetch(API_BASE + '/api/allLettersFrequency')
          .then(function(response) {
            if (!response.ok) {
              throw new Error('Failed to load all letters frequency');
            }
            return response.json();
          })
          .catch(function() {
            return { allLettersFrequency: [] };
          });
      }

      return allLettersFrequencyCachePromise;
    }

    async function loadDictionaryWords() {
      if (!dictionaryWordsCachePromise) {
        dictionaryWordsCachePromise = fetch('/twl06.txt')
          .then(function(response) {
            if (!response.ok) {
              throw new Error('Failed to load TWL dictionary');
            }
            return response.text();
          })
          .then(function(text) {
            return Array.from(new Set(
              text
                .split(/\r?\n/)
                .map(function(word) { return word.trim().toLowerCase(); })
                .filter(Boolean)
            ));
          })
          .catch(function() {
            return [];
          });
      }

      return dictionaryWordsCachePromise;
    }

    function showListView() {
      puzzleDetail.classList.add('hidden');
      puzzleListView.classList.remove('hidden');
      // Keep URL as just /archive — no query params
      var url = new URL(window.location);
      url.searchParams.delete('date');
      window.history.replaceState({}, '', url.pathname + (url.search || ''));
    }

    function showDetailView() {
      puzzleListView.classList.add('hidden');
      puzzleDetail.classList.remove('hidden');
    }

    async function loadPuzzleBySlug(slug) {
      var dateStr = parseSlugToDate(slug);
      if (!dateStr) {
        showNotFound('Invalid date format');
        return;
      }

      showDetailView();
      var url = new URL(window.location);
      url.searchParams.set('date', slug);
      window.history.replaceState({}, '', url.pathname + '?' + url.searchParams.toString());
      puzzleDetailContent.innerHTML = '<div class="text-center py-12"><div class="inline-block w-10 h-10 border-[3px] border-amber-400 border-t-transparent rounded-full animate-spin"></div><p class="text-gray-500 mt-3 font-medium">Loading puzzle...</p></div>';

      try {
        var res = await fetch(API_BASE + '/api/search/date/' + encodeURIComponent(dateStr));
        var data = await res.json();
        var results = data.results || [];

        if (results.length === 0) {
          res = await fetch(API_BASE + '/api/puzzles/list?limit=1&search=' + encodeURIComponent(dateStr));
          data = await res.json();
          results = data.puzzles || [];
        }

        if (results.length === 0) {
          showNotFound(dateStr);
          return;
        }

        var p = results[0];
        var detailResults = await Promise.all([
          fetch(API_BASE + '/api/puzzle/' + p.puzzle_id).then(function(response) { return response.json(); }),
          fetch(API_BASE + '/api/puzzleAnalysis/' + p.puzzle_id).then(function(response) { return response.json(); }),
          loadAllLettersFrequency(),
          loadDictionaryWords(),
        ]);
        var puzzleData = detailResults[0] || {};
        var analysisData = detailResults[1] || {};
        var allLettersFrequencyData = detailResults[2] || { allLettersFrequency: [] };
        var dictionaryWords = detailResults[3] || [];
        var puzzle = puzzleData.puzzle || p;
        var words = puzzleData.words || [];
        var definitionsByWord = puzzleData.definitionsByWord || {};
        var totalPoints = puzzleData.totalPoints || 0;
        var hasPerfectPangram = puzzleData.hasPerfectPangram || false;
        var perfectPangrams = puzzleData.perfectPangrams || [];
        var analysis = analysisData.analysis || {
          score: { percentile: 0, highestScore: totalPoints, highestScoreDate: null, lowestScore: totalPoints, lowestScoreDate: null, lastTimeAtOrAboveDate: null, histogram: [] },
          wordCount: { percentile: 0, highestWordCount: puzzle.word_count || 0, highestWordCountDate: null, lowestWordCount: puzzle.word_count || 0, lowestWordCountDate: null, lastTimeAboveDate: null, histogram: [] },
          genius: { requiredLength: 0, lastTimeSameLengthDate: null, histogram: [] },
          averageWordLength: { value: 0, globalAverage: 0, histogram: [] },
          commonWords: [],
          allAnswerLengthDistribution: [],
          uniqueAnswerLengthDistribution: [],
          totalHistoricalAnswers: 0,
          totalUniqueHistoricalWords: 0,
          sameCenterPuzzles: [],
          pangramHistoryCombined: [],
        };
        var geniusThreshold = Math.round(totalPoints * 0.70);
        var center = puzzle.letters || '';
        var allLetters = puzzle.all_letters || '';
        var outerLetters = allLetters.split('').filter(function(l) { return l !== center; });
        var pangrams = words.filter(function(w) { return w.is_pangram === 1; });
        var regularWords = words.filter(function(w) { return w.is_pangram !== 1; });
        var pangramHistoryCombined = analysis.pangramHistoryCombined || [];
        var letterFreq = allLettersFrequencyData.allLettersFrequency || [];
        var letterFreqMap = {};
        letterFreq.forEach(function(item) {
          letterFreqMap[item.letter] = item;
        });
        var wordsWithDefinitions = words.map(function(word) {
          return {
            word: word.word,
            is_pangram: word.is_pangram,
            definitionMeta: definitionsByWord[word.word] || definitionsByWord[word.word.toLowerCase()] || null,
          };
        }).filter(function(word) { return word.definitionMeta; });
        var wordsByLengthAll = {};
        var wordsByLengthRegular = {};
        var pointsByLength = {};
        var byFirst = {};

        words.forEach(function(word) {
          var length = safeNum(word.length, String(word.word || '').length);
          if (!wordsByLengthAll[length]) wordsByLengthAll[length] = [];
          wordsByLengthAll[length].push(word);
          pointsByLength[length] = (pointsByLength[length] || 0) + getWordPoints(word);

          var first = word.word && word.word[0] ? word.word[0].toUpperCase() : '';
          if (first) {
            if (!byFirst[first]) byFirst[first] = { count: 0, isPangram: false };
            byFirst[first].count += 1;
            if (word.is_pangram === 1) byFirst[first].isPangram = true;
          }
        });

        regularWords.forEach(function(word) {
          var length = safeNum(word.length, String(word.word || '').length);
          if (!wordsByLengthRegular[length]) wordsByLengthRegular[length] = [];
          wordsByLengthRegular[length].push(word);
        });

        var sortedLengths = Object.keys(wordsByLengthAll).map(Number).sort(function(a, b) { return a - b; });
        var sortedFirsts = Object.keys(byFirst).sort();
        var maxWordsByLength = Math.max.apply(null, sortedLengths.map(function(length) { return wordsByLengthAll[length].length; }).concat([1]));
        var maxPointsByLength = Math.max.apply(null, sortedLengths.map(function(length) { return pointsByLength[length] || 0; }).concat([1]));
        var maxFirst = Math.max.apply(null, sortedFirsts.map(function(letter) { return byFirst[letter].count; }).concat([1]));
        var scoreHistogramPeak = histogramPeak(analysis.score && analysis.score.histogram || []);
        var wordCountHistogramPeak = histogramPeak(analysis.wordCount && analysis.wordCount.histogram || []);
        var geniusHistogramPeak = histogramPeak(analysis.genius && analysis.genius.histogram || []);
        var averageLengthHistogramPeak = histogramPeak(analysis.averageWordLength && analysis.averageWordLength.histogram || []);
        var maxCenterCount = Math.max.apply(null, allLettersAZ.map(function(letter) {
          return safeNum(letterFreqMap[letter] && letterFreqMap[letter].asCenter, 0);
        }).concat([1]));
        var maxValidLetterCount = Math.max.apply(null, allLettersAZ.map(function(letter) {
          return safeNum(letterFreqMap[letter] && letterFreqMap[letter].totalAppearances, 0);
        }).concat([1]));
        var sameCenterPuzzles = analysis.sameCenterPuzzles || [];
        var currentCenterUsage = safeNum(letterFreqMap[center] && letterFreqMap[center].asCenter, 0);
        var commonWords = analysis.commonWords || [];
        var maxCommonWordCount = Math.max.apply(null, commonWords.map(function(item) { return safeNum(item.count, 0); }).concat([1]));
        var allAnswerLengthDistribution = analysis.allAnswerLengthDistribution || [];
        var uniqueAnswerLengthDistribution = analysis.uniqueAnswerLengthDistribution || [];
        var maxAllAnswerLengthCount = Math.max.apply(null, allAnswerLengthDistribution.map(function(item) { return safeNum(item.count, 0); }).concat([1]));
        var maxUniqueAnswerLengthCount = Math.max.apply(null, uniqueAnswerLengthDistribution.map(function(item) { return safeNum(item.count, 0); }).concat([1]));
        var totalHistoricalAnswers = safeNum(analysis.totalHistoricalAnswers, allAnswerLengthDistribution.reduce(function(sum, item) {
          return sum + safeNum(item.count, 0);
        }, 0));
        var totalUniqueHistoricalWords = safeNum(analysis.totalUniqueHistoricalWords, uniqueAnswerLengthDistribution.reduce(function(sum, item) {
          return sum + safeNum(item.count, 0);
        }, 0));
        var officialWordSet = new Set(words.map(function(word) { return String(word.word || '').toLowerCase(); }));
        var validLetters = new Set(allLetters.toLowerCase().split(''));
        var centerLower = center.toLowerCase();
        var nonOfficialWords = dictionaryWords.filter(function(word) {
          if (word.length < 4) return false;
          if (!word.includes(centerLower)) return false;
          if (officialWordSet.has(word)) return false;
          return Array.from(word).every(function(letter) { return validLetters.has(letter); });
        }).sort(function(a, b) { return a.localeCompare(b); });
        var scorePercentileText = formatOrdinal(safeNum(analysis.score && analysis.score.percentile, 0));
        var wordCountPercentileText = formatOrdinal(safeNum(analysis.wordCount && analysis.wordCount.percentile, 0));

        document.title = 'Spelling Bee Answers for ' + puzzle.date + ' | SpellingBee Solver';

        var honeycombHtml = '<div class="flex justify-center mb-6">' + buildHoneycombHTML(center, outerLetters) + '</div>';

        var statsHtml = '<div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">' +
          '<div class="stat-card"><p class="stat-value">' + puzzle.word_count + '</p><p class="stat-label">Words</p></div>' +
          '<div class="stat-card"><p class="stat-value">' + puzzle.pangrams_count + '</p><p class="stat-label">Pangrams</p></div>' +
          '<div class="stat-card"><p class="stat-value">' + totalPoints + '</p><p class="stat-label">Points</p></div>' +
