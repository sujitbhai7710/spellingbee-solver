---
import BaseLayout from '../layouts/BaseLayout.astro';

// This page uses the Svelte Solver island for interactivity
---

<BaseLayout title="Spelling Bee Solver" description="Solve any NYT Spelling Bee puzzle. Enter your 7 letters and find all possible words instantly.">
  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="text-center mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-2">🐝 Spelling Bee Solver</h1>
      <p class="text-gray-500 text-lg">Enter your 7 letters and find all possible words</p>
    </div>

    <div class="bg-white rounded-2xl border border-gray-200 p-6 sm:p-8">
      <!-- Instructions -->
      <div class="mb-6 p-4 bg-amber-50 rounded-xl border border-amber-200">
        <p class="text-sm text-amber-800"><strong>How to use:</strong> Type the center letter first (uppercase), then the 6 outer letters (lowercase). Example: <code class="bg-amber-100 px-1 rounded">Nblemod</code> where N is center.</p>
      </div>

      <!-- Input -->
      <div class="mb-6">
        <label for="letters-input" class="block text-sm font-medium text-gray-700 mb-2">Your Letters</label>
        <input
          id="letters-input"
          type="text"
          maxlength="7"
          placeholder="e.g. Nblemod"
          class="w-full px-4 py-3 text-lg font-mono tracking-widest rounded-xl border border-gray-300 focus:border-amber-400 focus:ring-2 focus:ring-amber-200 outline-none transition-all"
          autocomplete="off"
          spellcheck="false"
        />
      </div>

      <!-- Results container -->
      <div id="solver-results" class="hidden">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-gray-800">Results</h2>
          <span id="result-count" class="text-sm text-gray-500"></span>
        </div>

        <!-- Stats -->
        <div id="solver-stats" class="grid grid-cols-3 gap-3 mb-4"></div>

        <!-- Pangrams -->
        <div id="solver-pangrams" class="mb-4 hidden">
          <h3 class="text-sm font-bold text-amber-700 mb-2 flex items-center gap-1"><span>★</span> Pangrams</h3>
          <div id="pangram-list" class="flex flex-wrap gap-2"></div>
        </div>

        <!-- Words by length -->
        <div id="solver-words" class="max-h-96 overflow-y-auto custom-scroll divide-y divide-gray-100"></div>
      </div>

      <!-- Loading state -->
      <div id="solver-loading" class="hidden text-center py-8">
        <div class="inline-block w-8 h-8 border-3 border-amber-400 border-t-transparent rounded-full animate-spin"></div>
        <p class="text-gray-500 mt-2">Solving...</p>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  const API_BASE = 'https://spelling-bee-api.sbsolver.workers.dev';
  let dictionary: string[] = [];
  let dictLoaded = false;

  async function loadDictionary() {
    if (dictLoaded) return;
    try {
      const res = await fetch('https://raw.githubusercontent.com/words/an-array-of-english-words/refs/heads/master/index.json');
      dictionary = await res.json();
      dictLoaded = true;
    } catch (e) {
      console.error('Failed to load dictionary:', e);
    }
  }

  function solveSpellingBee(centerLetter: string, outerLetters: string[], dict: string[]) {
    const allLetters = [centerLetter, ...outerLetters];
    const letterSet = new Set(allLetters.map(l => l.toLowerCase()));
    const results: { word: string; isPangram: boolean }[] = [];

    for (const word of dict) {
      const w = word.toLowerCase();
      if (w.length < 4) continue;
      if (!w.includes(centerLetter.toLowerCase())) continue;
      let valid = true;
      let pangram = true;
      for (const ch of w) {
        if (!letterSet.has(ch)) { valid = false; break; }
      }
      if (!valid) continue;
      for (const l of letterSet) {
        if (!w.includes(l)) { pangram = false; break; }
      }
      results.push({ word: w, isPangram: pangram });
    }

    return results.sort((a, b) => {
      if (a.isPangram !== b.isPangram) return a.isPangram ? -1 : 1;
      if (b.word.length !== a.word.length) return b.word.length - a.word.length;
      return a.word.localeCompare(b.word);
    });
  }

  function calculateWordPoints(word: string, isPangram: boolean) {
    let pts = word.length === 4 ? 1 : word.length;
    if (isPangram) pts += 7;
    return pts;
  }

  const input = document.getElementById('letters-input') as HTMLInputElement;
  const resultsDiv = document.getElementById('solver-results')!;
  const loadingDiv = document.getElementById('solver-loading')!;
  const countSpan = document.getElementById('result-count')!;
  const statsDiv = document.getElementById('solver-stats')!;
  const pangramsDiv = document.getElementById('solver-pangrams')!;
  const pangramList = document.getElementById('pangram-list')!;
  const wordsDiv = document.getElementById('solver-words')!;

  let debounceTimer: ReturnType<typeof setTimeout>;

  input.addEventListener('input', async () => {
    clearTimeout(debounceTimer);
    const val = input.value.trim();

    if (val.length < 7) {
      resultsDiv.classList.add('hidden');
      return;
    }

    debounceTimer = setTimeout(async () => {
      loadingDiv.classList.remove('hidden');
      resultsDiv.classList.add('hidden');

      await loadDictionary();

      const center = val[0].toUpperCase();
      const outer = val.slice(1).toUpperCase().split('');
      const results = solveSpellingBee(center, outer, dictionary);

      loadingDiv.classList.add('hidden');
      resultsDiv.classList.remove('hidden');

      const pangrams = results.filter(r => r.isPangram);
      const regular = results.filter(r => !r.isPangram);
      const totalPts = results.reduce((s, r) => s + calculateWordPoints(r.word, r.isPangram), 0);

      countSpan.textContent = `${results.length} words found`;
      statsDiv.innerHTML = `
        <div class="bg-gray-50 rounded-lg p-3 text-center">
          <p class="text-xl font-bold text-amber-600">${results.length}</p>
          <p class="text-xs text-gray-500">Words</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-3 text-center">
          <p class="text-xl font-bold text-amber-600">${pangrams.length}</p>
          <p class="text-xs text-gray-500">Pangrams</p>
        </div>
        <div class="bg-gray-50 rounded-lg p-3 text-center">
          <p class="text-xl font-bold text-amber-600">${totalPts}</p>
          <p class="text-xs text-gray-500">Points</p>
        </div>
      `;

      if (pangrams.length > 0) {
        pangramsDiv.classList.remove('hidden');
        pangramList.innerHTML = pangrams.map(r =>
          `<span class="pangram-word px-3 py-1.5 rounded-md text-sm border border-amber-200">${r.word} <span class="text-xs text-amber-400">${r.word.length}</span></span>`
        ).join('');
      } else {
        pangramsDiv.classList.add('hidden');
      }

      const byLen: Record<number, typeof regular> = {};
      for (const w of regular) {
        const l = w.word.length;
        if (!byLen[l]) byLen[l] = [];
        byLen[l].push(w);
      }

      wordsDiv.innerHTML = Object.keys(byLen).sort((a,b) => +b - +a).map(len => `
        <div class="px-4 py-3">
          <p class="text-xs font-semibold text-gray-400 mb-2 uppercase tracking-wide">${len}-Letter Words (${byLen[+len].length})</p>
          <div class="flex flex-wrap gap-1.5">
            ${byLen[+len].map(w => `<span class="word-item bg-gray-50 text-gray-700 border border-gray-100">${w.word}</span>`).join('')}
          </div>
        </div>
      `).join('');
    }, 300);
  });

  // Focus input on load
  input.focus();
</script>
