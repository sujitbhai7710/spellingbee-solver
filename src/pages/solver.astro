---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Spelling Bee Solver" description="Solve any NYT Spelling Bee puzzle. Enter your 7 letters and find all possible words instantly.">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">
    <!-- Header -->
    <div class="text-center mb-8">
      <h1 class="text-3xl sm:text-4xl font-black text-gray-900 mb-2">Spelling Bee Solver</h1>
      <p class="text-gray-500 text-lg">Enter letters and click a button below to get answers</p>
    </div>

    <div class="flex flex-col lg:flex-row gap-8 items-start">
      <!-- Left: Input & Honeycomb -->
      <div class="w-full lg:w-auto flex-shrink-0">
        <div class="card-elevated p-6 sm:p-8">
          <!-- Interactive Honeycomb Input -->
          <div id="solver-hex-container" class="honeycomb-solver mx-auto">
            <!-- Center hex -->
            <div class="solver-hex solver-hex-center solver-hex-pos-center">
              <svg viewBox="0 -17 256 256" fill="none" class="solver-hex-svg">
                <path d="M0 111L64 0.148707L192 0.148707L256 111L192 221.851L64 221.851L0 111Z" fill="currentColor" />
              </svg>
              <input type="text" class="solver-hex-input" maxlength="1" id="center-letter" name="centerLetter" required autocomplete="off" aria-label="Center Letter" />
            </div>

            <!-- Outer hexes -->
            <div class="solver-hex solver-hex-outer solver-hex-pos-0">
              <svg viewBox="0 -17 256 256" fill="none" class="solver-hex-svg">
                <path d="M0 111L64 0.148707L192 0.148707L256 111L192 221.851L64 221.851L0 111Z" fill="currentColor" />
              </svg>
              <input type="text" class="solver-hex-input" maxlength="1" name="outerLetters" required autocomplete="off" aria-label="Outer Letter 1" />
            </div>

            <div class="solver-hex solver-hex-outer solver-hex-pos-1">
              <svg viewBox="0 -17 256 256" fill="none" class="solver-hex-svg">
                <path d="M0 111L64 0.148707L192 0.148707L256 111L192 221.851L64 221.851L0 111Z" fill="currentColor" />
              </svg>
              <input type="text" class="solver-hex-input" maxlength="1" name="outerLetters" required autocomplete="off" aria-label="Outer Letter 2" />
            </div>

            <div class="solver-hex solver-hex-outer solver-hex-pos-2">
              <svg viewBox="0 -17 256 256" fill="none" class="solver-hex-svg">
                <path d="M0 111L64 0.148707L192 0.148707L256 111L192 221.851L64 221.851L0 111Z" fill="currentColor" />
              </svg>
              <input type="text" class="solver-hex-input" maxlength="1" name="outerLetters" required autocomplete="off" aria-label="Outer Letter 3" />
            </div>

            <div class="solver-hex solver-hex-outer solver-hex-pos-3">
              <svg viewBox="0 -17 256 256" fill="none" class="solver-hex-svg">
                <path d="M0 111L64 0.148707L192 0.148707L256 111L192 221.851L64 221.851L0 111Z" fill="currentColor" />
              </svg>
              <input type="text" class="solver-hex-input" maxlength="1" name="outerLetters" required autocomplete="off" aria-label="Outer Letter 4" />
            </div>

            <div class="solver-hex solver-hex-outer solver-hex-pos-4">
              <svg viewBox="0 -17 256 256" fill="none" class="solver-hex-svg">
                <path d="M0 111L64 0.148707L192 0.148707L256 111L192 221.851L64 221.851L0 111Z" fill="currentColor" />
              </svg>
              <input type="text" class="solver-hex-input" maxlength="1" name="outerLetters" required autocomplete="off" aria-label="Outer Letter 5" />
            </div>

            <div class="solver-hex solver-hex-outer solver-hex-pos-5">
              <svg viewBox="0 -17 256 256" fill="none" class="solver-hex-svg">
                <path d="M0 111L64 0.148707L192 0.148707L256 111L192 221.851L64 221.851L0 111Z" fill="currentColor" />
              </svg>
              <input type="text" class="solver-hex-input" maxlength="1" name="outerLetters" required autocomplete="off" aria-label="Outer Letter 6" />
            </div>
          </div>

          <!-- Action Buttons -->
          <div class="mt-6 flex flex-col items-center gap-3">
            <div class="flex items-center justify-center gap-3">
              <button id="solve-btn" class="btn-primary !py-2.5 !px-6 text-sm font-bold">
                Solve Puzzle
                <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M6.5 3.5L11 8l-4.5 4.5L5.5 11 8.5 8 5.5 5z"/></svg>
              </button>
              <button id="clear-btn" class="btn-secondary !py-2.5 !px-5 text-sm">Clear</button>
            </div>
            <button id="autofill-btn" class="autofill-btn text-sm font-semibold">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
              Autofill Today's NYT Puzzle
            </button>
          </div>
        </div>
      </div>

      <!-- Right: Results -->
      <div class="flex-1 min-w-0 w-full">
        <!-- Loading -->
        <div id="solver-loading" class="hidden text-center py-12">
          <div class="inline-block w-10 h-10 border-[3px] border-amber-400 border-t-transparent rounded-full animate-spin"></div>
          <p class="text-gray-500 mt-3 font-medium">Solving...</p>
        </div>

        <!-- Results -->
        <div id="solver-results" class="hidden">
          <div class="flex items-center justify-between mb-5">
            <h2 class="text-xl font-bold text-gray-900">Results</h2>
            <span id="result-count" class="text-sm text-gray-500 font-medium"></span>
          </div>

          <!-- Stats -->
          <div id="solver-stats" class="grid grid-cols-3 gap-3 mb-6"></div>

          <!-- Pangrams -->
          <div id="solver-pangrams" class="mb-6 hidden">
            <h3 class="text-sm font-bold text-amber-700 mb-3 flex items-center gap-1.5">
              <svg width="14" height="14" viewBox="0 0 20 20" fill="#F59E0B"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.33L10 13.27l-4.77 2.51.91-5.33L2.27 6.62l5.34-.78z"/></svg>
              Pangrams
            </h3>
            <div id="pangram-list" class="flex flex-wrap gap-2"></div>
          </div>

          <!-- Words by length -->
          <div id="solver-words" class="card-elevated max-h-[500px] overflow-y-auto custom-scroll divide-y divide-gray-50"></div>
        </div>

        <!-- Empty State -->
        <div id="solver-empty" class="text-center py-12">
          <div class="hex-empty-icon mx-auto mb-4">
            <svg viewBox="0 -17 256 256" fill="none" width="64" height="64">
              <path d="M0 111L64 0.148707L192 0.148707L256 111L192 221.851L64 221.851L0 111Z" fill="#FEF3C7" stroke="#F7C948" stroke-width="2"/>
            </svg>
          </div>
          <p class="text-gray-400 font-medium">Click the hexagons above and type your letters</p>
          <p class="text-gray-300 text-sm mt-1">Or use Autofill to load today's puzzle</p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ API_BASE: 'https://spelling-bee-api.sbsolver.workers.dev' }}>
  // Dictionary
  let dictionary = [];
  let dictLoaded = false;

  async function loadDictionary() {
    if (dictLoaded) return;
    try {
      const res = await fetch('https://raw.githubusercontent.com/words/an-array-of-english-words/refs/heads/master/index.json');
      dictionary = await res.json();
      dictLoaded = true;
    } catch (e) {
      console.error('Failed to load dictionary:', e);
    }
  }

  function solveSpellingBee(centerLetter, outerLetters, dict) {
    const allLetters = [centerLetter, ...outerLetters];
    const letterSet = new Set(allLetters.map(l => l.toLowerCase()));
    const results = [];

    for (const word of dict) {
      const w = word.toLowerCase();
      if (w.length < 4) continue;
      if (!w.includes(centerLetter.toLowerCase())) continue;
      let valid = true;
      let pangram = true;
      for (const ch of w) {
        if (!letterSet.has(ch)) { valid = false; break; }
      }
      if (!valid) continue;
      for (const l of letterSet) {
        if (!w.includes(l)) { pangram = false; break; }
      }
      results.push({ word: w, isPangram: pangram });
    }

    return results.sort((a, b) => {
      if (a.isPangram !== b.isPangram) return a.isPangram ? -1 : 1;
      if (b.word.length !== a.word.length) return b.word.length - a.word.length;
      return a.word.localeCompare(b.word);
    });
  }

  function calculateWordPoints(word, isPangram) {
    let pts = word.length === 4 ? 1 : word.length;
    if (isPangram) pts += 7;
    return pts;
  }

  function displayResults(results) {
    const resultsDiv = document.getElementById('solver-results');
    const loadingDiv = document.getElementById('solver-loading');
    const emptyDiv = document.getElementById('solver-empty');
    const countSpan = document.getElementById('result-count');
    const statsDiv = document.getElementById('solver-stats');
    const pangramsDiv = document.getElementById('solver-pangrams');
    const pangramList = document.getElementById('pangram-list');
    const wordsDiv = document.getElementById('solver-words');

    loadingDiv.classList.add('hidden');
    emptyDiv.classList.add('hidden');
    resultsDiv.classList.remove('hidden');

    const pangrams = results.filter(r => r.isPangram);
    const regular = results.filter(r => !r.isPangram);
    const totalPts = results.reduce((s, r) => s + calculateWordPoints(r.word, r.isPangram), 0);

    countSpan.textContent = results.length + ' words found';
    statsDiv.innerHTML = `
      <div class="stat-card"><p class="stat-value">${results.length}</p><p class="stat-label">Words</p></div>
      <div class="stat-card"><p class="stat-value">${pangrams.length}</p><p class="stat-label">Pangrams</p></div>
      <div class="stat-card"><p class="stat-value">${totalPts}</p><p class="stat-label">Points</p></div>
    `;

    if (pangrams.length > 0) {
      pangramsDiv.classList.remove('hidden');
      pangramList.innerHTML = pangrams.map(r =>
        '<span class="pangram-chip"><span class="star">&#9733;</span>' + r.word + ' <span class="text-xs text-amber-500 opacity-70">' + r.word.length + '</span></span>'
      ).join('');
    } else {
      pangramsDiv.classList.add('hidden');
    }

    const byLen = {};
    for (const w of regular) {
      const l = w.word.length;
      if (!byLen[l]) byLen[l] = [];
      byLen[l].push(w);
    }

    wordsDiv.innerHTML = Object.keys(byLen).sort((a,b) => +b - +a).map(len => `
      <div class="px-5 py-4">
        <p class="text-xs font-bold text-gray-400 mb-3 uppercase tracking-wider">${len}-Letter Words (${byLen[+len].length})</p>
        <div class="flex flex-wrap gap-2">
          ${byLen[+len].map(w => '<span class="word-chip">' + w.word + '</span>').join('')}
        </div>
      </div>
    `).join('');
  }

  async function solve() {
    const centerInput = document.getElementById('center-letter');
    const outerInputs = document.querySelectorAll('.solver-hex-outer .solver-hex-input');
    const center = centerInput.value.trim().toUpperCase();
    const outer = [];
    outerInputs.forEach(input => {
      const v = input.value.trim().toUpperCase();
      if (v) outer.push(v);
    });

    if (!center || outer.length < 1) {
      // Highlight center if empty
      if (!center) {
        centerInput.focus();
      }
      return;
    }

    const loadingDiv = document.getElementById('solver-loading');
    const resultsDiv = document.getElementById('solver-results');
    const emptyDiv = document.getElementById('solver-empty');
    resultsDiv.classList.add('hidden');
    emptyDiv.classList.add('hidden');
    loadingDiv.classList.remove('hidden');

    await loadDictionary();
    const results = solveSpellingBee(center, outer, dictionary);
    displayResults(results);
  }

  // Hex input behavior: auto-uppercase, auto-advance on type, auto-delete on empty backspace
  const allHexInputs = document.querySelectorAll('.solver-hex-input');
  const centerInput = document.getElementById('center-letter');
  const outerInputList = Array.from(document.querySelectorAll('.solver-hex-outer .solver-hex-input'));

  allHexInputs.forEach((input, idx) => {
    input.addEventListener('input', function(e) {
      const val = this.value.toUpperCase();
      this.value = val;

      if (val.length === 1) {
        // Auto-advance to next input
        if (this.id === 'center-letter') {
          // Move to first outer
          const firstEmpty = outerInputList.find(i => !i.value);
          if (firstEmpty) firstEmpty.focus();
          else outerInputList[0]?.focus();
        } else {
          const currentIdx = outerInputList.indexOf(this);
          const nextEmpty = outerInputList.slice(currentIdx + 1).find(i => !i.value);
          if (nextEmpty) nextEmpty.focus();
          else if (currentIdx < outerInputList.length - 1) outerInputList[currentIdx + 1]?.focus();
        }
      }
    });

    input.addEventListener('keydown', function(e) {
      if (e.key === 'Backspace' && !this.value) {
        // Move to previous input
        if (this.id !== 'center-letter') {
          const currentIdx = outerInputList.indexOf(this);
          if (currentIdx > 0) {
            outerInputList[currentIdx - 1].focus();
            outerInputList[currentIdx - 1].value = '';
          } else {
            centerInput.focus();
            centerInput.value = '';
          }
        }
      }
      if (e.key === 'Enter') {
        e.preventDefault();
        solve();
      }
    });

    // Select all text on focus for easy replacement
    input.addEventListener('focus', function() {
      this.select();
    });
  });

  // Solve button
  document.getElementById('solve-btn').addEventListener('click', solve);

  // Clear button
  document.getElementById('clear-btn').addEventListener('click', function() {
    allHexInputs.forEach(input => { input.value = ''; });
    centerInput.focus();
    document.getElementById('solver-results').classList.add('hidden');
    document.getElementById('solver-loading').classList.add('hidden');
    document.getElementById('solver-empty').classList.remove('hidden');
  });

  // Autofill button
  document.getElementById('autofill-btn').addEventListener('click', async function() {
    const btn = this;
    btn.disabled = true;
    btn.innerHTML = '<div class="inline-block w-4 h-4 border-2 border-amber-500 border-t-transparent rounded-full animate-spin"></div> Loading...';

    try {
      const res = await fetch(API_BASE + '/today');
      const data = await res.json();
      const puzzle = data.puzzle || {};

      if (!puzzle.letters) {
        throw new Error('No puzzle data');
      }

      const center = puzzle.letters.toUpperCase();
      const allLetters = (puzzle.all_letters || '').toUpperCase();
      const outerLetters = allLetters.split('').filter(l => l !== center);

      centerInput.value = center;
      outerInputList.forEach((input, i) => {
        input.value = outerLetters[i] || '';
      });

      // Auto-solve after filling
      solve();
    } catch (e) {
      console.error('Autofill failed:', e);
      alert('Could not load today\'s puzzle. Please try again.');
    } finally {
      btn.disabled = false;
      btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg> Autofill Today\'s NYT Puzzle';
    }
  });
</script>

<style>
  /* ========================================
     Solver Honeycomb - Interactive hex grid
     Based on beesolver.com approach
     ======================================== */

  .honeycomb-solver {
    position: relative;
    width: 280px;
    height: 280px;
    margin: 0 auto;
  }

  .solver-hex {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 38%;
    height: 38%;
  }

  /* Position transforms */
  .solver-hex-pos-center {
    transform: translate(-50%, -50%);
    z-index: 2;
  }
  .solver-hex-pos-0 {
    transform: translate(-50%, -50%) translate(0, -92%);
  }
  .solver-hex-pos-1 {
    transform: translate(-50%, -50%) translate(80%, -46%);
  }
  .solver-hex-pos-2 {
    transform: translate(-50%, -50%) translate(80%, 46%);
  }
  .solver-hex-pos-3 {
    transform: translate(-50%, -50%) translate(0, 92%);
  }
  .solver-hex-pos-4 {
    transform: translate(-50%, -50%) translate(-80%, 46%);
  }
  .solver-hex-pos-5 {
    transform: translate(-50%, -50%) translate(-80%, -46%);
  }

  .solver-hex-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .solver-hex-outer .solver-hex-svg {
    color: #e5e7eb;
  }

  .solver-hex-center .solver-hex-svg {
    color: #f7c948;
  }

  .solver-hex-input {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
    background: transparent;
    text-align: center;
    text-transform: uppercase;
    font-size: 1.75rem;
    font-weight: 700;
    font-family: 'Inter', system-ui, sans-serif;
    color: #475569;
    outline: none;
    cursor: pointer;
    z-index: 1;
    caret-color: transparent;
  }

  .solver-hex-center .solver-hex-input {
    font-weight: 900;
    color: white;
  }

  .solver-hex-input::placeholder {
    color: transparent;
  }

  /* Focus states */
  .solver-hex-outer:focus-within .solver-hex-svg {
    color: #fef3c7;
  }

  .solver-hex-center:focus-within .solver-hex-svg {
    color: #fbbf24;
  }

  .solver-hex-outer:hover .solver-hex-svg {
    color: #f3f4f6;
  }

  .solver-hex-center:hover .solver-hex-svg {
    color: #fbbf24;
  }

  /* Autofill button */
  .autofill-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: 8px;
    background: #fffbeb;
    color: #92400e;
    border: 1px solid #fde68a;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .autofill-btn:hover {
    background: #fef3c7;
    border-color: #f59e0b;
  }

  .autofill-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .honeycomb-solver {
      width: 240px;
      height: 240px;
    }
    .solver-hex-input {
      font-size: 1.4rem;
    }
  }
</style>
