                  <span class="font-bold text-gray-800">{avgPointsPerWord}</span>
                  <span class="text-gray-400 mx-1">pts/word</span>
                </span>
              </div>
              <div class="w-full bg-gray-100 rounded-full h-3 overflow-hidden">
                <div class="bg-gradient-to-r from-emerald-300 to-emerald-500 h-3 rounded-full transition-all" style={`width: ${Math.min((parseFloat(avgPointsPerWord) / 5) * 100, 100)}%`}></div>
              </div>
              <p class="text-xs text-gray-400 mt-1">
                {parseFloat(avgPointsPerWord) >= 2.5
                  ? 'High points-per-word ratio — longer and pangram-heavy words boost this.'
                  : 'Lower points-per-word ratio — more short words diluting the average.'
                }
              </p>
            </div>
          </div>

          <!-- Verdict -->
          <div class="mt-6 p-4 bg-gradient-to-r from-gray-50 to-amber-50/30 rounded-xl border border-gray-100">
            <p class="text-sm text-gray-700 leading-relaxed">
              {wordPercentile >= 70
                ? `This is a <strong>larger-than-average</strong> puzzle, ranking roughly in the ${wordPercentile}th percentile for word count. With ${puzzle.word_count} words and ${totalPoints} total points, there's plenty of opportunity for scoring.`
                : wordPercentile >= 30
                  ? `This is a <strong>fairly typical</strong> puzzle, ranking roughly in the ${wordPercentile}th percentile for word count. It sits close to the average of ${safeNum(averages.wordsPerPuzzle).toFixed(0)} words per puzzle.`
                  : `This is a <strong>smaller-than-average</strong> puzzle, ranking roughly in the ${wordPercentile}th percentile for word count. With only ${puzzle.word_count} words, every find counts more toward your progress.`
              }
            </p>
          </div>
        </div>

        <!-- ===== SECTION 8: HAVEN'T I SEEN THESE LETTERS BEFORE? ===== -->
        <div class="card-elevated p-6 mb-8">
          <h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            Haven't I Seen These Letters Before?
          </h2>
          <p class="text-sm text-gray-500 mb-4">How often each letter in today's puzzle has appeared across all {safeLocale(totalPuzzles)} puzzles.</p>
          <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-3">
            {allLetters.split('').map(l => {
              const freq = letterFreqMap[l] || { totalAppearances: 0, asCenter: 0, asOuter: 0 };
              const centerInfo = centerFreqMap[l] || { count: 0, percentage: 0 };
              const isCenter = l === center;
              return (
                <div class:list={[
                  'p-4 rounded-xl border text-center',
                  isCenter ? 'border-amber-300 bg-amber-50' : 'border-gray-100 bg-white'
                ]}>
                  <span class:list={[
                    'inline-flex items-center justify-center w-10 h-10 rounded-full text-lg font-black mb-2',
                    isCenter ? 'bg-amber-400 text-white' : 'bg-gray-100 text-gray-700'
                  ]}>{l}</span>
                  {isCenter && <span class="block text-[10px] font-bold text-amber-600 mb-1">CENTER</span>}
                  <div class="space-y-1">
                    <div class="flex items-center justify-between text-xs">
                      <span class="text-gray-400">As center</span>
                      <span class="font-bold text-gray-700">{centerInfo.count || freq.asCenter}</span>
                    </div>
                    <div class="flex items-center justify-between text-xs">
                      <span class="text-gray-400">Total</span>
                      <span class="font-bold text-gray-700">{freq.totalAppearances}</span>
                    </div>
                    {centerInfo.percentage > 0 && (
                      <div class="mt-1.5">
                        <div class="w-full bg-gray-100 rounded-full h-1.5">
                          <div class="bg-amber-400 h-1.5 rounded-full" style={`width: ${Math.min(centerInfo.percentage * 10, 100)}%`}></div>
                        </div>
                      </div>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
          <p class="text-sm text-gray-500 mt-4">
            {(() => {
              const centerData = letterFreqMap[center] || {};
              const centerTimes = centerData.asCenter || 0;
              return <span>Center letter <strong>{center}</strong> has been the center letter <strong>{centerTimes} times</strong> across all puzzles
                {centerTimes > 200 ? ' — making it one of the most frequently used center letters.' : centerTimes > 100 ? ' — a fairly common center letter.' : ' — a relatively uncommon center letter.'}
              </span>;
            })()}
          </p>
        </div>

        <!-- ===== SECTION 9: HAVEN'T I SEEN THESE WORDS BEFORE? ===== -->
        <div class="card-elevated p-6 mb-8">
          <h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0891B2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            Haven't I Seen These Words Before?
          </h2>
          <p class="text-sm text-gray-500 mb-4">Word frequency analysis — how often words from today's puzzle appear across recent puzzles.</p>

          <!-- Rarity Legend -->
          <div class="flex flex-wrap gap-3 mb-5">
            {Object.entries(rarityColors).map(([key, val]) => (
              <div class:list={['flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold border', val.bg, val.border, val.text]}>
                <span>{val.label}</span>
              </div>
            ))}
          </div>

          <!-- Words by Rarity -->
          {['unique', 'uncommon', 'occasional', 'common'].map(rarity => {
            const filteredWords = wordRarity.filter(w => w.rarity === rarity);
            if (filteredWords.length === 0) return null;
            const style = rarityColors[rarity];
            return (
              <div class="mb-4">
                <p class:list={['text-xs font-bold uppercase tracking-wider mb-2', style.text]}>
                  {rarity === 'unique' ? 'Unique to this puzzle' : rarity === 'uncommon' ? 'Uncommon (1 recent appearance)' : rarity === 'occasional' ? 'Occasional (2-3 recent appearances)' : 'Common (4+ recent appearances)'}
                  <span class="font-normal ml-1">({filteredWords.length})</span>
                </p>
                <div class="flex flex-wrap gap-1.5">
                  {filteredWords.map(w => (
                    <span class:list={[
                      'inline-flex items-center gap-1 px-2.5 py-1 rounded-lg text-xs font-medium border',
                      style.bg, style.border, style.text,
                      w.is_pangram ? '!bg-amber-50 !border-amber-300 !text-amber-800 font-bold' : ''
                    ]}>
                      {w.is_pangram === 1 && <span class="text-amber-500">&#9733;</span>}
                      {w.word}
                      <span class="opacity-50">{w.length}</span>
                    </span>
                  ))}
                </div>
              </div>
            );
          })}

          <p class="text-sm text-gray-500 mt-4">
            {(() => {
              const uniqueCount = wordRarity.filter(w => w.rarity === 'unique').length;
              const commonCount = wordRarity.filter(w => w.rarity === 'common').length;
              return <span>This puzzle has <strong>{uniqueCount} words</strong> unique to it among recent puzzles, and <strong>{commonCount} words</strong> that appear frequently.
                {uniqueCount > words.length * 0.5 ? ' This puzzle features an unusually high number of uncommon words, making it more challenging.' : ''}
              </span>;
            })()}
          </p>
        </div>

        <!-- ========== SEO CONTENT SECTION ========== -->
        <div class="mt-10 p-6 bg-gray-50 rounded-2xl">
          <h2 class="text-lg font-bold text-gray-800 mb-3">Today's Spelling Bee Puzzle Breakdown</h2>
          <p class="text-gray-600 leading-relaxed text-sm mb-3">The New York Times Spelling Bee for <strong>{puzzle.date}</strong> uses <strong>{center}</strong> as the mandatory center letter with outer letters <strong>{outerLetters.join(', ')}</strong>. Players need to find as many words as possible that include the center letter and are at least four letters long. Each letter can be used multiple times within a word.</p>
          <p class="text-gray-600 leading-relaxed text-sm mb-3">Today's puzzle contains <strong>{puzzle.word_count} valid words</strong> and <strong>{puzzle.pangrams_count} pangram{puzzle.pangrams_count !== 1 ? 's' : ''}</strong>. A pangram is a word that uses all seven available letters at least once. {hasPerfectPangram ? `This puzzle features a perfect pangram — a word that uses each letter exactly once, making it exactly 7 letters long. The perfect pangram${perfectPangrams.length > 1 ? 's are' : ' is'} <strong>${perfectPangrams.join(', ').toUpperCase()}</strong>.` : 'There are no perfect pangrams in today\'s puzzle, meaning no 7-letter word uses each letter exactly once.'}</p>
          <p class="text-gray-600 leading-relaxed text-sm mb-3">The maximum possible score for this puzzle is <strong>{totalPoints} points</strong>. Four-letter words earn 1 point each, while longer words earn points equal to their letter count. Pangrams receive a bonus 7 points on top of their letter-count score. To reach Genius level, you need <strong>{geniusThreshold} points</strong> (70% of the total), which can be achieved by finding <strong>{geniusWordCount} of the {words.length} words</strong>.</p>
          <p class="text-gray-600 leading-relaxed text-sm mb-3">Word lengths in today's Bee range from 4 to {sortedLengths[sortedLengths.length - 1] || '?'} letters. The most common word length is {sortedLengths.reduce((a, b) => wordsByLengthAll[a].length >= wordsByLengthAll[b].length ? a : b)}-letter words with {wordsByLengthAll[sortedLengths.reduce((a, b) => wordsByLengthAll[a].length >= wordsByLengthAll[b].length ? a : b)]?.length || 0} entries. The center letter {center} appears in every single word, while the outer letters each appear in a varying number of answers.</p>
          <p class="text-gray-600 leading-relaxed text-sm">SpellingBee Solver provides the complete word list, pangram details, scoring breakdown, and in-depth statistical analysis for every daily Spelling Bee puzzle. Whether you're stuck on a few words or want to verify your progress, our tool gives you instant access to today's full solution set without any subscription or paywall.</p>
        </div>

        <!-- ========== FAQ SECTION ========== -->
        <div class="mt-8">
          <h2 class="text-lg font-bold text-gray-800 mb-4">Frequently Asked Questions</h2>
          <div class="space-y-3">
            <details class="card-elevated p-5 group" open>
              <summary class="font-semibold text-gray-800 cursor-pointer flex items-center justify-between">What are the NYT Spelling Bee answers for {puzzle.date}?
                <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <p class="text-sm text-gray-600 mt-3 leading-relaxed">The Spelling Bee for {puzzle.date} has {puzzle.word_count} words and {puzzle.pangrams_count} pangram{puzzle.pangrams_count !== 1 ? 's' : ''}. The center letter is {center} and the available letters are {allLetters.split('').join(', ')}. Scroll up to see the complete word list organized by length.</p>
            </details>
            <details class="card-elevated p-5 group">
              <summary class="font-semibold text-gray-800 cursor-pointer flex items-center justify-between">What score do I need for Genius today?
                <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <p class="text-sm text-gray-600 mt-3 leading-relaxed">You need {geniusThreshold} points out of {totalPoints} total to reach Genius. That's 70% of the maximum score. You can achieve this by finding {geniusWordCount} of the {words.length} words. {puzzle.pangrams_count > 0 ? `Finding the pangram${puzzle.pangrams_count > 1 ? 's' : ''} helps a lot since each one is worth at least 14 points (7-letter word = 7 points + 7 bonus).` : ''}</p>
            </details>
            <details class="card-elevated p-5 group">
              <summary class="font-semibold text-gray-800 cursor-pointer flex items-center justify-between">Does today's puzzle have a perfect pangram?
                <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <p class="text-sm text-gray-600 mt-3 leading-relaxed">{hasPerfectPangram ? `Yes! Today's puzzle has a perfect pangram: <strong>${perfectPangrams.join(', ').toUpperCase()}</strong>. A perfect pangram uses all seven letters exactly once, making it exactly 7 letters long.` : 'No, today\'s puzzle does not have a perfect pangram. A perfect pangram would be a 7-letter word that uses each of the seven available letters exactly once.'}</p>
            </details>
            <details class="card-elevated p-5 group">
              <summary class="font-semibold text-gray-800 cursor-pointer flex items-center justify-between">How does the NYT Spelling Bee scoring work?
                <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <p class="text-sm text-gray-600 mt-3 leading-relaxed">Four-letter words are worth 1 point each. Words with five or more letters earn points equal to their length. Pangrams (words using all seven letters) get a 7-point bonus on top of their base score. The progress levels are: Beginner (0%), Starting (2%), Solid (5%), Nice (8%), Good (15%), Great (25%), Amazing (40%), Genius (70%), and Queen Bee (100%).</p>
            </details>
            <details class="card-elevated p-5 group">
              <summary class="font-semibold text-gray-800 cursor-pointer flex items-center justify-between">How does today's puzzle compare to others?
                <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <p class="text-sm text-gray-600 mt-3 leading-relaxed">Today's puzzle ranks roughly in the {wordPercentile}th percentile for word count with {puzzle.word_count} words (average is {safeNum(averages.wordsPerPuzzle).toFixed(0)}). It has {puzzle.pangrams_count} pangram{puzzle.pangrams_count !== 1 ? 's' : ''} compared to the average of {safeNum(averages.pangramsPerPuzzle).toFixed(1)}. {faqCompareText}</p>
            </details>
          </div>
        </div>
      </div>

      <!-- ========== SIDEBAR ========== -->
      <aside class="w-full lg:w-72 flex-shrink-0 space-y-4">
        <div class="card-elevated p-5">
          <h3 class="font-bold text-gray-800 mb-4 text-sm">Recent Puzzles</h3>
          <div class="space-y-1">
            {recentPuzzles.map(p => (
              <a href="/archive" class="block p-2.5 rounded-lg hover:bg-amber-50 transition-colors group">
                <p class="text-sm font-medium text-gray-700 group-hover:text-amber-700">{p.date}</p>
                <p class="text-xs text-gray-400">Center: {p.letters} &middot; {p.word_count} words</p>
              </a>
            ))}
          </div>
        </div>

        <div class="card-elevated p-5 space-y-2">
          <a href="/solver" class="btn-primary w-full text-sm !py-3">
            <svg width="16" height="18" viewBox="0 0 100 110"><polygon points="50,3 95,27.5 95,72.5 50,97 5,72.5 5,27.5" fill="white" stroke="white" stroke-width="3"/></svg>
            Use Solver
          </a>
          <a href="/yesterday" class="btn-secondary w-full text-sm !py-3">Yesterday's Answers</a>
          <a href="/archive" class="btn-secondary w-full text-sm !py-3">Puzzle Archive</a>
        </div>

        <!-- Sidebar Stats Card -->
        <div class="card-elevated p-5">
          <h3 class="font-bold text-gray-800 mb-3 text-sm">Quick Stats</h3>
          <div class="space-y-2.5">
            <div class="flex items-center justify-between">
              <span class="text-xs text-gray-500">Total puzzles</span>
              <span class="text-xs font-bold text-gray-700">{safeLocale(totalPuzzles)}</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-xs text-gray-500">Avg words/puzzle</span>
              <span class="text-xs font-bold text-gray-700">{safeNum(averages.wordsPerPuzzle).toFixed(1)}</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-xs text-gray-500">Avg pangrams/puzzle</span>
              <span class="text-xs font-bold text-gray-700">{safeNum(averages.pangramsPerPuzzle).toFixed(1)}</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-xs text-gray-500">Most common center</span>
              <span class="text-xs font-bold text-gray-700">{centerFreq.length > 0 ? centerFreq[0].letter : '\u2014'}</span>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ API_BASE: 'https://spelling-bee-api.sbsolver.workers.dev', puzzleId: (data.puzzle || {}).puzzle_id }}>
  // Fetch pangram history for each pangram word
  document.addEventListener('DOMContentLoaded', () => {
    const pangramElements = document.querySelectorAll('[id^="pangram-history-"]');
    pangramElements.forEach(async (el) => {
      const word = el.id.replace('pangram-history-', '');
      if (!word) return;
      try {
        const res = await fetch(`${API_BASE}/api/pangramHistory/${word}`);
        const data = await res.json();
        const history = (data.pangramHistory || []).filter(p => p.puzzle_id !== puzzleId);
        if (history.length === 0) {
          el.innerHTML = '<span class="text-gray-400 italic">No other puzzles found with this pangram</span>';
        } else {
          el.innerHTML = '<div class="grid grid-cols-1 sm:grid-cols-2 gap-2">' +
            history.slice(0, 6).map(p =>
              '<a href="/archive" class="block p-3 rounded-lg border border-gray-100 hover:border-amber-200 hover:bg-amber-50/50 transition-all group">' +
                '<div class="flex items-center justify-between mb-1">' +
                  '<span class="font-semibold text-gray-800 group-hover:text-amber-700 text-xs">' + p.date + '</span>' +
                  '<span class="font-mono text-[10px] text-gray-400">' + p.all_letters + '</span>' +
                '</div>' +
                '<div class="flex items-center gap-2 text-[10px]">' +
                  '<span class="text-gray-500">' + p.word_count + ' words</span>' +
                  '<span class="text-amber-600 font-semibold">' + p.pangrams_count + ' pangram' + (p.pangrams_count !== 1 ? 's' : '') + '</span>' +
                '</div>' +
              '</a>'
            ).join('') +
          '</div>';
        }
      } catch (e) {
        el.innerHTML = '<span class="text-red-400">Failed to load history</span>';
      }
    });
  });
</script>
