              </div>

              <!-- Histogram Charts -->
              {scoreHistogram.length > 0 && (
                <div class="mt-6 pt-6 border-t border-gray-100">
                  <h3 class="text-sm font-bold text-gray-800 mb-3">Score Distribution</h3>
