---
import { readFileSync } from 'node:fs';
import BaseLayout from '../layouts/BaseLayout.astro';
import Honeycomb from '../components/Honeycomb.astro';
import { API_BASE, formatDateURL } from '../lib/utils';

const safeFetchJSON = async (url, fallback) => {
  try {
    const response = await fetch(url);
    if (!response.ok) {
      return fallback;
    }
    return await response.json();
  } catch (error) {
    console.error(`Failed to fetch ${url}:`, error);
    return fallback;
  }
};

const safeNum = (value, fallback = 0) => (
  value != null && !Number.isNaN(Number(value)) ? Number(value) : fallback
);

const safeLocale = (value) => (
  typeof value === 'number' ? value.toLocaleString() : (value ?? '--')
);

const roundTo = (value, decimals = 1) => {
  const factor = 10 ** decimals;
  return Math.round(value * factor) / factor;
};

const formatOrdinal = (value) => {
  const number = safeNum(value, 0);
  const mod100 = number % 100;
  if (mod100 >= 11 && mod100 <= 13) return `${number}th`;
  switch (number % 10) {
    case 1:
      return `${number}st`;
    case 2:
      return `${number}nd`;
    case 3:
      return `${number}rd`;
    default:
      return `${number}th`;
  }
};

const getWordPoints = (word) => {
  if (!word) return 0;
  if (word.length === 4) return 1;
  return word.length + (word.is_pangram ? 7 : 0);
};

const histogramPeak = (bins) => Math.max(...(bins || []).map((bin) => safeNum(bin.percentage)), 1);

const formatHistogramRange = (bin, decimals = 0) => {
  if (!bin) return '--';
  const start = decimals === 0 ? Math.round(bin.start) : roundTo(bin.start, decimals).toFixed(decimals);
  const end = decimals === 0 ? Math.round(bin.end) : roundTo(bin.end, decimals).toFixed(decimals);
  return start === end ? `${start}` : `${start}-${end}`;
};

const archiveHref = (date) => `/archive?date=${formatDateURL(date)}`;

const dictionaryPath = new URL('../../public/twl06.txt', import.meta.url);
const dictionaryWords = (() => {
  try {
    return [...new Set(
      readFileSync(dictionaryPath, 'utf8')
        .split(/\r?\n/)
        .map((word) => word.trim().toLowerCase())
        .filter(Boolean),
    )];
  } catch (error) {
    console.error('Failed to load TWL dictionary:', error);
    return [];
  }
})();

const todayData = await safeFetchJSON(`${API_BASE}/today`, { puzzle: {}, words: [] });
const puzzle = todayData.puzzle || {};
const words = todayData.words || [];
const totalPoints = safeNum(todayData.totalPoints);
const center = puzzle.letters || '';
const allLetters = puzzle.all_letters || '';
const outerLetters = allLetters.split('').filter((letter) => letter !== center);
const pangrams = words.filter((word) => word.is_pangram === 1);
const regularWords = words.filter((word) => word.is_pangram !== 1);
const perfectPangrams = todayData.perfectPangrams || [];
const hasPerfectPangram = todayData.hasPerfectPangram || false;
const geniusThreshold = Math.round(totalPoints * 0.7);

const analysisData = puzzle.puzzle_id
  ? await safeFetchJSON(`${API_BASE}/api/puzzleAnalysis/${puzzle.puzzle_id}`, { analysis: null })
  : { analysis: null };
const analysis = analysisData.analysis || {
  score: {
    value: totalPoints,
    percentile: 0,
    highestScore: totalPoints,
    highestScoreDate: null,
    lowestScore: totalPoints,
    lowestScoreDate: null,
    lastTimeAtOrAboveDate: null,
    histogram: [],
  },
  wordCount: {
    value: safeNum(puzzle.word_count),
    percentile: 0,
    highestWordCount: safeNum(puzzle.word_count),
    highestWordCountDate: null,
    lowestWordCount: safeNum(puzzle.word_count),
    lowestWordCountDate: null,
    lastTimeAboveDate: null,
    histogram: [],
  },
  genius: {
    threshold: geniusThreshold,
    minWords: 0,
    maxWords: 0,
    requiredLength: 0,
    lastTimeSameLengthDate: null,
    neededWithoutPangramsPct: 0,
    neededAfterPangramsPct: 0,
    histogram: [],
  },
  averageWordLength: {
    value: words.length > 0 ? roundTo(words.reduce((sum, word) => sum + word.length, 0) / words.length, 1) : 0,
    globalAverage: 0,
    histogram: [],
  },
  commonWords: [],
  allAnswerLengthDistribution: [],
  uniqueAnswerLengthDistribution: [],
  sameCenterPuzzles: [],
  pangramHistoryByWord: {},
};

const statsData = await safeFetchJSON(`${API_BASE}/api/statistics`, {
  overview: {},
  averages: {},
  extremes: {},
});
const centerFrequencyData = await safeFetchJSON(`${API_BASE}/api/mostCommonCenterLetters`, {
  centerLetterFrequency: [],
});
const letterFrequencyData = await safeFetchJSON(`${API_BASE}/api/allLettersFrequency`, {
  allLettersFrequency: [],
});
const recentData = await safeFetchJSON(`${API_BASE}/api/last/8`, { puzzles: [] });

const stats = statsData || {};
const overview = stats.overview || {};
const averages = stats.averages || {};
const centerFreq = centerFrequencyData.centerLetterFrequency || [];
const letterFreq = letterFrequencyData.allLettersFrequency || [];
const recentPuzzles = (recentData.puzzles || [])
  .filter((item) => item.puzzle_id !== puzzle.puzzle_id)
  .slice(0, 6);

const totalPuzzles = safeNum(overview.totalPuzzles);
const totalWordsAcrossAllPuzzles = safeNum(overview.totalWords);

const wordsByLengthAll = {};
for (const word of words) {
  if (!wordsByLengthAll[word.length]) wordsByLengthAll[word.length] = [];
  wordsByLengthAll[word.length].push(word);
}
const sortedLengths = Object.keys(wordsByLengthAll).map(Number).sort((a, b) => a - b);

const wordsByLengthRegular = {};
for (const word of regularWords) {
  if (!wordsByLengthRegular[word.length]) wordsByLengthRegular[word.length] = [];
  wordsByLengthRegular[word.length].push(word);
}
const sortedRegularLengths = Object.keys(wordsByLengthRegular).map(Number).sort((a, b) => a - b);

const pointsByLength = {};
for (const word of words) {
  pointsByLength[word.length] = (pointsByLength[word.length] || 0) + getWordPoints(word);
}

const wordsByFirstLetter = {};
for (const word of words) {
  const firstLetter = word.word[0]?.toUpperCase();
  if (!firstLetter) continue;
  if (!wordsByFirstLetter[firstLetter]) {
    wordsByFirstLetter[firstLetter] = { count: 0, hasPangram: false };
  }
  wordsByFirstLetter[firstLetter].count += 1;
  if (word.is_pangram === 1) {
    wordsByFirstLetter[firstLetter].hasPangram = true;
  }
}

const sortedFirstLetters = Object.keys(wordsByFirstLetter).sort();
const maxFirstLetterCount = Math.max(...sortedFirstLetters.map((letter) => wordsByFirstLetter[letter].count), 1);
const maxWordsByLength = Math.max(...sortedLengths.map((length) => wordsByLengthAll[length].length), 1);
const maxPointsByLength = Math.max(...sortedLengths.map((length) => pointsByLength[length] || 0), 1);
const averageWordLengthValue = words.length > 0
  ? roundTo(words.reduce((sum, word) => sum + word.length, 0) / words.length, 1)
  : 0;

const scoreHistogram = analysis.score?.histogram || [];
const wordCountHistogram = analysis.wordCount?.histogram || [];
const geniusHistogram = analysis.genius?.histogram || [];
const averageLengthHistogram = analysis.averageWordLength?.histogram || [];
const scoreHistogramPeak = histogramPeak(scoreHistogram);
const wordCountHistogramPeak = histogramPeak(wordCountHistogram);
const geniusHistogramPeak = histogramPeak(geniusHistogram);
const averageLengthHistogramPeak = histogramPeak(averageLengthHistogram);

const commonWords = (analysis.commonWords || []).slice(0, 50);
const maxCommonWordCount = Math.max(...commonWords.map((item) => item.count), 1);

const allAnswerLengthDistribution = analysis.allAnswerLengthDistribution || [];
const uniqueAnswerLengthDistribution = analysis.uniqueAnswerLengthDistribution || [];
const maxAllAnswerLengthCount = Math.max(...allAnswerLengthDistribution.map((item) => item.count), 1);
const maxUniqueAnswerLengthCount = Math.max(...uniqueAnswerLengthDistribution.map((item) => item.count), 1);
const totalHistoricalAnswers = allAnswerLengthDistribution.reduce((sum, item) => sum + safeNum(item.count), 0);
const totalUniqueHistoricalWords = uniqueAnswerLengthDistribution.reduce((sum, item) => sum + safeNum(item.count), 0);

const centerFreqMap = Object.fromEntries(centerFreq.map((item) => [item.letter, item]));
const letterFreqMap = Object.fromEntries(letterFreq.map((item) => [item.letter, item]));
const allLettersAZ = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('');
const maxCenterCount = Math.max(...allLettersAZ.map((letter) => safeNum(centerFreqMap[letter]?.count || letterFreqMap[letter]?.asCenter)), 1);
const maxValidLetterCount = Math.max(...allLettersAZ.map((letter) => safeNum(letterFreqMap[letter]?.totalAppearances)), 1);

const sameCenterPuzzles = analysis.sameCenterPuzzles || [];
const pangramHistoryByWord = analysis.pangramHistoryByWord || {};

const officialWordSet = new Set(words.map((word) => word.word.toLowerCase()));
const validLetters = new Set(allLetters.toLowerCase().split(''));
const centerLower = center.toLowerCase();
const nonOfficialWords = dictionaryWords
  .filter((word) => {
    if (word.length < 4) return false;
    if (!word.includes(centerLower)) return false;
    if (officialWordSet.has(word)) return false;
    return [...word].every((letter) => validLetters.has(letter));
  })
  .sort((a, b) => a.localeCompare(b));

const wordCountPercentileText = formatOrdinal(safeNum(analysis.wordCount?.percentile));
const scorePercentileText = formatOrdinal(safeNum(analysis.score?.percentile));
const requiredLength = safeNum(analysis.genius?.requiredLength);
const geniusMinWords = safeNum(analysis.genius?.minWords);
const geniusMaxWords = safeNum(analysis.genius?.maxWords);
const averageWordLengthGlobal = safeNum(analysis.averageWordLength?.globalAverage, safeNum(averages.averageWordLength));
const currentCenterUsage = safeNum(centerFreqMap[center]?.count || letterFreqMap[center]?.asCenter);

const faqCompareText = safeNum(analysis.wordCount?.percentile) >= 60
  ? 'This is a larger-than-average puzzle with more total scoring chances.'
  : safeNum(analysis.wordCount?.percentile) < 40
    ? 'This is a tighter puzzle, so each answer carries more weight.'
    : 'This one sits close to the middle of the historical pack.';

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `What are the NYT Spelling Bee answers for ${puzzle.date}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `The NYT Spelling Bee for ${puzzle.date} has ${puzzle.word_count} answers, ${puzzle.pangrams_count} pangrams, and a maximum score of ${totalPoints}. The center letter is ${center} and the full set of letters is ${allLetters.split('').join(', ')}.`
      }
    },
    {
      "@type": "Question",
      "name": `What score do you need for Genius in today's Spelling Bee?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `You need ${geniusThreshold} points to reach Genius in today's puzzle. Historically, this puzzle requires between ${geniusMinWords} and ${geniusMaxWords} answers, and you need at least a ${requiredLength}-letter word to get there.`
      }
    },
    {
      "@type": "Question",
      "name": `How does today's puzzle compare to other Spelling Bee puzzles?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Today's puzzle ranks in the ${wordCountPercentileText} percentile for answer count and the ${scorePercentileText} percentile for maximum score. ${faqCompareText}`
      }
    }
  ]
});
---

<BaseLayout title="Spelling Bee Answers and Clue with Meaning" description={`NYT Spelling Bee answers for ${puzzle.date}. Find all ${puzzle.word_count} words, ${puzzle.pangrams_count} pangrams, and full puzzle analysis.`} schema={faqSchema}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
    <div class="flex flex-col lg:flex-row gap-8">
      <div class="flex-1 min-w-0">
        <div class="mb-8">
          <div class="flex items-center gap-3 mb-2">
            <span class="badge badge-gold">Today</span>
            <span class="badge badge-slate">Full Analysis</span>
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">Spelling Bee Answers and Clue with Meaning</h1>
          </div>
          <p class="text-gray-500 font-medium">{puzzle.date}</p>
        </div>

        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-8 mb-8">
          <div class="flex-shrink-0">
            <Honeycomb center={center} outer={outerLetters} size="md" />
          </div>
          <div class="flex-1 w-full">
            <div class="grid grid-cols-2 gap-3 mb-5">
              <div class="stat-card">
                <p class="stat-value">{puzzle.word_count}</p>
                <p class="stat-label">Answers</p>
              </div>
              <div class="stat-card">
                <p class="stat-value">{puzzle.pangrams_count}</p>
                <p class="stat-label">Pangrams</p>
              </div>
              <div class="stat-card">
                <p class="stat-value">{totalPoints}</p>
                <p class="stat-label">Max Score</p>
              </div>
              <div class="stat-card">
                <p class="stat-value">{hasPerfectPangram ? 'Yes' : '--'}</p>
                <p class="stat-label">Perfect Pangram</p>
              </div>
            </div>
            <div class="text-sm text-gray-500 mb-2">
              <span class="font-semibold text-purple-600">Genius threshold:</span> {geniusThreshold} points
            </div>
            <div class="text-sm text-gray-500">
              <span class="font-semibold text-gray-700">Center:</span>
              <span class="letter-circle letter-circle-center !w-7 !h-7 !text-xs inline-flex">{center}</span>
              <span class="mx-2 text-gray-300">|</span>
              <span class="font-semibold text-gray-700">Letters:</span>
              {allLetters.split('').map((letter) => (
                <span class:list={[
                  'inline-flex items-center justify-center w-6 h-6 rounded text-xs font-bold mx-0.5',
                  letter === center ? 'bg-amber-100 text-amber-700' : 'bg-gray-100 text-gray-600',
                ]}>{letter}</span>
              ))}
            </div>
          </div>
        </div>

        <details class="card-elevated p-6 mb-8 group">
          <summary class="font-semibold text-gray-800 cursor-pointer flex items-center justify-between">
            Show Official Answers
            <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="mt-5">
            {hasPerfectPangram && perfectPangrams.length > 0 && (
              <div class="mb-6 p-4 bg-emerald-50 border border-emerald-200 rounded-xl">
                <h2 class="text-sm font-bold text-emerald-800 mb-2">Perfect Pangram{perfectPangrams.length > 1 ? 's' : ''}</h2>
                <div class="flex flex-wrap gap-2">
                  {perfectPangrams.map((word) => (
                    <span class="inline-flex items-center px-3 py-1.5 bg-emerald-100 border border-emerald-300 rounded-lg text-sm font-bold text-emerald-800 uppercase">
                      {word}
                    </span>
                  ))}
                </div>
              </div>
            )}

            {pangrams.length > 0 && (
              <div class="mb-6">
                <h2 class="text-lg font-bold text-gray-800 mb-3">Pangrams ({pangrams.length})</h2>
                <div class="flex flex-wrap gap-2">
                  {pangrams.map((word) => (
                    <span class="pangram-chip">
                      <span class="star">&#9733;</span>
                      {word.word}
                      <span class="text-xs text-amber-500 opacity-70">{word.length}</span>
                    </span>
                  ))}
                </div>
              </div>
            )}

            <div class="card-elevated divide-y divide-gray-50 max-h-[600px] overflow-y-auto custom-scroll">
              {sortedRegularLengths.map((length) => (
                <div class="px-5 py-4">
                  <p class="text-xs font-bold text-gray-400 mb-3 uppercase tracking-wider">{length}-Letter Words ({wordsByLengthRegular[length].length})</p>
                  <div class="flex flex-wrap gap-2">
                    {wordsByLengthRegular[length].map((word) => (
                      <span class="word-chip">{word.word}</span>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        </details>

        <div class="card-elevated p-6 mb-8">
          <h2 class="text-lg font-bold text-gray-800 mb-4">Puzzle Statistics</h2>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-5">
            <div class="p-4 bg-gray-50 rounded-xl border border-gray-200">
              <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Number of Pangrams</p>
              <p class="text-2xl font-black text-gray-800 mt-1">{puzzle.pangrams_count}</p>
            </div>
            <div class="p-4 bg-gray-50 rounded-xl border border-gray-200">
              <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Maximum Puzzle Score</p>
              <p class="text-2xl font-black text-gray-800 mt-1">{totalPoints}</p>
            </div>
            <div class="p-4 bg-gray-50 rounded-xl border border-gray-200">
              <p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Number of Answers</p>
              <p class="text-2xl font-black text-gray-800 mt-1">{puzzle.word_count}</p>
            </div>
            <div class="p-4 bg-purple-50 rounded-xl border border-purple-100">
              <p class="text-xs font-semibold text-purple-500 uppercase tracking-wide">Points Needed for Genius</p>
              <p class="text-2xl font-black text-purple-700 mt-1">{geniusThreshold}</p>
            </div>
          </div>
          <p class="text-sm text-gray-600 leading-relaxed">
            Genius requires between <strong>{geniusMinWords}</strong> and <strong>{geniusMaxWords}</strong> words.
            You need at least a <strong>{requiredLength}-letter word</strong> to reach genius.
            If you do not get the pangrams, you need <strong>{analysis.genius?.neededWithoutPangramsPct}%</strong> of the total points to reach genius.
            If you do get the pangrams, you only need <strong>{analysis.genius?.neededAfterPangramsPct}%</strong> of the remaining points.
          </p>
        </div>

        <div class="card-elevated p-6 mb-8">
          <h2 class="text-lg font-bold text-gray-800 mb-4">Length of Words in This Puzzle</h2>
          <div class="space-y-2.5">
            {sortedLengths.map((length) => {
              const count = wordsByLengthAll[length].length;
              const percentage = words.length > 0 ? roundTo((count / words.length) * 100, 1) : 0;
              const barWidth = Math.max((count / maxWordsByLength) * 100, 3);
              const hasPangramAtLength = wordsByLengthAll[length].some((word) => word.is_pangram === 1);
              return (
                <div class="flex items-center gap-3">
                  <span class="w-16 text-sm font-bold text-gray-600 text-right flex-shrink-0">{length}-letter</span>
                  <div class="flex-1">
                    <div class="w-full bg-gray-100 rounded-full h-7 overflow-hidden">
                      <div class:list={[
                        'h-7 rounded-full flex items-center pl-3 text-xs font-bold',
                        hasPangramAtLength ? 'bg-gradient-to-r from-amber-300 to-amber-500 text-white' : 'bg-gray-300 text-gray-700',
                      ]} style={`width: ${barWidth}%`}>
                        {count}
                      </div>
                    </div>
                  </div>
                  <span class="text-xs text-gray-400 font-medium w-12 text-right flex-shrink-0">{percentage}%</span>
                </div>
              );
            })}
          </div>
        </div>

        <div class="card-elevated p-6 mb-8">
          <h2 class="text-lg font-bold text-gray-800 mb-4">Points Available by Length</h2>
          <div class="space-y-2.5">
            {sortedLengths.map((length) => {
              const points = pointsByLength[length] || 0;
              const percentage = totalPoints > 0 ? roundTo((points / totalPoints) * 100, 1) : 0;
              const barWidth = Math.max((points / maxPointsByLength) * 100, 3);
              const hasPangramAtLength = wordsByLengthAll[length].some((word) => word.is_pangram === 1);
              return (
                <div class="flex items-center gap-3">
                  <span class="w-16 text-sm font-bold text-gray-600 text-right flex-shrink-0">{length}-letter</span>
                  <div class="flex-1">
                    <div class="w-full bg-gray-100 rounded-full h-7 overflow-hidden">
                      <div class:list={[
                        'h-7 rounded-full flex items-center pl-3 text-xs font-bold',
                        hasPangramAtLength ? 'bg-gradient-to-r from-emerald-300 to-emerald-500 text-white' : 'bg-emerald-200 text-emerald-800',
                      ]} style={`width: ${barWidth}%`}>
                        {points} pts
                      </div>
                    </div>
                  </div>
                  <span class="text-xs text-gray-400 font-medium w-12 text-right flex-shrink-0">{percentage}%</span>
                </div>
              );
            })}
          </div>
        </div>

        <details class="card-elevated p-6 mb-8 group" open>
          <summary class="font-semibold text-gray-800 cursor-pointer flex items-center justify-between">
            Show Counts by First Letter
            <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mt-5">
            {sortedFirstLetters.map((letter) => {
              const info = wordsByFirstLetter[letter];
              const barWidth = Math.max((info.count / maxFirstLetterCount) * 100, 8);
              return (
                <div class:list={[
                  'p-3 rounded-xl border',
                  info.hasPangram ? 'border-amber-200 bg-amber-50' : 'border-gray-100 bg-white',
                ]}>
                  <div class="flex items-center justify-between mb-2">
                    <span class:list={['text-lg font-black', info.hasPangram ? 'text-amber-600' : 'text-gray-700']}>{letter}</span>
                    <span class="text-sm font-bold text-gray-500">{info.count}</span>
                  </div>
                  <div class="w-full bg-gray-100 rounded-full h-2">
                    <div class:list={['h-2 rounded-full', info.hasPangram ? 'bg-amber-400' : 'bg-gray-300']} style={`width: ${barWidth}%`}></div>
                  </div>
                  {info.hasPangram && <span class="text-[10px] text-amber-600 font-bold mt-1 block">HAS PANGRAM</span>}
                </div>
              );
            })}
          </div>
        </details>

        {pangrams.length > 0 && (
          <div class="card-elevated p-6 mb-8">
            <h2 class="text-lg font-bold text-gray-800 mb-4">Other Days With This Pangram</h2>
            <div class="space-y-5">
              {pangrams.map((word) => {
                const history = pangramHistoryByWord[word.word] || [];
                return (
                  <div>
                    <p class="font-semibold text-amber-700 mb-2">{word.word.toUpperCase()}</p>
                    {history.length > 0 ? (
                      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                        {history.slice(0, 6).map((item) => (
                          <a href={archiveHref(item.date)} class="block p-4 rounded-xl border border-gray-100 hover:border-amber-200 hover:bg-amber-50/50 transition-all group">
                            <div class="flex items-center justify-between mb-2">
                              <span class="font-semibold text-gray-800 group-hover:text-amber-700 text-sm">{item.date}</span>
                              <span class="font-mono text-xs text-gray-400">{item.all_letters}</span>
                            </div>
                            <div class="flex items-center gap-3 text-xs">
                              <span class="text-gray-500">{item.word_count} answers</span>
                              <span class="text-amber-600 font-semibold">{item.pangrams_count} pangram{item.pangrams_count !== 1 ? 's' : ''}</span>
                            </div>
                          </a>
                        ))}
                      </div>
                    ) : (
                      <p class="text-sm text-gray-400 italic">No earlier puzzles found with this pangram.</p>
                    )}
                  </div>
                );
              })}
            </div>
          </div>
        )}

        <div class="card-elevated p-6 mb-8">
          <h2 class="text-lg font-bold text-gray-800 mb-4">How Does This Puzzle Compare?</h2>

          <div class="mb-8">
            <h3 class="text-sm font-bold text-gray-700 mb-3">Score Percentile</h3>
            <p class="text-sm text-gray-600 leading-relaxed mb-2">
              Today's score of <strong>{totalPoints}</strong> was in the <strong>{scorePercentileText}</strong> percentile of all puzzles.
            </p>
            {analysis.score?.lastTimeAtOrAboveDate && (
              <p class="text-sm text-gray-600 leading-relaxed mb-2">
                The last time there was a score this high was on <strong>{analysis.score.lastTimeAtOrAboveDate}</strong>.
              </p>
            )}
            {analysis.score?.highestScoreDate && (
              <p class="text-sm text-gray-600 leading-relaxed mb-2">
                The highest score ever was <strong>{analysis.score.highestScore}</strong> on <strong>{analysis.score.highestScoreDate}</strong>.
              </p>
            )}
            {analysis.score?.lowestScoreDate && (
              <p class="text-sm text-gray-600 leading-relaxed mb-4">
                The lowest score ever was <strong>{analysis.score.lowestScore}</strong> on <strong>{analysis.score.lowestScoreDate}</strong>.
              </p>
            )}
            <div class="space-y-1.5">
              {scoreHistogram.map((bin) => {
                const barWidth = Math.max((safeNum(bin.percentage) / scoreHistogramPeak) * 100, bin.isCurrent ? 3 : 1);
                return (
                  <div class:list={['flex items-center gap-3', bin.isCurrent && 'bg-amber-50 -mx-2 px-2 rounded-lg py-0.5']}>
                    <span class:list={['w-20 text-xs font-bold text-right flex-shrink-0', bin.isCurrent ? 'text-amber-700' : 'text-gray-400']}>
                      {formatHistogramRange(bin)}
                    </span>
                    <div class="flex-1">
                      <div class="w-full bg-gray-100 rounded-full h-5 overflow-hidden">
                        <div class:list={[
                          'h-5 rounded-full flex items-center pl-2 text-[10px] font-bold',
                          bin.isCurrent ? 'bg-gradient-to-r from-amber-400 to-amber-500 text-white' : 'bg-gray-300 text-gray-600',
                        ]} style={`width: ${barWidth}%`}>
                          {bin.isCurrent ? 'Current' : `${roundTo(safeNum(bin.percentage), 1)}%`}
                        </div>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
            <p class="text-xs text-gray-400 mt-2">Max score in all puzzles</p>
          </div>

          <hr class="border-gray-100 my-6" />

          <div class="mb-8">
            <h3 class="text-sm font-bold text-gray-700 mb-3">Word Count Percentile</h3>
            <p class="text-sm text-gray-600 leading-relaxed mb-2">
              This puzzle's <strong>{puzzle.word_count} possible answers</strong> rank it in the <strong>{wordCountPercentileText}</strong> percentile of all puzzles.
            </p>
            {analysis.wordCount?.lastTimeAboveDate && (
              <p class="text-sm text-gray-600 leading-relaxed mb-2">
                The last time there were more answers than this was on <strong>{analysis.wordCount.lastTimeAboveDate}</strong>.
              </p>
            )}
            {analysis.wordCount?.highestWordCountDate && (
              <p class="text-sm text-gray-600 leading-relaxed mb-2">
                The highest number of answers was <strong>{analysis.wordCount.highestWordCount}</strong> on <strong>{analysis.wordCount.highestWordCountDate}</strong>.
              </p>
            )}
            {analysis.wordCount?.lowestWordCountDate && (
              <p class="text-sm text-gray-600 leading-relaxed mb-4">
                The lowest number of answers was <strong>{analysis.wordCount.lowestWordCount}</strong> on <strong>{analysis.wordCount.lowestWordCountDate}</strong>.
              </p>
            )}
            <div class="space-y-1.5">
              {wordCountHistogram.map((bin) => {
                const barWidth = Math.max((safeNum(bin.percentage) / wordCountHistogramPeak) * 100, bin.isCurrent ? 3 : 1);
                return (
                  <div class:list={['flex items-center gap-3', bin.isCurrent && 'bg-violet-50 -mx-2 px-2 rounded-lg py-0.5']}>
                    <span class:list={['w-20 text-xs font-bold text-right flex-shrink-0', bin.isCurrent ? 'text-violet-700' : 'text-gray-400']}>
                      {formatHistogramRange(bin)}
                    </span>
                    <div class="flex-1">
                      <div class="w-full bg-gray-100 rounded-full h-5 overflow-hidden">
                        <div class:list={[
                          'h-5 rounded-full flex items-center pl-2 text-[10px] font-bold',
                          bin.isCurrent ? 'bg-gradient-to-r from-violet-400 to-violet-500 text-white' : 'bg-gray-300 text-gray-600',
                        ]} style={`width: ${barWidth}%`}>
                          {bin.isCurrent ? 'Current' : `${roundTo(safeNum(bin.percentage), 1)}%`}
                        </div>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
            <p class="text-xs text-gray-400 mt-2">Number of answers in all puzzles</p>
          </div>

          <hr class="border-gray-100 my-6" />

          <div class="mb-8">
            <h3 class="text-sm font-bold text-gray-700 mb-3">Length for Genius</h3>
            <p class="text-sm text-gray-600 leading-relaxed mb-2">
              It takes a <strong>{requiredLength}-letter word</strong> for genius.
            </p>
            {analysis.genius?.lastTimeSameLengthDate && (
              <p class="text-sm text-gray-600 leading-relaxed mb-4">
                The last time this happened was on <strong>{analysis.genius.lastTimeSameLengthDate}</strong>.
              </p>
            )}
            <div class="space-y-1.5">
              {geniusHistogram.map((item) => {
                const barWidth = Math.max((safeNum(item.percentage) / geniusHistogramPeak) * 100, item.isCurrent ? 3 : 1);
                return (
                  <div class:list={['flex items-center gap-3', item.isCurrent && 'bg-purple-50 -mx-2 px-2 rounded-lg py-0.5']}>
                    <span class:list={['w-20 text-xs font-bold text-right flex-shrink-0', item.isCurrent ? 'text-purple-700' : 'text-gray-400']}>
                      {item.value}-letter
                    </span>
                    <div class="flex-1">
                      <div class="w-full bg-gray-100 rounded-full h-5 overflow-hidden">
                        <div class:list={[
                          'h-5 rounded-full flex items-center pl-2 text-[10px] font-bold',
                          item.isCurrent ? 'bg-gradient-to-r from-purple-400 to-purple-500 text-white' : 'bg-gray-300 text-gray-600',
                        ]} style={`width: ${barWidth}%`}>
                          {item.isCurrent ? 'Current' : `${roundTo(safeNum(item.percentage), 1)}%`}
                        </div>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
            <p class="text-xs text-gray-400 mt-2">Length for Genius in all puzzles</p>
          </div>

          <hr class="border-gray-100 my-6" />

          <div>
            <h3 class="text-sm font-bold text-gray-700 mb-3">Average Word Length</h3>
            <p class="text-sm text-gray-600 leading-relaxed mb-2">
              Today's puzzle has an average word length of <strong>{averageWordLengthValue.toFixed(1)}</strong>.
            </p>
            <p class="text-sm text-gray-600 leading-relaxed mb-4">
              For all Bees, the average word length has been <strong>{averageWordLengthGlobal.toFixed(1)}</strong>.
            </p>
            <div class="space-y-1.5">
              {averageLengthHistogram.map((bin) => {
                const barWidth = Math.max((safeNum(bin.percentage) / averageLengthHistogramPeak) * 100, bin.isCurrent ? 3 : 1);
                return (
                  <div class:list={['flex items-center gap-3', bin.isCurrent && 'bg-emerald-50 -mx-2 px-2 rounded-lg py-0.5']}>
                    <span class:list={['w-20 text-xs font-bold text-right flex-shrink-0', bin.isCurrent ? 'text-emerald-700' : 'text-gray-400']}>
                      {formatHistogramRange(bin, 1)}
                    </span>
                    <div class="flex-1">
                      <div class="w-full bg-gray-100 rounded-full h-5 overflow-hidden">
                        <div class:list={[
                          'h-5 rounded-full flex items-center pl-2 text-[10px] font-bold',
                          bin.isCurrent ? 'bg-gradient-to-r from-emerald-400 to-emerald-500 text-white' : 'bg-gray-300 text-gray-600',
                        ]} style={`width: ${barWidth}%`}>
                          {bin.isCurrent ? 'Current' : `${roundTo(safeNum(bin.percentage), 1)}%`}
                        </div>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
            <p class="text-xs text-gray-400 mt-2">Average word length in all puzzles</p>
          </div>
        </div>

        <div class="card-elevated p-6 mb-8">
          <h2 class="text-lg font-bold text-gray-800 mb-4">Haven't I Seen These Letters Before?</h2>
          <p class="text-sm text-gray-500 mb-4">Historical letter frequency across all {safeLocale(totalPuzzles)} puzzles. Letters in today's puzzle are highlighted.</p>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div>
              <h3 class="text-sm font-bold text-gray-700 mb-3">As Center Letter</h3>
              <div class="space-y-1.5">
                {allLettersAZ.map((letter) => {
                  const count = safeNum(centerFreqMap[letter]?.count || letterFreqMap[letter]?.asCenter);
                  const isTodayCenter = letter === center;
                  const isTodayLetter = allLetters.includes(letter);
                  const barWidth = Math.max((count / maxCenterCount) * 100, isTodayCenter ? 2 : 0);
                  return (
                    <div class:list={['flex items-center gap-2', isTodayCenter && 'bg-amber-50 -mx-2 px-2 rounded-lg py-0.5']}>
                      <span class:list={[
                        'w-6 h-6 rounded-full flex items-center justify-center text-xs font-black flex-shrink-0',
                        isTodayCenter ? 'bg-amber-400 text-white' : isTodayLetter ? 'bg-gray-200 text-gray-600' : 'bg-gray-50 text-gray-300',
                      ]}>{letter}</span>
                      <div class="flex-1">
                        <div class="w-full bg-gray-100 rounded-full h-4 overflow-hidden">
                          <div class:list={[
                            'h-4 rounded-full',
                            isTodayCenter ? 'bg-amber-400' : 'bg-gray-300',
                          ]} style={`width: ${barWidth}%`}></div>
                        </div>
                      </div>
                      <span class:list={['text-[10px] font-bold w-10 text-right flex-shrink-0', isTodayCenter ? 'text-amber-700' : 'text-gray-400']}>{count}</span>
                    </div>
                  );
                })}
              </div>
            </div>

            <div>
              <h3 class="text-sm font-bold text-gray-700 mb-3">As Valid Letter</h3>
              <div class="space-y-1.5">
                {allLettersAZ.map((letter) => {
                  const count = safeNum(letterFreqMap[letter]?.totalAppearances);
                  const isTodayCenter = letter === center;
                  const isTodayLetter = allLetters.includes(letter);
                  const barWidth = Math.max((count / maxValidLetterCount) * 100, isTodayLetter ? 2 : 0);
                  return (
                    <div class:list={[
                      'flex items-center gap-2',
                      isTodayCenter && 'bg-amber-50 -mx-2 px-2 rounded-lg py-0.5',
                      isTodayLetter && !isTodayCenter && 'bg-gray-50 -mx-2 px-2 rounded-lg py-0.5',
                    ]}>
                      <span class:list={[
                        'w-6 h-6 rounded-full flex items-center justify-center text-xs font-black flex-shrink-0',
                        isTodayCenter ? 'bg-amber-400 text-white' : isTodayLetter ? 'bg-gray-200 text-gray-600' : 'bg-gray-50 text-gray-300',
                      ]}>{letter}</span>
                      <div class="flex-1">
                        <div class="w-full bg-gray-100 rounded-full h-4 overflow-hidden">
                          <div class:list={[
                            'h-4 rounded-full',
                            isTodayCenter ? 'bg-amber-400' : isTodayLetter ? 'bg-gray-400' : 'bg-gray-200',
                          ]} style={`width: ${barWidth}%`}></div>
                        </div>
                      </div>
                      <span class:list={['text-[10px] font-bold w-10 text-right flex-shrink-0', isTodayLetter ? 'text-gray-600' : 'text-gray-300']}>{count}</span>
                    </div>
                  );
                })}
              </div>
            </div>
          </div>

          <p class="text-sm text-gray-500 mt-4">
            Center letter <strong>{center}</strong> has appeared in the center <strong>{currentCenterUsage}</strong> times across the full archive.
          </p>

          {sameCenterPuzzles.length > 0 && (
            <div class="mt-6 border-t border-gray-100 pt-6">
              <h3 class="text-sm font-bold text-gray-700 mb-3">Other Days With Center Letter {center}</h3>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                {sameCenterPuzzles.map((item) => (
                  <a href={archiveHref(item.date)} class="block p-4 rounded-xl border border-gray-100 hover:border-amber-200 hover:bg-amber-50/50 transition-all group">
                    <div class="flex items-center justify-between mb-2">
                      <span class="font-semibold text-gray-800 group-hover:text-amber-700 text-sm">{item.date}</span>
                      <span class="font-mono text-xs text-gray-400">{item.all_letters}</span>
                    </div>
                    <div class="flex items-center gap-3 text-xs">
                      <span class="text-gray-500">{item.word_count} answers</span>
                      <span class="text-amber-600 font-semibold">{item.score} pts</span>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>

        <div class="card-elevated p-6 mb-8">
          <h2 class="text-lg font-bold text-gray-800 mb-4">Haven't I Seen These Words Before?</h2>
          <p class="text-sm text-gray-500 mb-4">The most common words in the Bee are:</p>
          <div class="grid sm:grid-cols-2 gap-2">
            {commonWords.map((item) => (
              <div class="flex items-center gap-3">
                <span class="w-20 text-sm font-semibold text-gray-700 truncate">{item.word}</span>
                <div class="flex-1">
                  <div class="w-full bg-gray-100 rounded-full h-4 overflow-hidden">
                    <div class="h-4 rounded-full bg-sky-400" style={`width: ${Math.max((item.count / maxCommonWordCount) * 100, 3)}%`}></div>
                  </div>
                </div>
                <span class="text-xs font-bold text-gray-500 w-10 text-right">{item.count}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="card-elevated p-6 mb-8">
          <h2 class="text-lg font-bold text-gray-800 mb-4">How Long Are Words in the Bee?</h2>
          <p class="text-sm text-gray-500 mb-6">
            There have been <strong>{safeLocale(totalHistoricalAnswers)}</strong> accepted answers in the Bee, with
            <strong> {safeLocale(totalUniqueHistoricalWords)}</strong> unique words.
          </p>

          <div class="mb-8">
            <h3 class="text-sm font-bold text-gray-700 mb-3">Length of All Answers</h3>
            <div class="space-y-2">
              {allAnswerLengthDistribution.map((item) => (
                <div class="flex items-center gap-3">
                  <span class="w-16 text-sm font-bold text-right text-gray-600 flex-shrink-0">{item.length}-letter</span>
                  <div class="flex-1">
                    <div class="w-full bg-gray-100 rounded-full h-6 overflow-hidden">
                      <div class="h-6 rounded-full bg-amber-300 text-amber-900 text-xs font-bold flex items-center pl-3" style={`width: ${Math.max((item.count / maxAllAnswerLengthCount) * 100, 2)}%`}>
                        {safeLocale(item.count)}
                      </div>
                    </div>
                  </div>
                  <span class="text-xs text-gray-400 font-medium w-12 text-right flex-shrink-0">{item.percentage}%</span>
                </div>
              ))}
            </div>
          </div>

          <div>
            <h3 class="text-sm font-bold text-gray-700 mb-3">Length of Unique Answers</h3>
            <div class="space-y-2">
              {uniqueAnswerLengthDistribution.map((item) => (
                <div class="flex items-center gap-3">
                  <span class="w-16 text-sm font-bold text-right text-gray-600 flex-shrink-0">{item.length}-letter</span>
                  <div class="flex-1">
                    <div class="w-full bg-gray-100 rounded-full h-6 overflow-hidden">
                      <div class="h-6 rounded-full bg-emerald-300 text-emerald-900 text-xs font-bold flex items-center pl-3" style={`width: ${Math.max((item.count / maxUniqueAnswerLengthCount) * 100, 2)}%`}>
                        {safeLocale(item.count)}
                      </div>
                    </div>
                  </div>
                  <span class="text-xs text-gray-400 font-medium w-12 text-right flex-shrink-0">{item.percentage}%</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="card-elevated p-6 mb-8">
          <h2 class="text-lg font-bold text-gray-800 mb-4">Valid Dictionary Words Not in Today's Official Answers</h2>
          <p class="text-sm text-gray-500 mb-4">
            You may be wondering why these words are not here. These are dictionary-valid words that fit today's letters but are not in the official NYT answer list.
          </p>
          {nonOfficialWords.length > 0 ? (
            <>
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-x-6 gap-y-1.5">
                {nonOfficialWords.map((word) => (
                  <span class="text-sm text-gray-700">{word}</span>
                ))}
              </div>
              <p class="text-xs text-gray-400 mt-4">Because the New York Times considers some of them obscure or otherwise out of scope.</p>
            </>
          ) : (
            <p class="text-sm text-gray-400 italic">No additional dictionary words found for these letters.</p>
          )}
        </div>

        <div class="mt-10 p-6 bg-gray-50 rounded-2xl">
          <h2 class="text-lg font-bold text-gray-800 mb-3">Today's Spelling Bee Puzzle Breakdown</h2>
          <p class="text-gray-600 leading-relaxed text-sm mb-3">
            The New York Times Spelling Bee for <strong>{puzzle.date}</strong> uses <strong>{center}</strong> as the mandatory center letter with outer letters <strong>{outerLetters.join(', ')}</strong>.
            Today's puzzle contains <strong>{puzzle.word_count} answers</strong>, <strong>{puzzle.pangrams_count} pangram{puzzle.pangrams_count !== 1 ? 's' : ''}</strong>, and a maximum score of <strong>{totalPoints}</strong>.
          </p>
          <p class="text-gray-600 leading-relaxed text-sm mb-3">
            Historically, this puzzle ranks in the <strong>{wordCountPercentileText}</strong> percentile for answer count and the <strong>{scorePercentileText}</strong> percentile for score.
            The average answer length today is <strong>{averageWordLengthValue.toFixed(1)}</strong>, compared with a long-run average of <strong>{averageWordLengthGlobal.toFixed(1)}</strong>.
          </p>
          <p class="text-gray-600 leading-relaxed text-sm">
            SpellingBee Solver now computes these comparison sections from the full archive instead of rough front-end approximations, so the percentile text, "last time" references, and history charts stay aligned with the historical data.
          </p>
        </div>

        <div class="mt-8">
          <h2 class="text-lg font-bold text-gray-800 mb-4">Frequently Asked Questions</h2>
          <div class="space-y-3">
            <details class="card-elevated p-5 group" open>
              <summary class="font-semibold text-gray-800 cursor-pointer flex items-center justify-between">
                What are the NYT Spelling Bee answers for {puzzle.date}?
                <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="text-sm text-gray-600 mt-3 leading-relaxed">
                The puzzle for {puzzle.date} has {puzzle.word_count} answers, {puzzle.pangrams_count} pangram{puzzle.pangrams_count !== 1 ? 's' : ''}, and a maximum score of {totalPoints}. The center letter is {center}, and the full set of letters is {allLetters.split('').join(', ')}.
              </p>
            </details>

            <details class="card-elevated p-5 group">
              <summary class="font-semibold text-gray-800 cursor-pointer flex items-center justify-between">
                What score do I need for Genius today?
                <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="text-sm text-gray-600 mt-3 leading-relaxed">
                You need {geniusThreshold} points to reach Genius. Historically, this puzzle requires between {geniusMinWords} and {geniusMaxWords} answers, and you need at least one {requiredLength}-letter word to get there.
              </p>
            </details>

            <details class="card-elevated p-5 group">
              <summary class="font-semibold text-gray-800 cursor-pointer flex items-center justify-between">
                How does today's puzzle compare to others?
                <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="text-sm text-gray-600 mt-3 leading-relaxed">
                Today's puzzle ranks in the {wordCountPercentileText} percentile for answer count and the {scorePercentileText} percentile for max score. It has {puzzle.pangrams_count} pangram{puzzle.pangrams_count !== 1 ? 's' : ''}, and {faqCompareText}
              </p>
            </details>
          </div>
        </div>
      </div>

      <aside class="w-full lg:w-72 flex-shrink-0 space-y-4">
        <div class="card-elevated p-5">
          <h3 class="font-bold text-gray-800 mb-4 text-sm">Recent Puzzles</h3>
          <div class="space-y-1">
            {recentPuzzles.map((item) => (
              <a href={archiveHref(item.date)} class="block p-2.5 rounded-lg hover:bg-amber-50 transition-colors group">
                <p class="text-sm font-medium text-gray-700 group-hover:text-amber-700">{item.date}</p>
                <p class="text-xs text-gray-400">Center: {item.letters} - {item.word_count} answers</p>
              </a>
            ))}
          </div>
        </div>

        <div class="card-elevated p-5 space-y-2">
          <a href="/solver" class="btn-primary w-full text-sm !py-3">
            <svg width="16" height="18" viewBox="0 0 100 110"><polygon points="50,3 95,27.5 95,72.5 50,97 5,72.5 5,27.5" fill="white" stroke="white" stroke-width="3"/></svg>
            Use Solver
          </a>
          <a href="/yesterday" class="btn-secondary w-full text-sm !py-3">Yesterday's Answers</a>
          <a href="/archive" class="btn-secondary w-full text-sm !py-3">Puzzle Archive</a>
        </div>

        <div class="card-elevated p-5">
          <h3 class="font-bold text-gray-800 mb-3 text-sm">Quick Stats</h3>
          <div class="space-y-2.5">
            <div class="flex items-center justify-between">
              <span class="text-xs text-gray-500">Total puzzles</span>
              <span class="text-xs font-bold text-gray-700">{safeLocale(totalPuzzles)}</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-xs text-gray-500">Total words</span>
              <span class="text-xs font-bold text-gray-700">{safeLocale(totalWordsAcrossAllPuzzles)}</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-xs text-gray-500">Avg answers/puzzle</span>
              <span class="text-xs font-bold text-gray-700">{safeNum(averages.wordsPerPuzzle).toFixed(1)}</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-xs text-gray-500">Most common center</span>
              <span class="text-xs font-bold text-gray-700">{centerFreq.length > 0 ? centerFreq[0].letter : '--'}</span>
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
