                              <div class="h-5 rounded-full flex items-center pl-2 text-xs font-bold text-white" style={`width: ${barWidth}%; background-color: ${h.isToday ? '#B22222' : '#1f77b4'}`}>
                                {h.count}
                              </div>
                            </div>
                          </div>
                        </div>
