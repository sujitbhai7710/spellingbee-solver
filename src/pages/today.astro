                              {h.count}
                            </div>
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
              )}

              {wordCountHistogram.length > 0 && (
                <div class="mt-6 pt-6 border-t border-gray-100">
                  <h3 class="text-sm font-bold text-gray-800 mb-3">Word Count Distribution</h3>
                  <p class="text-xs text-gray-400 mb-3">How this puzzle's word count compare to all puzzles. Today's bin is highlighted in red.</p>
                  <div class="space-y-1.5">
                    {renderHistogram(wordCountHistogram).map(h => (
                      <div class="flex items-center gap-2">
                        <span class="w-16 text-xs font-bold text-gray-500 text-right">{h.bin}</span>
                        <div class="flex-1">
                          <div class="w-full bg-gray-100 rounded-full h-5 overflow-hidden">
                            <div class:list={['h-5 rounded-full flex items-center pl-2 text-xs font-bold', h.isToday ? 'text-white' : 'text-white']} style={`width: ${h.barWidth}%; background-color: ${h.isToday ? '#B22222' : '#1f77b4'}`}>
                              {h.count}
                            </div>
                          </div>
                        </div>
                      </div>
                    ))}
                  </div>
                </div>
