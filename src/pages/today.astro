            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
            How Does This Puzzle Compare?
          </h2>
          <p class="text-sm text-gray-500 mb-5">Statistical analysis comparing today's puzzle to all {safeLocale(totalPuzzles)} puzzles in our database.</p>

          <div class="space-y-5">
            <!-- Word Count Percentile -->
            <div>
              <div class="flex items-center justify-between mb-2">
                <span class="text-sm font-semibold text-gray-700">Word Count</span>
                <span class="text-sm">
                  <span class="font-bold text-gray-800">{puzzle.word_count}</span>
                  <span class="text-gray-400 mx-1">vs</span>
                  <span class="text-gray-500">avg {safeNum(averages.wordsPerPuzzle).toFixed(1)}</span>
                </span>
              </div>
              <div class="w-full bg-gray-100 rounded-full h-3 overflow-hidden relative">
                <div class="bg-gradient-to-r from-violet-300 to-violet-500 h-3 rounded-full transition-all" style={`width: ${Math.min(wordCountPct, 100)}%`}></div>
              </div>
              <div class="flex justify-between mt-1">
                <span class="text-xs text-gray-400">Fewest ({minWords})</span>
                <span class:list={['text-xs font-semibold', wordPercentile >= 70 ? 'text-emerald-600' : wordPercentile >= 30 ? 'text-amber-600' : 'text-red-500']}>
                  ~{wordPercentile}th percentile
                </span>
                <span class="text-xs text-gray-400">Most ({maxWords})</span>
              </div>
            </div>

            <!-- Pangram Count -->
            <div>
              <div class="flex items-center justify-between mb-2">
                <span class="text-sm font-semibold text-gray-700">Pangram Count</span>
                <span class="text-sm">
                  <span class="font-bold text-gray-800">{puzzle.pangrams_count}</span>
                  <span class="text-gray-400 mx-1">vs</span>
                  <span class="text-gray-500">avg {safeNum(averages.pangramsPerPuzzle).toFixed(1)}</span>
                </span>
              </div>
              <div class="w-full bg-gray-100 rounded-full h-3 overflow-hidden">
                <div class="bg-gradient-to-r from-amber-300 to-amber-500 h-3 rounded-full transition-all" style={`width: ${Math.min(pangramPct, 100)}%`}></div>
              </div>
              <p class="text-xs text-gray-400 mt-1">
                {puzzle.pangrams_count > safeNum(averages.pangramsPerPuzzle)
                  ? 'More pangrams than average — a richer scoring opportunity.'
                  : puzzle.pangrams_count < safeNum(averages.pangramsPerPuzzle)
                    ? 'Fewer pangrams than average — each one is more valuable.'
                    : 'About average for pangram count.'
                }
              </p>
            </div>

            <!-- Points Per Word -->
            <div>
              <div class="flex items-center justify-between mb-2">
                <span class="text-sm font-semibold text-gray-700">Points Per Word</span>
