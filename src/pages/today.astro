                      const info = letterHistory[letter];
                      const maxCenter = Math.max(...allLetters.split('').map(l => letterHistory[l]?.centerCount || 0), 1);
                      const barWidth = Math.max(((info?.centerCount || 0) / maxCenter) * 100, 3);
                      const isCenter = letter === center;
                      return (
                        <div class="flex items-center gap-2">
                          <span class:list={['w-6 text-xs font-black text-right', isCenter ? 'text-amber-600' : 'text-gray-500']}>{letter}</span>
