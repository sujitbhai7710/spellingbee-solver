                            <div class="w-full bg-gray-100 rounded-full h-5 overflow-hidden">
                              <div class:list={['h-5 rounded-full flex items-center pl-2 text-xs font-bold', isCenter ? 'bg-gradient-to-r from-amber-400 to-amber-500 text-white' : 'bg-gradient-to-r from-gray-300 to-gray-400 text-white']} style={`width: ${barWidth}%`}>
                                {info?.centerCount || 0}
                              </div>
                            </div>
                          </div>
                        </div>
                      );
                    })}
                  </div>
                </div>

                <!-- Total Appearances -->
                <div>
                  <h4 class="text-xs font-bold text-gray-500 mb-2 uppercase tracking-wider">Total Appearances</h4>
