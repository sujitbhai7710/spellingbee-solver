                    {allLetters.split('').map(letter => {
                      const info = letterHistory[letter];
                      const maxTotal = Math.max(...allLetters.split('').map(l => letterHistory[l]?.totalCount || 0), 1);
                      const barWidth = Math.max(((info?.totalCount || 0) / maxTotal) * 100, 3);
                      const isCenter = letter === center;
                      return (
                        <div class="flex items-center gap-2">
                          <span class:list={['w-6 text-xs font-black text-right', isCenter ? 'text-amber-600' : 'text-gray-500']}>{letter}</span>
                          <div class="flex-1">
                            <div class="w-full bg-gray-100 rounded-full h-5 overflow-hidden">
                              <div class:list={['h-5 rounded-full flex items-center pl-2 text-xs font-bold', isCenter ? 'bg-gradient-to-r from-amber-400 to-amber-500 text-white' : 'bg-gradient-to-r from-blue-300 to-blue-400 text-white']} style={`width: ${barWidth}%`}>
                                {info?.totalCount || 0}
                              </div>
                            </div>
                          </div>
                        </div>
                      );
                    })}
                  </div>
                </div>
              </div>
            </div>
