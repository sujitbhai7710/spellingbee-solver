---
import BaseLayout from '../layouts/BaseLayout.astro';
import Honeycomb from '../components/Honeycomb.astro';
import { API_BASE, getProgressLevel } from '../lib/utils';

const res = await fetch(`${API_BASE}/today`);
const data = await res.json();
const puzzle = data.puzzle || {};
const words = data.words || [];

const center = puzzle.letters || '';
const allLetters = puzzle.all_letters || '';
const outerLetters = allLetters.split('').filter(l => l !== center);
const pangrams = words.filter(w => w.is_pangram === 1);
const regularWords = words.filter(w => w.is_pangram !== 1);
const totalPoints = data.totalPoints || 0;
const hasPerfectPangram = data.hasPerfectPangram || false;
const perfectPangrams = data.perfectPangrams || [];
const geniusThreshold = Math.ceil(totalPoints * 0.70);

// Calculate Genius Requirement Analysis (nytbee.com feature)
const pangramPoints = pangrams.reduce((sum, w) => {
  const pts = w.length === 4 ? 1 : w.length;
  return sum + pts + 7; // base + bonus
}, 0);
const nonPangramPoints = totalPoints - pangramPoints;
const pointsNeededWithoutPangrams = Math.max(0, geniusThreshold);
const pctWithoutPangrams = totalPoints > 0 ? Math.round((pointsNeededWithoutPangrams / totalPoints) * 100) : 0;
const remainingAfterPangrams = totalPoints - pangramPoints;
const pointsStillNeededWithPangrams = Math.max(0, geniusThreshold - pangramPoints);
const pctWithPangrams = remainingAfterPangrams > 0 ? Math.round((pointsStillNeededWithPangrams / remainingAfterPangrams) * 100) : 0;

// Min words for genius (all 4-letter = 1pt each)
const minWordsForGenius = Math.ceil(geniusThreshold / 1);
// Max words for genius (all longest words, roughly)
const avgWordPoints = words.length > 0 ? totalPoints / words.length : 1;
const maxWordsForGenius = Math.ceil(geniusThreshold / Math.max(avgWordPoints, 1));

// Minimum word length needed for genius
let minLenForGenius = 4;
if (words.length > 0) {
  // Sort words by points (ascending)
  const sortedByPoints = [...words].sort((a, b) => {
    const ptsA = a.length === 4 ? 1 : a.length;
    const ptsB = b.length === 4 ? 1 : b.length;
    return ptsA - ptsB;
  });
  let cumulativePts = 0;
  for (const w of sortedByPoints) {
    const pts = w.length === 4 ? 1 : w.length + (w.is_pangram ? 7 : 0);
    cumulativePts += pts;
    if (cumulativePts >= geniusThreshold) {
      minLenForGenius = w.length;
      break;
    }
  }
}

// Group words by length
const wordsByLength = {};
for (const w of regularWords) {
  const l = w.length;
  if (!wordsByLength[l]) wordsByLength[l] = [];
  wordsByLength[l].push(w);
}
const sortedLengths = Object.keys(wordsByLength).sort((a,b) => +b - +a);

// Word length distribution chart data
const wordsByLenAll = {};
for (const w of words) {
  const l = w.length;
  if (!wordsByLenAll[l]) wordsByLenAll[l] = [];
  wordsByLenAll[l].push(w);
}
const sortedLenAll = Object.keys(wordsByLenAll).sort((a,b) => +a - +b);
const maxLenCount = Math.max(...Object.values(wordsByLenAll).map(v => v.length), 1);

// Points by length
const pointsByLength = {};
for (const w of words) {
  const l = w.length;
  const pts = l === 4 ? 1 : l + (w.is_pangram ? 7 : 0);
  if (!pointsByLength[l]) pointsByLength[l] = 0;
  pointsByLength[l] += pts;
}
const maxPointsByLen = Math.max(...Object.values(pointsByLength), 1);

// Show Counts by First Letter (nytbee.com feature)
const wordsByFirstLetter = {};
for (const w of words) {
  const first = w.word[0]?.toUpperCase();
  if (!first) continue;
  if (!wordsByFirstLetter[first]) wordsByFirstLetter[first] = { count: 0, isPangram: false, words: [] };
  wordsByFirstLetter[first].count++;
  wordsByFirstLetter[first].words.push(w.word);
  if (w.is_pangram === 1) wordsByFirstLetter[first].isPangram = true;
}
const sortedFirstLetters = Object.keys(wordsByFirstLetter).sort();
const maxFirstLetterCount = Math.max(...Object.values(wordsByFirstLetter).map(v => v.count), 1);

// Get last 7 puzzles for the sidebar
const lastRes = await fetch(`${API_BASE}/api/last/8`);
const lastData = await lastRes.json();
const recentPuzzles = (lastData.puzzles || []).filter(p => p.puzzle_id !== puzzle.puzzle_id).slice(0, 6);

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `What are the NYT Spelling Bee answers for ${puzzle.date}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `The NYT Spelling Bee for ${puzzle.date} has ${puzzle.word_count} words and ${puzzle.pangrams_count} pangram${puzzle.pangrams_count !== 1 ? 's' : ''}. The center letter is ${center} and the outer letters are ${outerLetters.join(', ')}. The maximum score is ${totalPoints} points.`
      }
    },
    {
      "@type": "Question",
      "name": `What is the center letter in today's Spelling Bee?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "@type": "Answer",
        "text": `Today's center letter is ${center}. Every word must contain this letter. The full set of letters is ${allLetters.split('').join(', ')}.`
      }
    },
    {
      "@type": "Question",
      "name": `How many pangrams are in today's Spelling Bee?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `There ${puzzle.pangrams_count === 1 ? 'is' : 'are'} ${puzzle.pangrams_count} pangram${puzzle.pangrams_count !== 1 ? 's' : ''} in today's puzzle. ${hasPerfectPangram ? 'This puzzle has a perfect pangram (a 7-letter word using all letters exactly once).' : 'There are no perfect pangrams in today\'s puzzle.'}`
      }
    },
    {
      "@type": "Question",
      "name": `What score do you need for Genius in today's Spelling Bee?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `You need at least ${geniusThreshold} points out of ${totalPoints} total points to reach Genius level in today's puzzle. That's 70% of the maximum score.`
      }
    }
  ]
});
---

<BaseLayout title={`Spelling Bee Answers for ${puzzle.date} | Today's NYT Puzzle`} description={`NYT Spelling Bee answers for ${puzzle.date}. Find all ${puzzle.word_count} words, ${puzzle.pangrams_count} pangrams, and hints. Center letter: ${center}.`} schema={faqSchema}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 sm:py-10">
    <div class="flex flex-col lg:flex-row gap-8 lg:gap-10">
      <!-- Main Content -->
      <div class="flex-1 min-w-0">
        <!-- Header - Date BELOW H1 -->
        <div class="mb-8">
          <h1 class="text-2xl sm:text-3xl font-black text-gray-900 mb-2">Spelling Bee Answers and Clue with Meaning</h1>
          <p class="text-gray-500 font-medium">{puzzle.date}</p>
        </div>

        <!-- Honeycomb + Stats Row -->
        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-8 mb-8">
          <div class="flex-shrink-0">
            <div class="p-4 bg-gradient-to-br from-amber-50 to-yellow-50 rounded-2xl border border-amber-100">
              <Honeycomb center={center} outer={outerLetters} size="md" />
            </div>
          </div>
          <div class="flex-1 w-full">
            <div class="grid grid-cols-2 gap-3 mb-5">
              <div class="stat-card">
                <p class="stat-value">{puzzle.word_count}</p>
                <p class="stat-label">Words</p>
              </div>
              <div class="stat-card">
                <p class="stat-value">{puzzle.pangrams_count}</p>
                <p class="stat-label">Pangrams</p>
              </div>
              <div class="stat-card">
                <p class="stat-value">{totalPoints}</p>
                <p class="stat-label">Max Points</p>
              </div>
              <div class="stat-card">
                <p class="stat-value">{geniusThreshold}</p>
                <p class="stat-label">Points for Genius</p>
              </div>
            </div>
            <!-- Letters info -->
            <div class="text-sm text-gray-500 mb-3">
              <span class="font-semibold text-gray-700">Center:</span> <span class="letter-circle letter-circle-center !w-7 !h-7 !text-xs inline-flex">{center}</span>
              <span class="mx-2 text-gray-300">|</span>
              <span class="font-semibold text-gray-700">Letters:</span> {allLetters.split('').map((l) => <span class:list={['inline-flex items-center justify-center w-6 h-6 rounded text-xs font-bold mx-0.5', l === center ? 'bg-amber-100 text-amber-700' : 'bg-gray-100 text-gray-600']}>{l}</span>)}
            </div>
            {hasPerfectPangram && (
              <div class="text-sm text-emerald-700 font-semibold flex items-center gap-1.5">
                <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="#10B981" stroke-width="2"><circle cx="10" cy="10" r="9"/><path d="M6 10l3 3 5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Has Perfect Pangram!
              </div>
            )}
          </div>
        </div>

        <!-- Genius Requirement Analysis (nytbee.com feature) -->
        <div class="card-elevated p-5 mb-6">
          <h2 class="text-sm font-bold text-gray-800 mb-3 flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2" stroke-linecap="round"><path d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
            Genius Requirement Analysis
          </h2>
          <p class="text-sm text-gray-600 leading-relaxed">
            Genius requires between <strong>{minWordsForGenius}</strong> and <strong>{maxWordsForGenius}</strong> words. You need at least a <strong>{minLenForGenius}-letter word</strong> to reach genius.
            {pangrams.length > 0 ? (
              <>
                If you don't get the pangrams, you need <strong>{pctWithoutPangrams}%</strong> of the total points to reach genius.
                If you get the pangrams, you only need <strong>{pctWithPangrams}%</strong> of the remaining points to reach genius.
              </>
            ) : (
              <>You need <strong>{pctWithoutPangrams}%</strong> of the total points to reach genius.</>
            )}
          </p>
        </div>

        <!-- Spoiler Reveal Button -->
        <div class="mb-6">
          <button id="reveal-answers-btn" class="btn-secondary text-sm !py-2.5 w-full sm:w-auto" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            Show All Answers
          </button>
          <p class="text-xs text-gray-400 mt-1.5">Spoilers ahead! Click to reveal the complete word list.</p>
        </div>

        <!-- Answers Container (hidden by default for spoiler) -->
        <div id="answers-container" class="hidden">
          <!-- Perfect Pangrams -->
          {hasPerfectPangram && perfectPangrams.length > 0 && (
            <div class="mb-6 p-5 bg-emerald-50 border border-emerald-200 rounded-xl">
              <h2 class="text-sm font-bold text-emerald-800 mb-3 flex items-center gap-2">
                <svg width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="#10B981" stroke-width="2"><circle cx="10" cy="10" r="9"/><path d="M6 10l3 3 5-5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Perfect Pangram{perfectPangrams.length > 1 ? 's' : ''}!
              </h2>
              <p class="text-xs text-emerald-600 mb-3">A perfect pangram uses all 7 letters exactly once (7 letters total).</p>
              <div class="flex flex-wrap gap-2">
                {perfectPangrams.map(w => (
                  <span class="perfect-pangram-chip">{w}</span>
                ))}
              </div>
            </div>
          )}

          <!-- Pangrams -->
          {pangrams.length > 0 && (
            <div class="mb-8">
              <h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
                <svg width="16" height="16" viewBox="0 0 20 20" fill="#F59E0B"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.33L10 13.27l-4.77 2.51.91-5.33L2.27 6.62l5.34-.78z"/></svg>
                Pangrams ({pangrams.length})
              </h2>
              <div class="flex flex-wrap gap-2">
                {pangrams.map(w => (
                  <span class="pangram-chip">
                    <span class="star">&#9733;</span>
                    {w.word}
                    <span class="text-xs text-amber-500 opacity-70">{w.length}</span>
                  </span>
                ))}
              </div>
            </div>
          )}

          <!-- Words by Length -->
          <div>
            <h2 class="text-lg font-bold text-gray-800 mb-4">All Words ({words.length})</h2>
            <div class="card-elevated divide-y divide-gray-50 max-h-[600px] overflow-y-auto custom-scroll">
              {sortedLengths.map(len => (
                <div class="px-5 py-4">
                  <p class="text-xs font-bold text-gray-400 mb-3 uppercase tracking-wider">{len}-Letter Words ({wordsByLength[len].length})</p>
                  <div class="flex flex-wrap gap-2">
                    {wordsByLength[len].map(w => (
                      <span class="word-chip">{w.word}</span>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Word Length Distribution Chart (nytbee.com feature) -->
          <div class="mt-8 card-elevated p-6">
            <h2 class="text-lg font-bold text-gray-800 mb-2">Length of Words in This Puzzle</h2>
            <p class="text-xs text-gray-400 mb-4">Hover over bars to see which words belong to each length.</p>
            <div class="space-y-2.5">
              {sortedLenAll.map(len => {
                const count = wordsByLenAll[len].length;
                const pct = Math.round((count / words.length) * 100);
                const barWidth = Math.max((count / maxLenCount) * 100, 3);
                const isPangramLen = wordsByLenAll[len].some(w => w.is_pangram);
                return (
                  <div class="flex items-center gap-3 group cursor-default" title={wordsByLenAll[len].map(w => w.word).join(', ')}>
                    <span class="w-8 text-sm font-bold text-gray-600 text-right">{len}</span>
                    <div class="flex-1">
                      <div class="w-full bg-gray-100 rounded-full h-8 overflow-hidden">
                        <div class:list={[
                          'h-8 rounded-full flex items-center pl-3 text-xs font-bold transition-all',
                          isPangramLen ? 'bg-gradient-to-r from-amber-300 to-amber-500 text-white' : 'bg-gray-300 text-gray-700'
                        ]} style={`width: ${barWidth}%`}>
                          {count} {isPangramLen && <span class="ml-1 text-amber-100">&#9733;</span>}
                        </div>
                      </div>
                    </div>
                    <span class="text-xs text-gray-400 font-medium w-10 text-right">{pct}%</span>
                  </div>
                );
              })}
            </div>
          </div>

          <!-- Points by Length Chart -->
          <div class="mt-6 card-elevated p-6">
            <h2 class="text-lg font-bold text-gray-800 mb-2">Points Available by Length</h2>
            <p class="text-xs text-gray-400 mb-4">How the total score breaks down by word length.</p>
            <div class="space-y-2.5">
              {sortedLenAll.map(len => {
                const pts = pointsByLength[len] || 0;
                const pct = totalPoints > 0 ? Math.round((pts / totalPoints) * 100) : 0;
                const barWidth = Math.max((pts / maxPointsByLen) * 100, 3);
                return (
                  <div class="flex items-center gap-3">
                    <span class="w-8 text-sm font-bold text-gray-600 text-right">{len}</span>
                    <div class="flex-1">
                      <div class="w-full bg-gray-100 rounded-full h-8 overflow-hidden">
                        <div class="h-8 rounded-full flex items-center pl-3 text-xs font-bold bg-gradient-to-r from-purple-300 to-purple-500 text-white" style={`width: ${barWidth}%`}>
                          {pts} pts
                        </div>
                      </div>
                    </div>
                    <span class="text-xs text-gray-400 font-medium w-10 text-right">{pct}%</span>
                  </div>
                );
              })}
            </div>
          </div>

          <!-- Show Counts by First Letter (nytbee.com style) -->
          <div class="mt-6">
            <button id="show-first-letter-btn" class="btn-secondary text-sm !py-2.5 w-full sm:w-auto" type="button">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 20V10M12 20V4M6 20v-6"/></svg>
              Show Counts by First Letter
            </button>
            <p class="text-xs text-gray-400 mt-1.5">Reveals a chart with the number of words starting with each letter. Red bars indicate pangram(s).</p>
          </div>
          <div id="first-letter-chart" class="hidden mt-4 card-elevated p-6">
            <div class="space-y-2.5">
              {sortedFirstLetters.map(letter => {
                const info = wordsByFirstLetter[letter];
                const barWidth = Math.max((info.count / maxFirstLetterCount) * 100, 8);
                return (
                  <div class="flex items-center gap-3" title={info.words.join(', ')}>
                    <span class:list={['w-8 text-sm font-black text-right', info.isPangram ? 'text-red-500' : 'text-gray-600']}>{letter}</span>
                    <div class="flex-1">
                      <div class="w-full bg-gray-100 rounded-full h-7 overflow-hidden">
                        <div class:list={[
                          'h-7 rounded-full flex items-center pl-3 text-xs font-bold',
                          info.isPangram ? 'bg-red-400 text-white' : 'bg-gray-300 text-gray-700'
                        ]} style={`width: ${barWidth}%`}>
                          {info.count}
                        </div>
                      </div>
                    </div>
                    {info.isPangram && (
                      <span class="text-xs text-red-500 font-bold">PANGRAM</span>
                    )}
                  </div>
                );
              })}
            </div>
          </div>
        </div>

        <!-- SEO Content Section -->
        <div class="mt-10 p-6 bg-gray-50 rounded-2xl">
          <h2 class="text-lg font-bold text-gray-800 mb-3">Today's Spelling Bee Puzzle Breakdown</h2>
          <p class="text-gray-600 leading-relaxed text-sm mb-3">The New York Times Spelling Bee for <strong>{puzzle.date}</strong> uses <strong>{center}</strong> as the mandatory center letter with outer letters <strong>{outerLetters.join(', ')}</strong>. Players need to find as many words as possible that include the center letter and are at least four letters long. Each letter can be used multiple times within a word.</p>
          <p class="text-gray-600 leading-relaxed text-sm mb-3">Today's puzzle contains <strong>{puzzle.word_count} valid words</strong> and <strong>{puzzle.pangrams_count} pangram{puzzle.pangrams_count !== 1 ? 's' : ''}</strong>. A pangram is a word that uses all seven available letters at least once. {hasPerfectPangram ? `This puzzle features a perfect pangram — a word that uses each letter exactly once, making it exactly 7 letters long. The perfect pangram${perfectPangrams.length > 1 ? 's are' : ' is'} <strong>${perfectPangrams.join(', ').toUpperCase()}</strong>.` : 'There are no perfect pangrams in today\'s puzzle, meaning no 7-letter word uses each letter exactly once.'}</p>
          <p class="text-gray-600 leading-relaxed text-sm mb-3">The maximum possible score for this puzzle is <strong>{totalPoints} points</strong>. Four-letter words earn 1 point each, while longer words earn points equal to their letter count. Pangrams receive a bonus 7 points on top of their letter-count score. To reach Genius level, you need <strong>{geniusThreshold} points</strong> (70% of the total).</p>
          <p class="text-gray-600 leading-relaxed text-sm mb-3">Word lengths in today's Bee range from 4 to {sortedLengths[0] || '?'} letters. {sortedLengths.length > 0 ? `The most common word length is ${sortedLengths.reduce((a, b) => wordsByLength[a].length >= wordsByLength[b].length ? a : b)}-letter words with ${wordsByLength[sortedLengths.reduce((a, b) => wordsByLength[a].length >= wordsByLength[b].length ? a : b)].length} entries.` : ''} The center letter {center} appears in every single word, while the outer letters each appear in a varying number of answers.</p>
          <p class="text-gray-600 leading-relaxed text-sm">SbSolver provides the complete word list, pangram details, and scoring breakdown for every daily Spelling Bee puzzle. Whether you're stuck on a few words or want to verify your progress, our tool gives you instant access to today's full solution set without any subscription or paywall.</p>
        </div>

        <!-- FAQ Section -->
        <div class="mt-8">
          <h2 class="text-lg font-bold text-gray-800 mb-4">Frequently Asked Questions</h2>
          <div class="space-y-3">
            <details class="card-elevated p-5 group" open>
              <summary class="font-semibold text-gray-800 cursor-pointer flex items-center justify-between">What are the NYT Spelling Bee answers for {puzzle.date}?
                <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <p class="text-sm text-gray-600 mt-3 leading-relaxed">The Spelling Bee for {puzzle.date} has {puzzle.word_count} words and {puzzle.pangrams_count} pangram{puzzle.pangrams_count !== 1 ? 's' : ''}. The center letter is {center} and the available letters are {allLetters.split('').join(', ')}. Click "Show All Answers" above to see the complete word list.</p>
            </details>
            <details class="card-elevated p-5 group">
              <summary class="font-semibold text-gray-800 cursor-pointer flex items-center justify-between">What score do I need for Genius today?
                <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <p class="text-sm text-gray-600 mt-3 leading-relaxed">You need {geniusThreshold} points out of {totalPoints} total to reach Genius. That's 70% of the maximum score. {pangrams.length > 0 ? `Finding the pangram${pangrams.length > 1 ? 's' : ''} helps a lot since each one is worth at least 14 points (7-letter word = 7 points + 7 bonus).` : ''}</p>
            </details>
            <details class="card-elevated p-5 group">
              <summary class="font-semibold text-gray-800 cursor-pointer flex items-center justify-between">Does today's puzzle have a perfect pangram?
                <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <p class="text-sm text-gray-600 mt-3 leading-relaxed">{hasPerfectPangram ? `Yes! Today's puzzle has a perfect pangram: <strong>${perfectPangrams.join(', ').toUpperCase()}</strong>. A perfect pangram uses all seven letters exactly once, making it exactly 7 letters long.` : 'No, today\'s puzzle does not have a perfect pangram. A perfect pangram would be a 7-letter word that uses each of the seven available letters exactly once.'}</p>
            </details>
            <details class="card-elevated p-5 group">
              <summary class="font-semibold text-gray-800 cursor-pointer flex items-center justify-between">How does the NYT Spelling Bee scoring work?
                <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
              </summary>
              <p class="text-sm text-gray-600 mt-3 leading-relaxed">Four-letter words are worth 1 point each. Words with five or more letters earn points equal to their length. Pangrams (words using all seven letters) get a 7-point bonus on top of their base score. The progress levels are: Beginner (0%), Starting (2%), Solid (5%), Nice (8%), Good (15%), Great (25%), Amazing (40%), Genius (70%), and Queen Bee (100%).</p>
            </details>
          </div>
        </div>
      </div>

      <!-- Sidebar -->
      <aside class="w-full lg:w-72 flex-shrink-0 space-y-4">
        <div class="card-elevated p-5">
          <h3 class="font-bold text-gray-800 mb-4 text-sm">Recent Puzzles</h3>
          <div class="space-y-1">
            {recentPuzzles.map(p => {
              const slug = p.date.toLowerCase().replace(/,\s*/g, '-').replace(/\s+/g, '-');
              return (
                <a href={`/answer-for-${slug}`} class="block p-2.5 rounded-lg hover:bg-amber-50 transition-colors group">
                  <p class="text-sm font-medium text-gray-700 group-hover:text-amber-700">{p.date}</p>
                  <p class="text-xs text-gray-400">Center: {p.letters} &middot; {p.word_count} words</p>
                </a>
              );
            })}
          </div>
        </div>

        <div class="card-elevated p-5 space-y-2">
          <a href="/solver" class="btn-primary w-full text-sm !py-3">
            <svg width="16" height="18" viewBox="0 0 100 110"><polygon points="50,3 95,27.5 95,72.5 50,97 5,72.5 5,27.5" fill="white" stroke="white" stroke-width="3"/></svg>
            Use Solver
          </a>
          <a href="/archive" class="btn-secondary w-full text-sm !py-3">Puzzle Archive</a>
        </div>
      </aside>
    </div>
  </div>

  <script>
    // Reveal answers button
    document.getElementById('reveal-answers-btn')?.addEventListener('click', function() {
      const container = document.getElementById('answers-container');
      if (container) {
        container.classList.remove('hidden');
        this.style.display = 'none';
      }
    });

    // Show first letter chart toggle
    document.getElementById('show-first-letter-btn')?.addEventListener('click', function() {
      const chart = document.getElementById('first-letter-chart');
      if (chart) {
        const isHidden = chart.classList.contains('hidden');
        chart.classList.toggle('hidden');
        this.textContent = isHidden ? 'Hide Counts by First Letter' : 'Show Counts by First Letter';
      }
    });
  </script>
</BaseLayout>
