---
import BaseLayout from '../layouts/BaseLayout.astro';
import Honeycomb from '../components/Honeycomb.astro';
import { API_BASE, getProgressLevel } from '../lib/utils';

// ==================== FETCH PRIMARY DATA ====================
const res = await fetch(`${API_BASE}/today`);
const data = await res.json();
const puzzle = data.puzzle || {};
const words = data.words || [];

const center = puzzle.letters || '';
const allLetters = puzzle.all_letters || '';
const outerLetters = allLetters.split('').filter(l => l !== center);
const pangrams = words.filter(w => w.is_pangram === 1);
const regularWords = words.filter(w => w.is_pangram !== 1);
const totalPoints = data.totalPoints || 0;
const hasPerfectPangram = data.hasPerfectPangram || false;
const perfectPangrams = data.perfectPangrams || [];
const geniusThreshold = Math.round(totalPoints * 0.70);

// ==================== COMPUTE PUZZLE STATS ====================

// Group words by length (including pangrams for chart data)
const wordsByLengthAll = {};
for (const w of words) {
  const l = w.length;
  if (!wordsByLengthAll[l]) wordsByLengthAll[l] = [];
  wordsByLengthAll[l].push(w);
}
const sortedLengths = Object.keys(wordsByLengthAll).sort((a, b) => +a - +b);

// Group regular words by length (for display)
const wordsByLength = {};
for (const w of regularWords) {
  const l = w.length;
  if (!wordsByLength[l]) wordsByLength[l] = [];
  wordsByLength[l].push(w);
}
const sortedLengthsRegular = Object.keys(wordsByLength).sort((a, b) => +a - +b);

// Words by First Letter
const wordsByFirstLetter = {};
for (const w of words) {
  const first = w.word[0]?.toUpperCase();
  if (!first) continue;
  if (!wordsByFirstLetter[first]) wordsByFirstLetter[first] = { count: 0, isPangram: false };
  wordsByFirstLetter[first].count++;
  if (w.is_pangram === 1) wordsByFirstLetter[first].isPangram = true;
}
const sortedFirstLetters = Object.keys(wordsByFirstLetter).sort();
const maxFirstLetterCount = Math.max(...Object.values(wordsByFirstLetter).map(v => v.count), 1);

// Calculate points by word length
function getWordPoints(word) {
  if (word.length === 4) return 1;
  return word.length + (word.is_pangram ? 7 : 0);
}

const pointsByLength = {};
for (const w of words) {
  const l = w.length;
  if (!pointsByLength[l]) pointsByLength[l] = 0;
  pointsByLength[l] += getWordPoints(w);
}
const maxPointsByLength = Math.max(...Object.values(pointsByLength), 1);
const maxWordsByLength = Math.max(...sortedLengths.map(l => wordsByLengthAll[l].length), 1);

// ==================== GENIUS REQUIREMENT ANALYSIS ====================
// How many words (from shortest up) do you need to reach Genius?
let geniusWordCount = 0;
let geniusPointsAccum = 0;
const sortedByPointsDesc = [...words].sort((a, b) => {
  const pa = getWordPoints(a);
  const pb = getWordPoints(b);
  return pb - pa;
});
for (const w of sortedByPointsDesc) {
  geniusPointsAccum += getWordPoints(w);
  geniusWordCount++;
  if (geniusPointsAccum >= geniusThreshold) break;
}
const geniusPctOfWords = ((geniusWordCount / words.length) * 100).toFixed(1);
const geniusPctOfPoints = ((geniusThreshold / totalPoints) * 100).toFixed(1);

// ==================== FETCH SECONDARY DATA ====================

// Last 8 puzzles for sidebar
const lastRes = await fetch(`${API_BASE}/api/last/8`);
const lastData = await lastRes.json();
const recentPuzzles = (lastData.puzzles || []).filter(p => p.puzzle_id !== puzzle.puzzle_id).slice(0, 6);

// Global statistics
let stats = { overview: {}, averages: {}, extremes: {} };
let centerFreq = [];
let letterFreq = [];
let wordDist = [];
let centerLetterCombos = [];

try {
  const statsRes = await fetch(`${API_BASE}/api/statistics`);
  const statsData = await statsRes.json();
  stats = statsData || stats;

  const cfRes = await fetch(`${API_BASE}/api/mostCommonCenterLetters`);
  centerFreq = (await cfRes.json()).centerLetterFrequency || [];

  const lfRes = await fetch(`${API_BASE}/api/allLettersFrequency`);
  letterFreq = (await lfRes.json()).allLettersFrequency || [];

  const wdRes = await fetch(`${API_BASE}/api/wordLengthDistribution`);
  const wdData = await wdRes.json();
  wordDist = wdData.wordLengthDistribution || [];
} catch (e) {
  console.error('Secondary data fetch error:', e);
}

const overview = stats.overview || {};
const averages = stats.averages || {};
const extremes = stats.extremes || {};
const totalPuzzles = overview.totalPuzzles || 2932;

// Fetch center letter combo for "Other Days With This Pangram"
try {
  const clcRes = await fetch(`${API_BASE}/api/centerLetterCombo/${center}`);
  const clcData = await clcRes.json();
  centerLetterCombos = (clcData.puzzles || []).filter(p => p.puzzle_id !== puzzle.puzzle_id).slice(0, 8);
} catch (e) {
  console.error('Center letter combo fetch error:', e);
}

// ==================== COMPUTE COMPARISON DATA ====================

// Letter frequency lookup
const letterFreqMap = {};
for (const item of letterFreq) {
  letterFreqMap[item.letter] = item;
}

// Center letter frequency lookup
const centerFreqMap = {};
for (const item of centerFreq) {
  centerFreqMap[item.letter] = item;
}

// Global word length distribution map
const globalWordDistMap = {};
let globalTotalWords = 0;
for (const item of wordDist) {
  globalWordDistMap[item.length] = item.count;
  globalTotalWords += item.count;
}

// Average word length for this puzzle
const thisPuzzleAvgLen = words.length > 0
  ? (words.reduce((sum, w) => sum + w.length, 0) / words.length).toFixed(1)
  : '0';

// ==================== PERCENTILE RANKINGS ====================
// Compare this puzzle's metrics to global averages
const wordCountPct = averages.wordsPerPuzzle > 0
  ? Math.round((puzzle.word_count / averages.wordsPerPuzzle) * 100)
  : 100;
const pangramPct = averages.pangramsPerPuzzle > 0
  ? Math.round((puzzle.pangrams_count / averages.pangramsPerPuzzle) * 100)
  : 100;
const avgPointsPerWord = words.length > 0 ? (totalPoints / words.length).toFixed(1) : '0';
const globalAvgPointsPerWord = averages.wordsPerPuzzle > 0
  ? ((averages.wordsPerPuzzle * averages.averageWordLength || 0) / averages.wordsPerPuzzle).toFixed(1)
  : '0';

// Word count percentile (rough estimate based on extremes)
const minWords = extremes.puzzleWithFewestWords?.word_count || 16;
const maxWords = extremes.puzzleWithMostWords?.word_count || 81;
const wordRange = maxWords - minWords || 1;
const wordPercentile = Math.min(99, Math.max(1, Math.round(((puzzle.word_count - minWords) / wordRange) * 100)));

// Pre-compute FAQ strings that use < operator (Astro can't handle < in template expressions)
const faqCompareText = wordPercentile >= 60
  ? 'This makes it a larger-than-average puzzle with more scoring potential.'
  : wordPercentile < 40
    ? 'This makes it a smaller puzzle where every word matters more.'
    : 'This is a fairly typical puzzle by Spelling Bee standards.';

// ==================== WORD FREQUENCY (from recent puzzles) ====================
const recentWordFreq = {};
for (const rp of (lastData.puzzles || [])) {
  if (rp.puzzle_id === puzzle.puzzle_id) continue;
  const rpWords = rp.words || [];
  for (const w of rpWords) {
    recentWordFreq[w.word] = (recentWordFreq[w.word] || 0) + 1;
  }
}

// Categorize words by rarity
const wordRarity = words.map(w => {
  const freq = recentWordFreq[w.word] || 0;
  let rarity = 'common';
  if (freq === 0) rarity = 'unique';
  else if (freq === 1) rarity = 'uncommon';
  else if (freq <= 3) rarity = 'occasional';
  return { ...w, freq, rarity };
});

const rarityColors = {
  unique: { bg: 'bg-purple-50', border: 'border-purple-200', text: 'text-purple-700', label: 'Unique to this puzzle' },
  uncommon: { bg: 'bg-blue-50', border: 'border-blue-200', text: 'text-blue-700', label: 'Uncommon' },
  occasional: { bg: 'bg-emerald-50', border: 'border-emerald-200', text: 'text-emerald-700', label: 'Occasional' },
  common: { bg: 'bg-amber-50', border: 'border-amber-200', text: 'text-amber-700', label: 'Common' },
};

// ==================== FAQ SCHEMA ====================
const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `What are the NYT Spelling Bee answers for ${puzzle.date}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `The NYT Spelling Bee for ${puzzle.date} has ${puzzle.word_count} words and ${puzzle.pangrams_count} pangram${puzzle.pangrams_count !== 1 ? 's' : ''}. The center letter is ${center} and the outer letters are ${outerLetters.join(', ')}. The maximum score is ${totalPoints} points.`
      }
    },
    {
      "@type": "Question",
      "name": `What is the center letter in today's Spelling Bee?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `Today's center letter is ${center}. Every word must contain this letter. The full set of letters is ${allLetters.split('').join(', ')}.`
      }
    },
    {
      "@type": "Question",
      "name": `How many pangrams are in today's Spelling Bee?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `There ${puzzle.pangrams_count === 1 ? 'is' : 'are'} ${puzzle.pangrams_count} pangram${puzzle.pangrams_count !== 1 ? 's' : ''} in today's puzzle. ${hasPerfectPangram ? 'This puzzle has a perfect pangram (a 7-letter word using all letters exactly once).' : 'There are no perfect pangrams in today\'s puzzle.'}`
      }
    },
    {
      "@type": "Question",
      "name": `What score do you need for Genius in today's Spelling Bee?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `You need at least ${geniusThreshold} points out of ${totalPoints} total points to reach Genius level in today's puzzle. That's 70% of the maximum score.`
      }
    }
  ]
});

// ==================== HELPERS ====================
const safeNum = (val, def = 0) => (val != null && !isNaN(Number(val))) ? Number(val) : def;
const safeLocale = (val) => (val != null && typeof val === 'number') ? val.toLocaleString() : (val != null ? String(val) : '\u2014');
---

<BaseLayout title="Spelling Bee Answers and Clue with Meaning" description={`NYT Spelling Bee answers for ${puzzle.date}. Find all ${puzzle.word_count} words, ${puzzle.pangrams_count} pangrams, hints, and analysis. Center letter: ${center}.`} schema={faqSchema}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
    <div class="flex flex-col lg:flex-row gap-8">
      <!-- ========== MAIN CONTENT ========== -->
      <div class="flex-1 min-w-0">

        <!-- Header -->
        <div class="mb-8">
          <div class="flex items-center gap-3 mb-2">
            <span class="badge badge-gold">Today</span>
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">Spelling Bee Answers and Clue with Meaning</h1>
          </div>
          <p class="text-gray-500 font-medium">{puzzle.date}</p>
        </div>

        <!-- Honeycomb + Stats Row -->
        <div class="flex flex-col sm:flex-row items-center sm:items-start gap-8 mb-8">
          <div class="flex-shrink-0">
            <Honeycomb center={center} outer={outerLetters} size="md" />
          </div>
          <div class="flex-1 w-full">
            <div class="grid grid-cols-2 gap-3 mb-5">
              <div class="stat-card">
                <p class="stat-value">{puzzle.word_count}</p>
                <p class="stat-label">Words</p>
              </div>
              <div class="stat-card">
                <p class="stat-value">{puzzle.pangrams_count}</p>
                <p class="stat-label">Pangrams</p>
              </div>
              <div class="stat-card">
                <p class="stat-value">{totalPoints}</p>
                <p class="stat-label">Max Points</p>
              </div>
              <div class="stat-card">
                <p class="stat-value">{hasPerfectPangram ? 'Yes' : '\u2014'}</p>
                <p class="stat-label">Perfect Pangram</p>
              </div>
            </div>
            <div class="text-sm text-gray-500 mb-3">
              <span class="font-semibold text-purple-600">Genius threshold:</span> {geniusThreshold} points (70% of {totalPoints})
            </div>
            <div class="text-sm text-gray-500">
              <span class="font-semibold text-gray-700">Center:</span> <span class="letter-circle letter-circle-center !w-7 !h-7 !text-xs inline-flex">{center}</span>
              <span class="mx-2 text-gray-300">|</span>
              <span class="font-semibold text-gray-700">Letters:</span> {allLetters.split('').map((l) => <span class:list={['inline-flex items-center justify-center w-6 h-6 rounded text-xs font-bold mx-0.5', l === center ? 'bg-amber-100 text-amber-700' : 'bg-gray-100 text-gray-600']}>{l}</span>)}
            </div>
          </div>
        </div>

        <!-- ===== SECTION 1: GENIUS REQUIREMENT ANALYSIS ===== -->
        <div class="card-elevated p-6 mb-8">
          <h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#7C3AED" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            Genius Requirement Analysis
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-5">
            <div class="p-4 bg-purple-50 rounded-xl border border-purple-100 text-center">
              <p class="text-2xl font-black text-purple-700">{geniusThreshold}</p>
              <p class="text-xs font-semibold text-purple-500 mt-1 uppercase tracking-wide">Points for Genius</p>
            </div>
            <div class="p-4 bg-amber-50 rounded-xl border border-amber-100 text-center">
              <p class="text-2xl font-black text-amber-700">{geniusWordCount} <span class="text-sm font-semibold">of {words.length}</span></p>
              <p class="text-xs font-semibold text-amber-500 mt-1 uppercase tracking-wide">Words Needed</p>
            </div>
            <div class="p-4 bg-gray-50 rounded-xl border border-gray-200 text-center">
              <p class="text-2xl font-black text-gray-700">{geniusPctOfWords}%</p>
              <p class="text-xs font-semibold text-gray-500 mt-1 uppercase tracking-wide">Of All Words</p>
            </div>
          </div>
          <div class="mb-3">
            <div class="flex justify-between text-xs text-gray-500 mb-1.5">
              <span>0 pts</span>
              <span>Genius: {geniusThreshold} pts ({geniusPctOfPoints}%)</span>
              <span>{totalPoints} pts</span>
            </div>
            <div class="w-full bg-gray-100 rounded-full h-4 overflow-hidden relative">
              <div class="bg-gradient-to-r from-amber-300 to-amber-500 h-4 rounded-full" style={`width: ${geniusPctOfPoints}%`}></div>
              <div class="absolute top-0 h-full w-0.5 bg-purple-600" style={`left: ${geniusPctOfPoints}%`}></div>
            </div>
            <div class="flex justify-between text-xs text-gray-400 mt-1">
              <span>Beginner</span>
              <span>Genius</span>
              <span>Queen Bee</span>
            </div>
          </div>
          <p class="text-sm text-gray-600 leading-relaxed mt-3">
            You need <strong>{geniusWordCount} out of {words.length} words</strong> ({geniusPctOfWords}% of the total) to reach Genius at {geniusThreshold} points.
            {geniusWordCount < words.length * 0.5
              ? ' Focus on the highest-value words — especially pangrams — since you don\'t need every word.'
              : ' This puzzle requires finding most of the words to hit Genius, so thoroughness matters.'
            }
          </p>
        </div>

        <!-- Perfect Pangrams -->
        {hasPerfectPangram && perfectPangrams.length > 0 && (
          <div class="mb-6 p-4 bg-emerald-50 border border-emerald-200 rounded-xl">
            <h2 class="text-sm font-bold text-emerald-800 mb-2 flex items-center gap-2">
              <svg width="16" height="16" viewBox="0 0 20 20" fill="#10B981"><circle cx="10" cy="10" r="9" fill="none" stroke="#10B981" stroke-width="2"/><path d="M6 10l3 3 5-5" fill="none" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Perfect Pangram{perfectPangrams.length > 1 ? 's' : ''}!
            </h2>
            <div class="flex flex-wrap gap-2">
              {perfectPangrams.map(w => (
                <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-emerald-100 border border-emerald-300 rounded-lg text-sm font-bold text-emerald-800 uppercase">{w}</span>
              ))}
            </div>
          </div>
        )}

        <!-- Pangrams -->
        {pangrams.length > 0 && (
          <div class="mb-8">
            <h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
              <svg width="16" height="16" viewBox="0 0 20 20" fill="#F59E0B"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.33L10 13.27l-4.77 2.51.91-5.33L2.27 6.62l5.34-.78z"/></svg>
              Pangrams ({pangrams.length})
            </h2>
            <div class="flex flex-wrap gap-2">
              {pangrams.map(w => (
                <span class="pangram-chip">
                  <span class="star">&#9733;</span>
                  {w.word}
                  <span class="text-xs text-amber-500 opacity-70">{w.length}</span>
                </span>
              ))}
            </div>
          </div>
        )}

        <!-- All Words by Length -->
        <div class="mb-8">
          <h2 class="text-lg font-bold text-gray-800 mb-4">All Words ({words.length})</h2>
          <div class="card-elevated divide-y divide-gray-50 max-h-[600px] overflow-y-auto custom-scroll">
            {sortedLengthsRegular.map(len => (
              <div class="px-5 py-4">
                <p class="text-xs font-bold text-gray-400 mb-3 uppercase tracking-wider">{len}-Letter Words ({wordsByLength[len].length})</p>
                <div class="flex flex-wrap gap-2">
                  {wordsByLength[len].map(w => (
                    <span class="word-chip">{w.word}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- ===== SECTION 2: LENGTH OF WORDS IN THIS PUZZLE ===== -->
        <div class="card-elevated p-6 mb-8">
          <h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#D97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="12" width="4" height="9" rx="1"/><rect x="10" y="7" width="4" height="14" rx="1"/><rect x="17" y="3" width="4" height="18" rx="1"/></svg>
            Length of Words in This Puzzle
          </h2>
          <div class="space-y-2.5">
            {sortedLengths.map(len => {
              const count = wordsByLengthAll[len].length;
              const pctOfTotal = ((count / words.length) * 100).toFixed(1);
              const barWidth = Math.max((count / maxWordsByLength) * 100, 3);
              const hasPangram = wordsByLengthAll[len].some(w => w.is_pangram === 1);
              return (
                <div class="flex items-center gap-3">
                  <span class="w-14 text-sm font-bold text-gray-600 text-right flex-shrink-0">{len}-letter</span>
                  <div class="flex-1">
                    <div class="w-full bg-gray-100 rounded-full h-7 overflow-hidden">
                      <div class:list={[
                        'h-7 rounded-full flex items-center pl-3 text-xs font-bold',
                        hasPangram
                          ? 'bg-gradient-to-r from-amber-300 to-amber-500 text-white'
                          : 'bg-gray-300 text-gray-700'
                      ]} style={`width: ${barWidth}%`}>
                        {count}
                      </div>
                    </div>
                  </div>
                  <span class="text-xs text-gray-400 font-medium w-12 text-right flex-shrink-0">{pctOfTotal}%</span>
                  {hasPangram && (
                    <svg width="12" height="12" viewBox="0 0 20 20" fill="#F59E0B" class="flex-shrink-0"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.33L10 13.27l-4.77 2.51.91-5.33L2.27 6.62l5.34-.78z"/></svg>
                  )}
                </div>
              );
            })}
          </div>
          <p class="text-sm text-gray-500 mt-4">
            The most common word length is <strong>{sortedLengths.reduce((a, b) => wordsByLengthAll[a].length >= wordsByLengthAll[b].length ? a : b)}-letter</strong> words with {wordsByLengthAll[sortedLengths.reduce((a, b) => wordsByLengthAll[a].length >= wordsByLengthAll[b].length ? a : b)]?.length || 0} entries.
            Word lengths range from 4 to {sortedLengths[sortedLengths.length - 1] || '?'} letters.
          </p>
        </div>

        <!-- ===== SECTION 3: POINTS AVAILABLE BY LENGTH ===== -->
        <div class="card-elevated p-6 mb-8">
          <h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            Points Available by Length
          </h2>
          <div class="space-y-2.5">
            {sortedLengths.map(len => {
              const pts = pointsByLength[len] || 0;
              const pctOfTotal = totalPoints > 0 ? ((pts / totalPoints) * 100).toFixed(1) : '0';
              const barWidth = Math.max((pts / maxPointsByLength) * 100, 3);
              const hasPangram = wordsByLengthAll[len].some(w => w.is_pangram === 1);
              return (
                <div class="flex items-center gap-3">
                  <span class="w-14 text-sm font-bold text-gray-600 text-right flex-shrink-0">{len}-letter</span>
                  <div class="flex-1">
                    <div class="w-full bg-gray-100 rounded-full h-7 overflow-hidden">
                      <div class:list={[
                        'h-7 rounded-full flex items-center pl-3 text-xs font-bold',
                        hasPangram
                          ? 'bg-gradient-to-r from-emerald-300 to-emerald-500 text-white'
                          : 'bg-emerald-200 text-emerald-800'
                      ]} style={`width: ${barWidth}%`}>
                        {pts} pts
                      </div>
                    </div>
                  </div>
                  <span class="text-xs text-gray-400 font-medium w-12 text-right flex-shrink-0">{pctOfTotal}%</span>
                </div>
              );
            })}
          </div>
          <p class="text-sm text-gray-500 mt-4">
            {(() => {
              const maxPtsLen = sortedLengths.reduce((a, b) => (pointsByLength[a] || 0) >= (pointsByLength[b] || 0) ? a : b);
              return <span><strong>{maxPtsLen}-letter words</strong> contribute the most points with <strong>{pointsByLength[maxPtsLen] || 0} points</strong> ({totalPoints > 0 ? ((pointsByLength[maxPtsLen] / totalPoints) * 100).toFixed(1) : 0}% of the total). {pangrams.length > 0 ? 'Pangram bonuses add significant points to longer words.' : ''}</span>;
            })()}
          </p>
        </div>

        <!-- ===== SECTION 4: HOW LONG ARE WORDS IN THE BEE? ===== -->
        <div class="card-elevated p-6 mb-8">
          <h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 16l4-8 4 4 4-10"/></svg>
            How Long Are Words in the Bee?
          </h2>
          <p class="text-sm text-gray-500 mb-4">Comparing this puzzle's word length distribution to the average across all puzzles.</p>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-gray-100">
                  <th class="text-left py-2.5 pr-4 font-semibold text-gray-600">Length</th>
                  <th class="text-center py-2.5 px-3 font-semibold text-amber-700 bg-amber-50 rounded-t-lg">This Puzzle</th>
                  <th class="text-center py-2.5 px-3 font-semibold text-gray-600">All Puzzles (Avg)</th>
                  <th class="text-center py-2.5 pl-3 font-semibold text-gray-600">Diff</th>
                </tr>
              </thead>
              <tbody>
                {sortedLengths.map(len => {
                  const thisCount = wordsByLengthAll[len]?.length || 0;
                  const globalCount = globalWordDistMap[len] || 0;
                  const globalAvg = totalPuzzles > 0 ? (globalCount / totalPuzzles) : 0;
                  const diff = thisCount - globalAvg;
                  const diffStr = diff >= 0 ? `+${diff.toFixed(1)}` : diff.toFixed(1);
                  const diffColor = diff >= 0 ? 'text-emerald-600' : 'text-red-500';
                  return (
                    <tr class="border-b border-gray-50">
                      <td class="py-2.5 pr-4 font-bold text-gray-700">{len}-letter</td>
                      <td class="py-2.5 px-3 text-center font-bold text-amber-700 bg-amber-50/50">{thisCount}</td>
                      <td class="py-2.5 px-3 text-center text-gray-600">{globalAvg.toFixed(1)}</td>
                      <td class:list={['py-2.5 pl-3 text-center font-semibold', diffColor]}>{diffStr}</td>
                    </tr>
                  );
                })}
                <tr class="border-t-2 border-gray-200 font-bold">
                  <td class="py-2.5 pr-4 text-gray-800">Average Length</td>
                  <td class="py-2.5 px-3 text-center text-amber-700 bg-amber-50/50">{thisPuzzleAvgLen}</td>
                  <td class="py-2.5 px-3 text-center text-gray-700">{safeNum(averages.averageWordLength).toFixed(1)}</td>
                  <td class:list={['py-2.5 pl-3 text-center', parseFloat(thisPuzzleAvgLen) >= safeNum(averages.averageWordLength) ? 'text-emerald-600' : 'text-red-500']}>
                    {(parseFloat(thisPuzzleAvgLen) - safeNum(averages.averageWordLength) >= 0 ? '+' : '') + (parseFloat(thisPuzzleAvgLen) - safeNum(averages.averageWordLength)).toFixed(1)}
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
          <p class="text-sm text-gray-500 mt-4">
            {parseFloat(thisPuzzleAvgLen) > safeNum(averages.averageWordLength)
              ? `This puzzle's words are <strong>longer than average</strong> (${thisPuzzleAvgLen} vs ${safeNum(averages.averageWordLength).toFixed(1)}), meaning more points per word on average.`
              : `This puzzle's words are <strong>shorter than average</strong> (${thisPuzzleAvgLen} vs ${safeNum(averages.averageWordLength).toFixed(1)}), so you'll need to find more words to rack up points.`
            }
          </p>
        </div>

        <!-- ===== SECTION 5: WORDS BY FIRST LETTER ===== -->
        <div class="card-elevated p-6 mb-8">
          <h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0891B2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 7V4h16v3"/><path d="M9 20h6"/><path d="M12 4v16"/></svg>
            Words by First Letter
          </h2>
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
            {sortedFirstLetters.map(letter => {
              const info = wordsByFirstLetter[letter];
              const barWidth = Math.max((info.count / maxFirstLetterCount) * 100, 8);
              return (
                <div class:list={['p-3 rounded-xl border', info.isPangram ? 'border-amber-200 bg-amber-50' : 'border-gray-100 bg-white']}>
                  <div class="flex items-center justify-between mb-2">
                    <span class:list={['text-lg font-black', info.isPangram ? 'text-amber-600' : 'text-gray-700']}>{letter}</span>
                    <span class="text-sm font-bold text-gray-500">{info.count}</span>
                  </div>
                  <div class="w-full bg-gray-100 rounded-full h-2">
                    <div class:list={['h-2 rounded-full', info.isPangram ? 'bg-amber-400' : 'bg-gray-300']} style={`width: ${barWidth}%`}></div>
                  </div>
                  {info.isPangram && <span class="text-[10px] text-amber-600 font-bold mt-1 block">HAS PANGRAM</span>}
                </div>
              );
            })}
          </div>
        </div>

        <!-- ===== SECTION 6: OTHER DAYS WITH THIS PANGRAM ===== -->
        {centerLetterCombos.length > 0 && (
          <div class="card-elevated p-6 mb-8">
            <h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#DC2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              Other Days With Center Letter {center}
            </h2>
            <p class="text-sm text-gray-500 mb-4">Recent puzzles that also featured <strong>{center}</strong> as the center letter. Different outer letters mean different pangrams and word sets.</p>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {centerLetterCombos.slice(0, 6).map(p => (
                <a href="/archive" class="block p-4 rounded-xl border border-gray-100 hover:border-amber-200 hover:bg-amber-50/50 transition-all group">
                  <div class="flex items-center justify-between mb-2">
                    <span class="font-semibold text-gray-800 group-hover:text-amber-700 text-sm">{p.date}</span>
                    <span class="font-mono text-xs text-gray-400">{p.all_letters}</span>
                  </div>
                  <div class="flex items-center gap-3 text-xs">
                    <span class="text-gray-500">{p.word_count} words</span>
                    <span class="text-amber-600 font-semibold">{p.pangrams_count} pangram{p.pangrams_count !== 1 ? 's' : ''}</span>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}

        <!-- ===== SECTION 6b: OTHER DAYS WITH THIS PANGRAM ===== -->
        {pangrams.length > 0 && (
          <div class="card-elevated p-6 mb-8">
            <h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="#F59E0B" stroke="#D97706" stroke-width="1"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              Other Days With This Pangram
            </h2>
            <p class="text-sm text-gray-500 mb-4">Other puzzles where these pangram words also appeared as pangrams.</p>
            <div class="space-y-4">
              {pangrams.map(p => (
                <div class="mb-3">
                  <p class="font-semibold text-amber-700 mb-2">{p.word.toUpperCase()}</p>
                  <div id={`pangram-history-${p.word}`} class="text-sm text-gray-500">
                    <div class="inline-block w-4 h-4 border-2 border-amber-400 border-t-transparent rounded-full animate-spin"></div>
                    <span class="ml-2">Loading...</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- ===== SECTION 7: HOW DOES THIS PUZZLE COMPARE? ===== -->
        <div class="card-elevated p-6 mb-8">
