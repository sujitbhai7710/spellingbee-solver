                  .slice(0, 20)
                  .map(w => {
                    const freq = wordFrequency[w.word];
                    return (
                      <span class:list={[
                        'inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium',
                        freq.other_puzzles > 20 ? 'bg-red-50 text-red-700' :
                        freq.other_puzzles > 10 ? 'bg-orange-50 text-orange-700' :
                        'bg-blue-50 text-blue-700'
                      ]} title={`Appears in ${freq.other_puzzles} other puzzle${freq.other_puzzles !== 1 ? 's' : ''}`}>
                        {w.word} <span class="opacity-60">({freq.other_puzzles})</span>
                      </span>
                    );
                  })}
              </div>
              <!-- Most Common Words Across All Puzzles -->
              {mostCommonWords.length > 0 && (
                <div class="mt-4 pt-4 border-t border-gray-100">
                  <h3 class="text-sm font-bold text-gray-700 mb-3">The most common words in the Bee are:</h3>
