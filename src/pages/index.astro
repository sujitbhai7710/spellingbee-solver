---
import BaseLayout from '../layouts/BaseLayout.astro';
import { API_BASE } from '../lib/utils';

// Get latest puzzle for the homepage
const todayRes = await fetch(`${API_BASE}/today`);
const todayData = await todayRes.json();
const puzzle = todayData.puzzle || {};
const words = todayData.words || [];
const center = puzzle.letters || '';
const allLetters = puzzle.all_letters || '';
const outerLetters = allLetters.split('').filter(l => l !== center);
const totalPoints = todayData.totalPoints || 0;
const pangrams = words.filter(w => w.is_pangram === 1);
const wordCount = puzzle.word_count || 0;
const pangramCount = puzzle.pangrams_count || 0;

// Get recent puzzles
const recentRes = await fetch(`${API_BASE}/api/last/5`);
const recentData = await recentRes.json();
const recentPuzzles = (recentData.puzzles || []).filter(p => p.puzzle_id !== puzzle.puzzle_id);

// Get stats
const statsRes = await fetch(`${API_BASE}/api/statistics`);
const statsData = await statsRes.json();
const totalPuzzles = statsData.overview?.totalPuzzles || 0;
const totalWords = statsData.overview?.totalWords || 0;
---

<BaseLayout title="Spelling Bee Solver - Daily NYT Answers & Hints" description="Solve NYT Spelling Bee puzzles instantly. Get today's answers, hints, word lists, and use our free solver tool.">
  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-amber-50 via-white to-amber-50 py-12 sm:py-16">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <div class="inline-flex items-center gap-2 bg-amber-100 text-amber-800 text-sm font-medium px-4 py-1.5 rounded-full mb-4">
        <span class="w-2 h-2 bg-amber-400 rounded-full animate-pulse"></span>
        Updated daily at 3:00 AM ET
      </div>
      <h1 class="text-4xl sm:text-5xl font-black text-gray-900 mb-4">
        Spelling Bee <span class="text-amber-500">Solver</span>
      </h1>
      <p class="text-lg text-gray-500 max-w-2xl mx-auto mb-8">
        Get instant answers for the NYT Spelling Bee. Find all words, pangrams, and hints. Free and fast.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a href="/today" class="px-6 py-3 bg-amber-400 text-white font-bold rounded-xl hover:bg-amber-500 transition-colors shadow-lg shadow-amber-200">
          Today's Answers →
        </a>
        <a href="/solver" class="px-6 py-3 bg-white text-gray-700 font-bold rounded-xl border border-gray-300 hover:border-amber-300 hover:text-amber-700 transition-colors">
          🐝 Solver Tool
        </a>
      </div>
    </div>
  </section>

  <!-- Today's Puzzle Preview -->
  <section class="max-w-6xl mx-auto px-4 py-10">
    <div class="flex items-center gap-2 mb-6">
      <span class="bg-amber-400 text-white text-xs font-bold px-2.5 py-1 rounded-full uppercase tracking-wide">Today</span>
      <h2 class="text-2xl font-bold text-gray-900">Today's Puzzle</h2>
    </div>

    <div class="flex flex-col lg:flex-row gap-8">
      <!-- Honeycomb + Quick Stats -->
      <div class="flex flex-col items-center lg:items-start">
        <div class="relative w-48 h-52 mb-4">
          <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-18 h-18 hex-shape hex-center flex items-center justify-center text-3xl z-10" style="width:72px;height:72px;">
            {center}
          </div>
          {outerLetters.map((letter, i) => {
            const angles = [270, 330, 30, 90, 150, 210];
            const angle = (angles[i] || 0) * Math.PI / 180;
            const radius = 62;
            const x = 50 + radius * Math.cos(angle) / 100 * 100;
            const y = 50 + radius * Math.sin(angle) / 100 * 100;
            return (
              <div class="absolute w-14 h-14 hex-shape bg-gray-100 border-2 border-gray-200 flex items-center justify-center text-xl font-bold text-gray-700" style={`left: ${x}%; top: ${y}%; transform: translate(-50%, -50%);`}>
                {letter}
              </div>
            );
          })}
        </div>
        <div class="text-center lg:text-left">
          <p class="text-sm text-gray-500">{puzzle.date}</p>
          <p class="text-sm text-gray-400">Letters: {allLetters}</p>
        </div>
      </div>

      <!-- Quick Word Preview -->
      <div class="flex-1 min-w-0">
        <div class="grid grid-cols-3 gap-3 mb-5">
          <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
            <p class="text-2xl font-bold text-amber-600">{wordCount}</p>
            <p class="text-xs text-gray-500">Words</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
            <p class="text-2xl font-bold text-amber-600">{pangramCount}</p>
            <p class="text-xs text-gray-500">Pangrams</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
            <p class="text-2xl font-bold text-amber-600">{totalPoints}</p>
            <p class="text-xs text-gray-500">Points</p>
          </div>
        </div>

        {pangrams.length > 0 && (
          <div class="mb-4">
            <h3 class="text-sm font-bold text-amber-700 mb-2 flex items-center gap-1"><span>★</span> Pangrams</h3>
            <div class="flex flex-wrap gap-2">
              {pangrams.map(w => (
                <span class="pangram-word px-3 py-1 rounded-md text-sm border border-amber-200">{w.word}</span>
              ))}
            </div>
          </div>
        )}

        <a href="/today" class="inline-flex items-center gap-1 text-amber-600 font-medium text-sm hover:text-amber-700 transition-colors">
          View all {wordCount} words →
        </a>
      </div>
    </div>
  </section>

  <!-- Features Grid -->
  <section class="bg-white py-12 border-t border-gray-100">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-gray-900 text-center mb-8">Everything You Need</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <a href="/today" class="group p-6 rounded-2xl border border-gray-200 hover:border-amber-300 hover:shadow-lg hover:shadow-amber-50 transition-all">
          <div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center text-2xl mb-4 group-hover:bg-amber-200 transition-colors">📋</div>
          <h3 class="font-bold text-gray-800 mb-1">Daily Answers</h3>
          <p class="text-sm text-gray-500">Get today's complete word list and pangrams instantly</p>
        </a>
        <a href="/solver" class="group p-6 rounded-2xl border border-gray-200 hover:border-amber-300 hover:shadow-lg hover:shadow-amber-50 transition-all">
          <div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center text-2xl mb-4 group-hover:bg-amber-200 transition-colors">🐝</div>
          <h3 class="font-bold text-gray-800 mb-1">Solver Tool</h3>
          <p class="text-sm text-gray-500">Enter your letters and find all possible words</p>
        </a>
        <a href="/archive" class="group p-6 rounded-2xl border border-gray-200 hover:border-amber-300 hover:shadow-lg hover:shadow-amber-50 transition-all">
          <div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center text-2xl mb-4 group-hover:bg-amber-200 transition-colors">📚</div>
          <h3 class="font-bold text-gray-800 mb-1">Archive</h3>
          <p class="text-sm text-gray-500">Browse {totalPuzzles.toLocaleString()}+ past puzzles with full answers</p>
        </a>
        <a href="/stats" class="group p-6 rounded-2xl border border-gray-200 hover:border-amber-300 hover:shadow-lg hover:shadow-amber-50 transition-all">
          <div class="w-12 h-12 bg-amber-100 rounded-xl flex items-center justify-center text-2xl mb-4 group-hover:bg-amber-200 transition-colors">📊</div>
          <h3 class="font-bold text-gray-800 mb-1">Statistics</h3>
          <p class="text-sm text-gray-500">Letter frequencies, word distributions, and more</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Recent Puzzles -->
  {recentPuzzles.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 py-10">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">Recent Puzzles</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {recentPuzzles.map(p => {
          const slug = p.date.toLowerCase().replace(/,\s*/g, '-').replace(/\s+/g, '-');
          return (
            <a href={`/answer-for-${slug}`} class="block bg-white rounded-xl border border-gray-200 p-5 hover:border-amber-300 hover:shadow-md transition-all group">
              <div class="flex items-center gap-3 mb-2">
                <span class="w-9 h-9 rounded-full bg-amber-400 text-white font-bold text-sm flex items-center justify-center">{p.letters}</span>
                <div>
                  <p class="font-medium text-gray-800 group-hover:text-amber-700">{p.date}</p>
                  <p class="text-xs text-gray-400">{p.all_letters}</p>
                </div>
              </div>
              <div class="flex items-center gap-4 text-xs text-gray-500">
                <span>{p.word_count} words</span>
                <span>{p.pangrams_count} pangram{p.pangrams_count !== 1 ? 's' : ''}</span>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )}

  <!-- SEO Content -->
  <section class="bg-gray-50 py-10 border-t border-gray-100">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-xl font-bold text-gray-800 mb-4">What is the NYT Spelling Bee?</h2>
      <p class="text-gray-600 leading-relaxed mb-3">The New York Times Spelling Bee is a daily word puzzle where players must find as many words as possible using seven letters arranged in a honeycomb pattern. Every word must include the center letter, must be at least four letters long, and each letter can be used multiple times. Words that use all seven letters are called "pangrams" and earn bonus points.</p>
      <p class="text-gray-600 leading-relaxed">SB Solver provides instant access to all Spelling Bee answers, hints, and statistics. Whether you're stuck on today's puzzle or want to analyze patterns across thousands of historical puzzles, our free tool has you covered. We update our database daily with the latest puzzle data from the NYT.</p>
    </div>
  </section>
</BaseLayout>
