---
import BaseLayout from './BaseLayout.astro';

export interface Props {
  puzzle: any;
  title: string;
  showWords?: boolean;
}

const { puzzle, title, showWords = true } = Astro.props;

const center = puzzle.letters || '';
const allLetters = puzzle.all_letters || '';
const outerLetters = allLetters.split('').filter(l => l !== center);
const pangrams = (puzzle.words || []).filter(w => w.is_pangram === 1);
const regularWords = (puzzle.words || []).filter(w => w.is_pangram !== 1);
const totalPoints = puzzle.totalPoints || 0;
const dateSlug = puzzle.date?.toLowerCase().replace(/,\s*/g, '-').replace(/\s+/g, '-') || '';
---

<BaseLayout title={title} description={`NYT Spelling Bee answers for ${puzzle.date}. Find all ${puzzle.word_count} words, ${puzzle.pangrams_count} pangrams, and hints.`}>
  <div class="max-w-6xl mx-auto px-4 py-8">
    <!-- Puzzle Header -->
    <div class="text-center mb-8">
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-2">
        Spelling Bee Answers
      </h1>
      <p class="text-lg text-gray-500">{puzzle.date}</p>
    </div>

    <!-- Honeycomb + Stats Row -->
    <div class="flex flex-col lg:flex-row gap-8 items-start">
      <!-- Left: Honeycomb -->
      <div class="flex-shrink-0 mx-auto lg:mx-0">
        <div class="relative w-48 h-52">
          <!-- Center hex -->
          <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-16 h-16 hex-shape hex-center flex items-center justify-center text-2xl z-10">
            {center}
          </div>
          <!-- Outer hexes positioned around center -->
          {outerLetters.map((letter, i) => {
            const angles = [270, 330, 30, 90, 150, 210]; // degrees
            const angle = (angles[i] || 0) * Math.PI / 180;
            const radius = 58;
            const x = 50 + radius * Math.cos(angle) / 96 * 100;
            const y = 50 + radius * Math.sin(angle) / 96 * 100;
            return (
              <div
                class="absolute w-14 h-14 hex-shape bg-gray-100 border-2 border-gray-200 flex items-center justify-center text-xl font-bold text-gray-700 hover:bg-amber-50 hover:border-amber-300 transition-colors cursor-default"
                style={`left: ${x}%; top: ${y}%; transform: translate(-50%, -50%);`}
              >
                {letter}
              </div>
            );
          })}
        </div>
        <div class="text-center mt-4">
          <p class="text-sm text-gray-500">
            Center: <span class="font-bold text-amber-600">{center}</span> &middot;
            Letters: <span class="font-semibold">{allLetters}</span>
          </p>
        </div>
      </div>

      <!-- Right: Stats + Word Lists -->
      <div class="flex-1 min-w-0 w-full">
        <!-- Stats Cards -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-6">
          <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
            <p class="text-2xl font-bold text-amber-600">{puzzle.word_count}</p>
            <p class="text-xs text-gray-500 mt-1">Words</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
            <p class="text-2xl font-bold text-amber-600">{puzzle.pangrams_count}</p>
            <p class="text-xs text-gray-500 mt-1">Pangrams</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
            <p class="text-2xl font-bold text-amber-600">{totalPoints}</p>
            <p class="text-xs text-gray-500 mt-1">Points</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-4 text-center">
            <p class="text-2xl font-bold text-amber-600">{puzzle.hasPerfectPangram ? '✓' : '✗'}</p>
            <p class="text-xs text-gray-500 mt-1">Perfect Pangram</p>
          </div>
        </div>

        {showWords && (
          <>
            <!-- Pangrams Section -->
            {pangrams.length > 0 && (
              <div class="mb-6">
                <h2 class="text-lg font-bold text-gray-800 mb-3 flex items-center gap-2">
                  <span class="text-amber-500">★</span> Pangrams
                </h2>
                <div class="flex flex-wrap gap-2">
                  {pangrams.map(w => (
                    <span class="pangram-word px-3 py-1.5 rounded-md text-sm border border-amber-200">
                      {w.word}
                      <span class="text-xs text-amber-400 ml-1">{w.length}</span>
                    </span>
                  ))}
                </div>
              </div>
            )}

            <!-- Words by Length -->
            <div>
              <h2 class="text-lg font-bold text-gray-800 mb-3">All Words</h2>
              <div class="bg-white rounded-xl border border-gray-200 divide-y divide-gray-100 max-h-96 overflow-y-auto custom-scroll">
                {(() => {
                  const byLen = {};
                  for (const w of regularWords) {
                    const l = w.length;
                    if (!byLen[l]) byLen[l] = [];
                    byLen[l].push(w);
                  }
                  return Object.keys(byLen).sort((a,b) => b-a).map(len => (
                    <div class="px-4 py-3">
                      <p class="text-xs font-semibold text-gray-400 mb-2">{len}-LETTER WORDS ({byLen[len].length})</p>
                      <div class="flex flex-wrap gap-1.5">
                        {byLen[len].map(w => (
                          <span class="word-item bg-gray-50 text-gray-700">{w.word}</span>
                        ))}
                      </div>
                    </div>
                  ));
                })()}
              </div>
            </div>
          </>
        )}
      </div>
    </div>

    <!-- SEO Content Block -->
    <div class="mt-10 prose prose-gray max-w-none">
      <h2 class="text-xl font-bold text-gray-800 mb-3">About Today's Spelling Bee</h2>
      <p>The New York Times Spelling Bee for {puzzle.date} features <strong>{center}</strong> as the center letter with outer letters <strong>{outerLetters.join(', ')}</strong>. There are <strong>{puzzle.word_count} words</strong> to find, including <strong>{puzzle.pangrams_count} pangram{puzzle.pangrams_count !== 1 ? 's' : ''}</strong> worth a total of <strong>{totalPoints} points</strong>.</p>
    </div>
  </div>
</BaseLayout>
