---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Solve NYT Spelling Bee puzzles instantly. Find all words, pangrams, and hints.' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <title>{title} | SB Solver</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Header -->
    <header class="bg-white/80 backdrop-blur-lg border-b border-gray-100 sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5 group">
          <svg width="36" height="40" viewBox="0 0 100 110" class="group-hover:scale-105 transition-transform">
            <polygon points="50,3 95,27.5 95,72.5 50,97 5,72.5 5,27.5" fill="#F7C948" stroke="#E8A317" stroke-width="3"/>
            <text x="50" y="62" font-family="system-ui,sans-serif" font-size="38" font-weight="900" fill="white" text-anchor="middle">B</text>
          </svg>
          <div>
            <span class="font-black text-lg text-gray-900 tracking-tight">SB Solver</span>
            <span class="hidden sm:block text-[10px] text-gray-400 font-medium -mt-0.5 tracking-wide">DAILY SPELLING BEE ANSWERS</span>
          </div>
        </a>
        <nav class="flex items-center gap-0.5 sm:gap-1">
          <a href="/today" class:list={["nav-link", currentPath === '/today' && '!bg-amber-50 !text-amber-700']}>Today</a>
          <a href="/yesterday" class:list={["nav-link", currentPath === '/yesterday' && '!bg-amber-50 !text-amber-700']}>Yesterday</a>
          <a href="/solver" class:list={["nav-link", currentPath === '/solver' && '!bg-amber-50 !text-amber-700']}>Solver</a>
          <a href="/archive" class:list={["nav-link", currentPath === '/archive' && '!bg-amber-50 !text-amber-700']}>Archive</a>
          <a href="/stats" class:list={["nav-link", currentPath === '/stats' && '!bg-amber-50 !text-amber-700']}>Stats</a>
        </nav>
      </div>
    </header>

    <main class="flex-1 page-enter">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-400 mt-auto">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
        <div class="grid sm:grid-cols-3 gap-8">
          <div>
            <div class="flex items-center gap-2 mb-3">
              <svg width="24" height="27" viewBox="0 0 100 110">
                <polygon points="50,3 95,27.5 95,72.5 50,97 5,72.5 5,27.5" fill="#F7C948" stroke="#E8A317" stroke-width="3"/>
                <text x="50" y="62" font-family="system-ui,sans-serif" font-size="38" font-weight="900" fill="white" text-anchor="middle">B</text>
              </svg>
              <span class="font-black text-white text-sm tracking-tight">SB Solver</span>
            </div>
            <p class="text-sm leading-relaxed">Get instant answers for the NYT Spelling Bee puzzle. Free, fast, and updated daily.</p>
          </div>
          <div>
            <h4 class="font-bold text-white text-sm mb-3">Quick Links</h4>
            <div class="space-y-2 text-sm">
              <a href="/today" class="block hover:text-amber-400 transition-colors">Today's Answers</a>
              <a href="/yesterday" class="block hover:text-amber-400 transition-colors">Yesterday's Answers</a>
              <a href="/solver" class="block hover:text-amber-400 transition-colors">Solver Tool</a>
              <a href="/archive" class="block hover:text-amber-400 transition-colors">Puzzle Archive</a>
              <a href="/stats" class="block hover:text-amber-400 transition-colors">Statistics</a>
            </div>
          </div>
          <div>
            <h4 class="font-bold text-white text-sm mb-3">About</h4>
            <p class="text-sm leading-relaxed">Not affiliated with The New York Times. Puzzle data sourced from public APIs. For educational and entertainment purposes only.</p>
          </div>
        </div>
        <div class="mt-8 pt-6 border-t border-gray-800 text-center text-xs text-gray-500">
          <p>&copy; {new Date().getFullYear()} SB Solver. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </body>
</html>
