---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  schema?: string;
}

const { title, description = 'Solve NYT Spelling Bee puzzles instantly. Find all words, pangrams, and hints with our free solver tool.', schema } = Astro.props;
const currentPath = Astro.url.pathname;
const siteName = 'SpellingBee Solver';
const siteDomain = 'https://spellingbeesolver.dev';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="SpellingBee Solver" />
    <link rel="canonical" href={`${siteDomain}${currentPath}`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <title>{title} | {siteName}</title>
    <!-- Open Graph -->
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${siteDomain}${currentPath}`} />
    <meta property="og:locale" content="en_US" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {schema && <script type="application/ld+json" set:html={schema} />}
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Header -->
    <header class="bg-white/80 backdrop-blur-lg border-b border-gray-100 sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5 group" aria-label="SpellingBee Solver Home">
          <svg width="36" height="40" viewBox="0 0 100 110" class="group-hover:scale-105 transition-transform" aria-hidden="true">
            <polygon points="50,3 95,27.5 95,72.5 50,97 5,72.5 5,27.5" fill="#F7C948" stroke="#E8A317" stroke-width="3"/>
            <text x="50" y="62" font-family="system-ui,sans-serif" font-size="38" font-weight="900" fill="white" text-anchor="middle">B</text>
          </svg>
          <div>
            <span class="font-black text-lg text-gray-900 tracking-tight">SpellingBee Solver</span>
            <span class="hidden sm:block text-[10px] text-gray-400 font-medium -mt-0.5 tracking-wide">DAILY SPELLING BEE ANSWERS</span>
          </div>
        </a>
        <!-- Mobile menu button (hidden on sm+) -->
        <button id="mobile-menu-btn" class="sm:hidden flex items-center justify-center w-10 h-10 rounded-lg text-gray-600 hover:bg-amber-50 hover:text-amber-700 transition-colors" aria-label="Open menu" aria-expanded="false">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>

        <!-- Desktop nav (hidden on mobile) -->
        <nav class="hidden sm:flex items-center gap-0.5 sm:gap-1" aria-label="Main navigation">
          <a href="/today" class:list={["nav-link", currentPath === '/today' && '!bg-amber-50 !text-amber-700']}>Today</a>
          <a href="/solver" class:list={["nav-link", currentPath === '/solver' && '!bg-amber-50 !text-amber-700']}>Solver</a>
          <a href="/archive" class:list={["nav-link", currentPath.startsWith('/archive') && '!bg-amber-50 !text-amber-700']}>Archive</a>
          <a href="/stats" class:list={["nav-link", currentPath === '/stats' && '!bg-amber-50 !text-amber-700']}>Stats</a>
          <a href="/blog" class:list={["nav-link", currentPath.startsWith('/blog') && '!bg-amber-50 !text-amber-700']}>Blog</a>
          <a href="/blog/spelling-bee-rules" class:list={["nav-link", currentPath === '/blog/spelling-bee-rules' && '!bg-amber-50 !text-amber-700']}>Rules</a>
        </nav>

        <!-- Mobile dropdown menu -->
        <div id="mobile-menu" class="hidden sm:hidden absolute top-full left-0 right-0 bg-white border-b border-gray-100 shadow-lg z-50">
          <nav class="max-w-6xl mx-auto px-4 py-3 space-y-1" aria-label="Mobile navigation">
            <a href="/today" class:list={["mobile-nav-link", currentPath === '/today' && '!text-amber-700 !bg-amber-50']}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              Today
            </a>
            <a href="/solver" class:list={["mobile-nav-link", currentPath === '/solver' && '!text-amber-700 !bg-amber-50']}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
              Solver
            </a>
            <a href="/archive" class:list={["mobile-nav-link", currentPath.startsWith('/archive') && '!text-amber-700 !bg-amber-50']}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              Archive
            </a>
            <a href="/stats" class:list={["mobile-nav-link", currentPath === '/stats' && '!text-amber-700 !bg-amber-50']}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/></svg>
              Stats
            </a>
            <a href="/blog" class:list={["mobile-nav-link", currentPath.startsWith('/blog') && '!text-amber-700 !bg-amber-50']}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
              Blog
            </a>
            <a href="/blog/spelling-bee-rules" class:list={["mobile-nav-link", currentPath === '/blog/spelling-bee-rules' && '!text-amber-700 !bg-amber-50']}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
              Rules
            </a>
          </nav>
        </div>
      </div>
    </header>

    <main class="flex-1 page-enter">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-400 mt-auto">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
          <div>
            <h4 class="font-bold text-white text-sm mb-3">ANSWERS</h4>
            <div class="space-y-2 text-sm">
              <a href="/today" class="block hover:text-amber-400 transition-colors">Today's Answers</a>
              <a href="/archive" class="block hover:text-amber-400 transition-colors">Puzzle Archive</a>
              <a href="/stats" class="block hover:text-amber-400 transition-colors">Statistics</a>
            </div>
          </div>
          <div>
            <h4 class="font-bold text-white text-sm mb-3">TOOLS</h4>
            <div class="space-y-2 text-sm">
              <a href="/solver" class="block hover:text-amber-400 transition-colors">Word Solver</a>
              <a href="/blog/spelling-bee-rules" class="block hover:text-amber-400 transition-colors">Spelling Bee Rules</a>
            </div>
          </div>
          <div>
            <h4 class="font-bold text-white text-sm mb-3">BLOG</h4>
            <div class="space-y-2 text-sm">
              <a href="/blog" class="block hover:text-amber-400 transition-colors">All Articles</a>
              <a href="/blog/spelling-bee-rules" class="block hover:text-amber-400 transition-colors">Rules Guide</a>
            </div>
          </div>
          <div>
            <div class="flex items-center gap-2 mb-3">
              <svg width="24" height="27" viewBox="0 0 100 110" aria-hidden="true">
                <polygon points="50,3 95,27.5 95,72.5 50,97 5,72.5 5,27.5" fill="#F7C948" stroke="#E8A317" stroke-width="3"/>
                <text x="50" y="62" font-family="system-ui,sans-serif" font-size="38" font-weight="900" fill="white" text-anchor="middle">B</text>
              </svg>
              <span class="font-black text-white text-sm tracking-tight">SpellingBee Solver</span>
            </div>
            <p class="text-sm leading-relaxed">Free NYT Spelling Bee solver and answer tool. Updated daily with the latest puzzle solutions, hints, and statistics. Not affiliated with The New York Times.</p>
            <p class="text-xs text-gray-500 mt-4">&copy; {new Date().getFullYear()} SpellingBee Solver. All rights reserved.</p>
          </div>
        </div>
      </div>
    </footer>
  <script>
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    if (menuBtn && mobileMenu) {
      menuBtn.addEventListener('click', () => {
        const isOpen = !mobileMenu.classList.contains('hidden');
        mobileMenu.classList.toggle('hidden');
        menuBtn.setAttribute('aria-expanded', String(!isOpen));
        // Swap hamburger to X icon
        menuBtn.innerHTML = isOpen
          ? '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>'
          : '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>';
      });
      // Close menu when clicking a link
      mobileMenu.querySelectorAll('a').forEach(a => {
        a.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
          menuBtn.setAttribute('aria-expanded', 'false');
          menuBtn.innerHTML = '<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>';
        });
      });
    }

    function storeArchiveSelection(link) {
      const slug = link.getAttribute('data-archive-slug') || '';
      const date = link.getAttribute('data-archive-date') || '';
      if (slug) {
        sessionStorage.setItem('sb_archive_slug', slug);
      }
      if (date) {
        sessionStorage.setItem('sb_archive_date', date);
      }
      return { slug, date };
    }

    document.addEventListener('click', (event) => {
      const link = event.target.closest('a[data-archive-slug]');
      if (!link) return;

      const detail = storeArchiveSelection(link);
      const onArchivePage = window.location.pathname === '/archive' || window.location.pathname === '/archive/';

      if (onArchivePage) {
        event.preventDefault();
        window.dispatchEvent(new CustomEvent('sb:archive-select', { detail }));
      }
    });
  </script>
  </body>
</html>
