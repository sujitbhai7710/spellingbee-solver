---
import BaseLayout from '../layouts/BaseLayout.astro';
import Honeycomb from '../components/Honeycomb.astro';
import { API_BASE } from '../lib/utils';

const res = await fetch(`${API_BASE}/yesterday`);
const data = await res.json();
const puzzle = data.puzzle || {};
const words = data.words || [];
const totalPoints = data.totalPoints || 0;
const hasPerfectPangram = data.hasPerfectPangram || false;
const perfectPangrams = data.perfectPangrams || [];
const geniusThreshold = Math.ceil(totalPoints * 0.70);

const center = puzzle.letters || '';
const allLetters = puzzle.all_letters || '';
const outerLetters = allLetters.split('').filter(l => l !== center);
const pangrams = words.filter(w => w.is_pangram === 1);
const regularWords = words.filter(w => w.is_pangram !== 1);

// Group words by length
const wordsByLength = {};
for (const w of regularWords) {
  const l = w.length;
  if (!wordsByLength[l]) wordsByLength[l] = [];
  wordsByLength[l].push(w);
}
const sortedLengths = Object.keys(wordsByLength).sort((a,b) => +b - +a);

// Words by first letter
const wordsByFirstLetter = {};
for (const w of words) {
  const first = w.word[0]?.toUpperCase();
  if (!first) continue;
  if (!wordsByFirstLetter[first]) wordsByFirstLetter[first] = { count: 0, isPangram: false };
  wordsByFirstLetter[first].count++;
  if (w.is_pangram === 1) wordsByFirstLetter[first].isPangram = true;
}
const sortedFirstLetters = Object.keys(wordsByFirstLetter).sort();
const maxFirstLetterCount = Math.max(...Object.values(wordsByFirstLetter).map(v => v.count), 1);

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": `What were the NYT Spelling Bee answers for ${puzzle.date}?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": `The NYT Spelling Bee for ${puzzle.date} had ${puzzle.word_count} words and ${puzzle.pangrams_count} pangram${puzzle.pangrams_count !== 1 ? 's' : ''}. Center letter: ${center}. Outer letters: ${outerLetters.join(', ')}. Maximum score: ${totalPoints} points.`
      }
    },
    {
      "@type": "Question",
      "name": `Did yesterday's Spelling Bee have a perfect pangram?`,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": hasPerfectPangram ? `Yes. The perfect pangram${perfectPangrams.length > 1 ? 's were' : ' was'} ${perfectPangrams.join(', ').toUpperCase()}.` : 'No, there was no perfect pangram in yesterday\'s puzzle.'
      }
    }
  ]
});
---

<BaseLayout title="Yesterday's NYT Spelling Bee Answers" description={`NYT Spelling Bee answers for ${puzzle.date}. All ${puzzle.word_count} words, ${puzzle.pangrams_count} pangrams, and hints. Center letter: ${center}.`} schema={faqSchema}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 py-8">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center gap-3 mb-2">
        <span class="badge badge-slate">Yesterday</span>
        <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">Spelling Bee Answers</h1>
      </div>
      <p class="text-gray-500 font-medium">{puzzle.date}</p>
    </div>

    <!-- Honeycomb + Stats -->
    <div class="flex flex-col sm:flex-row items-center sm:items-start gap-8 mb-8">
      <div class="flex-shrink-0">
        <Honeycomb center={center} outer={outerLetters} size="md" />
      </div>
      <div class="flex-1 w-full">
        <div class="grid grid-cols-2 gap-3 mb-5">
          <div class="stat-card">
            <p class="stat-value">{puzzle.word_count}</p>
            <p class="stat-label">Words</p>
          </div>
          <div class="stat-card">
            <p class="stat-value">{puzzle.pangrams_count}</p>
            <p class="stat-label">Pangrams</p>
          </div>
          <div class="stat-card">
            <p class="stat-value">{totalPoints}</p>
            <p class="stat-label">Max Points</p>
          </div>
          <div class="stat-card">
            <p class="stat-value">{hasPerfectPangram ? 'Yes' : '\u2014'}</p>
            <p class="stat-label">Perfect Pangram</p>
          </div>
        </div>
        <div class="text-sm text-gray-500 mb-2">
          <span class="font-semibold text-purple-600">Genius threshold:</span> {geniusThreshold} points
        </div>
        <div class="text-sm text-gray-500">
          <span class="font-semibold text-gray-700">Center:</span> <span class="letter-circle letter-circle-center !w-7 !h-7 !text-xs inline-flex">{center}</span>
          <span class="mx-2 text-gray-300">|</span>
          <span class="font-semibold text-gray-700">Letters:</span> {allLetters.split('').map((l) => <span class:list={['inline-flex items-center justify-center w-6 h-6 rounded text-xs font-bold mx-0.5', l === center ? 'bg-amber-100 text-amber-700' : 'bg-gray-100 text-gray-600']}>{l}</span>)}
        </div>
      </div>
    </div>

    <!-- Spoiler Reveal -->
    <div class="mb-6">
      <button id="reveal-answers-btn" class="btn-secondary text-sm !py-2.5 w-full sm:w-auto" type="button">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
        Show All Answers
      </button>
      <p class="text-xs text-gray-400 mt-1.5">Spoilers ahead! Click to reveal the complete word list.</p>
    </div>

    <div id="answers-container" class="hidden">
      <!-- Perfect Pangrams -->
      {hasPerfectPangram && perfectPangrams.length > 0 && (
        <div class="mb-6 p-4 bg-emerald-50 border border-emerald-200 rounded-xl">
          <h2 class="text-sm font-bold text-emerald-800 mb-2 flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="#10B981"><circle cx="10" cy="10" r="9" fill="none" stroke="#10B981" stroke-width="2"/><path d="M6 10l3 3 5-5" fill="none" stroke="#10B981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Perfect Pangram{perfectPangrams.length > 1 ? 's' : ''}!
          </h2>
          <div class="flex flex-wrap gap-2">
            {perfectPangrams.map(w => (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-emerald-100 border border-emerald-300 rounded-lg text-sm font-bold text-emerald-800 uppercase">{w}</span>
            ))}
          </div>
        </div>
      )}

      <!-- Pangrams -->
      {pangrams.length > 0 && (
        <div class="mb-8">
          <h2 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="#F59E0B"><path d="M10 1l2.39 4.84 5.34.78-3.87 3.77.91 5.33L10 13.27l-4.77 2.51.91-5.33L2.27 6.62l5.34-.78z"/></svg>
            Pangrams ({pangrams.length})
          </h2>
          <div class="flex flex-wrap gap-2">
            {pangrams.map(w => (
              <span class="pangram-chip">
                <span class="star">&#9733;</span>
                {w.word}
                <span class="text-xs text-amber-500 opacity-70">{w.length}</span>
              </span>
            ))}
          </div>
        </div>
      )}

      <!-- All Words -->
      <div>
        <h2 class="text-lg font-bold text-gray-800 mb-4">All Words ({words.length})</h2>
        <div class="card-elevated divide-y divide-gray-50 max-h-[600px] overflow-y-auto custom-scroll">
          {sortedLengths.map(len => (
            <div class="px-5 py-4">
              <p class="text-xs font-bold text-gray-400 mb-3 uppercase tracking-wider">{len}-Letter Words ({wordsByLength[len].length})</p>
              <div class="flex flex-wrap gap-2">
                {wordsByLength[len].map(w => (
                  <span class="word-chip">{w.word}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Words by First Letter -->
      <div class="mt-8 card-elevated p-6">
        <h2 class="text-lg font-bold text-gray-800 mb-4">Words by First Letter</h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          {sortedFirstLetters.map(letter => {
            const info = wordsByFirstLetter[letter];
            const barWidth = Math.max((info.count / maxFirstLetterCount) * 100, 8);
            return (
              <div class:list={['p-3 rounded-xl border', info.isPangram ? 'border-amber-200 bg-amber-50' : 'border-gray-100 bg-white']}>
                <div class="flex items-center justify-between mb-2">
                  <span class:list={['text-lg font-black', info.isPangram ? 'text-amber-600' : 'text-gray-700']}>{letter}</span>
                  <span class="text-sm font-bold text-gray-500">{info.count}</span>
                </div>
                <div class="w-full bg-gray-100 rounded-full h-2">
                  <div class:list={['h-2 rounded-full', info.isPangram ? 'bg-amber-400' : 'bg-gray-300']} style={`width: ${barWidth}%`}></div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>

    <!-- SEO Content -->
    <div class="mt-10 p-6 bg-gray-50 rounded-2xl">
      <h2 class="text-lg font-bold text-gray-800 mb-3">Yesterday's Spelling Bee Puzzle Breakdown</h2>
      <p class="text-gray-600 leading-relaxed text-sm mb-3">The NYT Spelling Bee for <strong>{puzzle.date}</strong> featured center letter <strong>{center}</strong> with outer letters <strong>{outerLetters.join(', ')}</strong>. Players searched for words that include the center letter and are at least four letters long, using each letter as many times as needed.</p>
      <p class="text-gray-600 leading-relaxed text-sm mb-3">This puzzle contained <strong>{puzzle.word_count} valid words</strong> and <strong>{puzzle.pangrams_count} pangram{puzzle.pangrams_count !== 1 ? 's' : ''}</strong> with a maximum possible score of <strong>{totalPoints} points</strong>. {hasPerfectPangram ? `It included a perfect pangram: <strong>${perfectPangrams.join(', ').toUpperCase()}</strong>.` : 'No perfect pangram appeared in this puzzle.'} The Genius threshold was {geniusThreshold} points, requiring 70% of the maximum score.</p>
      <p class="text-gray-600 leading-relaxed text-sm mb-3">Word lengths ranged from 4 to {sortedLengths[0] || '?'} letters. {pangrams.length > 0 ? `The pangram${pangrams.length > 1 ? 's' : ''} in this puzzle ${pangrams.length > 1 ? 'were' : 'was'} ${pangrams.map(w => w.word).join(', ')}, each using all seven available letters.` : ''} Finding pangrams is key to reaching higher score tiers because of the 7-point bonus they carry.</p>
      <p class="text-gray-600 leading-relaxed text-sm">Reviewing past puzzles is one of the best ways to improve at the Spelling Bee. Patterns in letter combinations, common word structures, and pangram frequency all become more familiar with practice. Browse our archive for thousands of past puzzles with complete answer lists and scoring data.</p>
    </div>

    <!-- FAQ Section -->
    <div class="mt-8">
      <h2 class="text-lg font-bold text-gray-800 mb-4">Frequently Asked Questions</h2>
      <div class="space-y-3">
        <details class="card-elevated p-5 group" open>
          <summary class="font-semibold text-gray-800 cursor-pointer flex items-center justify-between">What were the Spelling Bee answers for {puzzle.date}?
            <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="text-sm text-gray-600 mt-3 leading-relaxed">The Spelling Bee for {puzzle.date} had {puzzle.word_count} words and {puzzle.pangrams_count} pangram{puzzle.pangrams_count !== 1 ? 's' : ''}. Center letter: {center}. Available letters: {allLetters.split('').join(', ')}. Click "Show All Answers" above to see the full list.</p>
        </details>
        <details class="card-elevated p-5 group">
          <summary class="font-semibold text-gray-800 cursor-pointer flex items-center justify-between">Did yesterday's puzzle have a perfect pangram?
            <svg class="w-4 h-4 text-gray-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="text-sm text-gray-600 mt-3 leading-relaxed">{hasPerfectPangram ? `Yes, the perfect pangram was <strong>${perfectPangrams.join(', ').toUpperCase()}</strong>. It uses all seven letters exactly once.` : 'No, yesterday\'s puzzle did not contain a perfect pangram.'}</p>
        </details>
      </div>
    </div>
  </div>

  <script>
    document.getElementById('reveal-answers-btn')?.addEventListener('click', function() {
      const container = document.getElementById('answers-container');
      if (container) {
        container.classList.remove('hidden');
        this.style.display = 'none';
      }
    });
  </script>
</BaseLayout>
